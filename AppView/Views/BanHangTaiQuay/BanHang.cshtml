    // Validate form giao hàng
    function validateFormGiaoHang() {
        let isValid = true;

        // Validate tên người nhận
        if (!$('#tenNguoiNhan').val().trim()) {
            $('#tenNguoiNhan').addClass('is-invalid');
            isValid = false;
        }

        // Validate số điện thoại
        const phoneRegex = /^(0[3|5|7|8|9])+([0-9]{8})$/;
        if (!phoneRegex.test($('#sdtNguoiNhan').val())) {
            $('#sdtNguoiNhan').addClass('is-invalid');
            isValid = false;
        }

        // Validate tỉnh/thành phố
        if (!$('#tinhThanh').val()) {
            $('#tinhThanh').addClass('is-invalid');
            isValid = false;
        }

        // Validate quận/huyện
        if (!$('#quanHuyen').val()) {
            $('#quanHuyen').addClass('is-invalid');
            isValid = false;
        }

        // Validate xã/phường
        if (!$('#xaPhuong').val()) {
            $('#xaPhuong').addClass('is-invalid');
            isValid = false;
        }

        // Validate địa chỉ chi tiết
        if (!$('#diaChiChiTiet').val().trim()) {
            $('#diaChiChiTiet').addClass('is-invalid');
            isValid = false;
        }

        return isValid;
    }

