            chonKhachHang(currentKhachHang || KHACH_LE);

            const addressInfo = kiemTraDiaChi();
            if (addressInfo && addressInfo.hasRequiredAddress) {
                tinhPhiShipTuDong();
            }
        } else {
            phiShip = 0;
            $('#phiShip').text('0 đ');
            $('#phiShipRow').addClass('d-none');
            capNhatTongTien();
        }
