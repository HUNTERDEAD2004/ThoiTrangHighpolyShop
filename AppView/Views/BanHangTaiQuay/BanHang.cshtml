@using AppData.Models
@using AppData.ViewModels
@using Newtonsoft.Json
@{
    ViewData["Title"] = "BanHang";
    var lsthdcho = ViewData["lsthdcho"] as List<HoaDon>;
    var loginInfor = new LoginViewModel();
    string? session = Context.Session.GetString("LoginInfor");
    if (session != null)
    {
        loginInfor = JsonConvert.DeserializeObject<LoginViewModel>(Context.Session.GetString("LoginInfor"));
    }
    <style>
        .box-section {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 16px;
        background-color: #fff;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        margin-bottom: 16px;
        }

        .section-title {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 0.9rem;
        }

        .tabs-box {
        overflow-x: auto;
        display: flex;
        gap: 10px;
        padding: 8px 10px;
        list-style: none;
        }

        .tab {
        background-color: #f1f3f5;
        border-radius: 5px;
        padding: 6px 12px;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        font-size: 0.9rem;
        }

        .tab:hover,
        .tab.active {
        background-color: #cde1ff;
        }

        .form-control, .form-select {
        font-size: 0.9rem;
        padding: 0.4rem 0.75rem;
        height: 38px;
        }

        .invalid-feedback {
        font-size: 0.75rem;
        }

        .is-invalid {
        border-color: #dc3545 !important;
        }

        .address-section {
        background-color: #f8f9fa;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 12px;
        }

        .address-section-title {
        font-weight: 600;
        margin-bottom: 8px;
        color: #4154f1;
        font-size: 0.9rem;
        }

        .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.8rem;
        }

        /* Modal styling */
        .modal-content {
        border-radius: 12px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.15);
        }

        .modal-header {
        background-color: #4154f1;
        color: white;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
        padding: 12px 20px;
        }

        .modal-title {
        font-size: 1.1rem;
        font-weight: 600;
        }

        .btn-close {
        filter: invert(1);
        }

        .form-check-input:checked {
        background-color: #4154f1;
        border-color: #4154f1;
        }

        /* Compact form layout */
        .compact-form .row {
        margin-bottom: 0.5rem;
        }

        .compact-form .form-label {
        margin-bottom: 0.3rem;
        font-size: 0.85rem;
        }

        .product-list-container {
        border: 1px solid #dee2e6;
        border-radius: 5px;
        }

        .product-item {
        transition: background-color 0.2s;
        padding: 10px;
        border-radius: 5px;
        }

        .product-item:hover {
        background-color: #f8f9fa;
        }

        .product-item img {
        object-fit: cover;
        }

        .modal {
        backdrop-filter: blur(3px);
        }

        .modal-content {
        border: none;
        box-shadow: 0 5px 25px rgba(0,0,0,0.15);
        }

        @@keyframes spin {
        0% {
        transform: rotate(0deg);
        }

        100% {
        transform: rotate(360deg);
        }
        }

        .spinner {
        animation: spin 1s linear infinite;
        }

        /* Tùy chỉnh thêm cho voucher */
        #voucherCount {
        font-size: 0.7rem;
        padding: 0.25em 0.4em;
        }

        .voucher-detail {
        background-color: #f8fff8;
        border: 1px solid #d4edda;
        border-radius: 4px;
        padding: 8px;
        margin-top: 5px;
        font-size: 0.85rem;
        }

        .voucher-detail a {
        font-size: 0.8rem;
        }

        #voucherSelect optgroup {
        font-weight: bold;
        font-style: normal;
        }

        #voucherSelect option {
        padding: 4px 8px;
        }

        .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.8rem;
        }

        .btn-danger {
        background-color: #dc3545;
        border-color: #dc3545;
        }

        .btn-danger:hover {
        background-color: #bb2d3b;
        border-color: #b02a37;
        }

        /* Thêm vào phần CSS */
        .input-group-sm {
        width: 120px;
        }

        .btn-minus, .btn-plus {
        width: 30px;
        padding: 0.25rem 0.5rem;
        }

        .so-luong-sp {
        width: 40px;
        text-align: center;
        padding: 0.25rem 0.5rem;
        }

        /* Đảm bảo input number không hiện mũi tên */
        .so-luong-sp::-webkit-outer-spin-button,
        .so-luong-sp::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
        }

        .so-luong-sp {
        -moz-appearance: textfield;
        }

        /* Hiệu ứng khi disabled */
        .so-luong-sp:disabled {
        background-color: #f8f9fa;
        opacity: 0.7;
        }

        /* Đảm bảo các phần tử ẩn hoàn toàn khi cần */
        .d-none {
        display: none !important;
        }
    </style>
}

<div class="container-fluid py-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <ul class="tabs-box">
            @if (lsthdcho != null)
            {
                var index = 1;
                foreach (var item in lsthdcho)
                {
                    <li class="tab" onclick="gethdct('@item.ID')">
                        <span value="@item.ID">
                            @(item.TrangThaiGiaoHang == 1 ? $"HĐ {index++}" : item.GhiChu)
                            <a style="padding-left: 8px; color:red; font-size:0.8rem;" onclick="event.stopPropagation(); deleteHDCho('@item.ID')">
                                <i class="fas fa-times"></i>
                            </a>
                        </span>
                    </li>
                }
            }
        </ul>
        <button class="btn btn-success btn-sm" onclick="addHDCho()">
            <i class="fas fa-plus me-1"></i> Tạo hóa đơn
        </button>
    </div>
</div>

<!-- Giao diện chính -->
<div id="mainPOSForm">
    <div class="row g-2">
        <div class="col-12">
            <div class="box-section">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-bold">Giỏ hàng</div>
                    <button class="btn btn-light border btn-sm" onclick="moModalSanPham()">
                        <i class="bi bi-plus"></i> Thêm sản phẩm
                    </button>
                </div>

                <div id="invoicePages">
                    @if (lsthdcho != null && lsthdcho.Count > 0)
                    {
                        var index = 1;
                        foreach (var item in lsthdcho)
                        {
                            <div class="invoice-page" id="page-@item.ID" style="display:none;">
                                <div class="gioHangContent" data-id="@item.ID">
                                    <p class="text-muted mb-0">Chưa có sản phẩm nào.</p>
                                </div>
                            </div>
                            index++;
                        }
                    }
                    else
                    {
                        <div class="invoice-page" id="page-empty">
                            <p class="text-muted mb-0">Chưa có hóa đơn nào. Vui lòng tạo mới.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-2 mt-2">
        <!-- Cột: Giao hàng -->
      
            <div class="col-md-4">
                <div class="box-section">
                    <div class="mb-2">
                        <label class="section-title">Khách Hàng</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control form-control-sm" id="khachHangDisplay"
                                   placeholder="Chọn khách hàng" readonly value="khachle">
                            <input type="hidden" id="khachHangId" value="e106c66d-f18d-4609-8a38-08e09d68e78c">
                            <button class="btn btn-outline-secondary" type="button" onclick="moModalKhachHang()">
                                <i class="bi bi-person"></i>
                            </button>
                            <button class="btn btn-outline-secondary" type="button" onclick="taoKhachHangNhanh()">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="fw-bold">Giao hàng</div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="giaoHang" onchange="toggleGiaoHangForm()">
                        </div>
                    </div>

                    <!-- Form giao hàng (ẩn mặc định) -->
                    <div id="formGiaoHang" style="display: none;" class="compact-form">
                        <div class="address-section">
                            <div class="address-section-title">Thông tin người nhận</div>

                            <div class="mb-2">
                                <input type="text" class="form-control form-control-sm" id="tenNguoiNhan" placeholder="Tên người nhận">
                                <div class="invalid-feedback">Vui lòng nhập tên</div>
                            </div>

                            <div class="mb-2">
                                <input type="text" class="form-control form-control-sm" id="sdtNguoiNhan" placeholder="Số điện thoại">
                                <div class="invalid-feedback">Số điện thoại không hợp lệ</div>
                            </div>
                        </div>

                        <div class="address-section">
                            <div class="address-section-title">Địa chỉ giao hàng</div>

                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="selectDiaChi" onchange="chonDiaChiTuDanhSach()">
                                    <option value="">-- Chọn địa chỉ có sẵn --</option>
                                </select>
                            </div>

                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="tinhThanh" onchange="loadQuanHuyen()">
                                    <option value="">Tỉnh/Thành phố</option>
                                </select>
                                <div class="invalid-feedback">Vui lòng chọn tỉnh/thành phố</div>
                            </div>

                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="quanHuyen" onchange="loadXaPhuong()">
                                    <option value="">Quận/Huyện</option>
                                </select>
                                <div class="invalid-feedback">Vui lòng chọn quận/huyện</div>
                            </div>

                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="xaPhuong">
                                    <option value="">Xã/Phường</option>
                                </select>
                                <div class="invalid-feedback">Vui lòng chọn xã/phường</div>
                            </div>

                            <div class="mb-2">
                                <input type="text" class="form-control form-control-sm" id="diaChiChiTiet" placeholder="Địa chỉ chi tiết">
                                <div class="invalid-feedback">Vui lòng nhập địa chỉ</div>
                            </div>
                        </div>
                        @* 
                    <div class="alert alert-info mt-2 py-2" id="phiShipResult" style="display: none;">
                        <small>Phí ship: <span id="phiShipValue">0</span> VNĐ</small>
                    </div> *@
                    </div>
                </div>
            </div>

            
        
        
        <!-- Form Thanh toán -->
        <div class="col-md-8">
            <div class="box-section">
                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <label class="section-title d-flex justify-content-between align-items-center">
                            <span>Voucher giảm giá</span>
                            <span class="badge bg-secondary" id="voucherCount">0 voucher</span>
                        </label>
                        <select class="form-select form-select-sm" id="voucherSelect" onchange="chonVoucher()">
                            <option value="" selected>-- Đang tải voucher --</option>
                        </select>
                        <div id="voucherInfo" class="mt-2 small text-success" style="display: none;"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="section-title">Hình thức thanh toán</label>
                        <select class="form-select form-select-sm" id="hinhThucThanhToan" onchange="onHinhThucThanhToanChange()">
                            <option value="tienmat" selected>Tiền mặt</option>
                            <option value="chuyenkhoan">Chuyển khoản</option>
                        </select>
                    </div>
                </div>

                <hr class="my-2">

                <div id="thanhToanSection">
                    <div class="fw-bold mb-2">Thanh toán</div>

                    <div class="row align-items-center mb-1">
                        <div class="col-6">
                            <small>Tổng tiền hàng:</small>
                        </div>
                        <div class="col-6 text-end">
                            <span id="tongTien" class="fw-bold">0 đ</span>
                        </div>
                    </div>

                    <div class="row align-items-center mb-1" id="voucherDiscountRow" style="display: none;">
                        <div class="col-6">
                            <small>Giảm giá voucher:</small>
                        </div>
                        <div class="col-6 text-end">
                            <span id="voucherDiscount" class="fw-bold text-success">0 đ</span>
                        </div>
                    </div>

                    <div class="row align-items-center mb-1 d-none" id="phiShipRow">
                        <div class="col-6">
                            <small>Phí ship:</small>
                        </div>
                        <div class="col-6 text-end">
                            <span id="phiShip" class="fw-bold">0 đ</span>
                        </div>
                    </div>

                    <div class="row align-items-center mb-2">
                        <div class="col-6">
                            <small>Thành tiền:</small>
                        </div>
                        <div class="col-6 text-end">
                            <span id="thanhTien" class="fw-bold">0 đ</span>
                        </div>
                    </div>

                    <div class="row align-items-center mb-2" id="khachPhaiTraRow">
                        <div class="col-6">
                            <small>Khách phải trả:</small>
                        </div>
                        <div class="col-6 text-end">
                            <span id="khachPhaiTra" class="fw-bold text-danger">0 đ</span>
                        </div>
                    </div>

                    <div class="row align-items-center mb-2" id="tienKhachDuaRow">
                        <div class="col-6">
                            <small>Tiền khách đưa:</small>
                        </div>
                        <div class="col-6">
                            <input type="number" class="form-control form-control-sm" id="tienKhachDua" value="0" onchange="updateTienThua()">
                        </div>
                    </div>

                    <div class="row align-items-center mb-3" id="tienThuaRow">
                        <div class="col-6">
                            <small>Tiền thừa:</small>
                        </div>
                        <div class="col-6 text-end">
                            <span id="tienThua" class="fw-bold text-success">0 đ</span>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-primary" onclick="thanhToanHoaDon()">
                            <i class="bi bi-credit-card me-1"></i> Thanh toán
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal thanh toán -->
<div class="modal border-0 rounded-0" id="thanhtoan" tabindex="-1">
    <div class="modal-dialog" id="modalthanhtoan">
        <div class="modal-content" id="modalthanhtoan-content">
            <div class="modal-body" id="thanhtoanbody"></div>
        </div>
    </div>
</div>

<!-- Modal Sản phẩm -->
<div class="modal fade" id="sanpham" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary py-2">
                <h6 class="modal-title text-white mb-0">Thêm sản phẩm vào giỏ</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-3">
                <div class="mb-3">
                    <label class="section-title">Tìm sản phẩm</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" placeholder="Nhập tên sản phẩm..." id="searchProduct">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                    </div>
                </div>

                <div class="product-list-container" style="max-height: 400px; overflow-y: auto;">
                    <ul class="product-list list-unstyled mb-0">
                        <li class="text-center py-4 text-muted">
                            <i class="bi bi-search display-4"></i>
                            <p class="mt-2">Nhập từ khóa để tìm sản phẩm</p>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal chọn khách hàng -->
<div class="modal fade" id="modalKhachHang" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title mb-0">Chọn khách hàng</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <div class="input-group input-group-sm mb-2">
                    <input type="text" class="form-control" placeholder="Tìm khách hàng..." id="searchKhachHang">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tableKhachHang">
                        <thead>
                            <tr>
                                <th>Mã KH</th>
                                <th>Tên</th>
                                <th>SĐT</th>
                                <th width="80">Chọn</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Danh sách khách hàng sẽ được load ở đây -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Tạo Khách Hàng -->
<div class="modal fade" id="modalTaoKhachHang" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title mb-0">Tạo khách hàng nhanh</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <div id="validatekh" class="text-danger mb-2 small"></div>
                <form id="formTaoKhachHang">
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <input type="text" class="form-control form-control-sm" id="inputTenKhachHang" placeholder="Tên khách hàng" required>
                        </div>
                        <div class="col-md-6">
                            <input type="text" class="form-control form-control-sm" id="inputSDT" placeholder="Số điện thoại">
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <input type="email" class="form-control form-control-sm" id="inputEmail" placeholder="Email">
                        </div>
                        <div class="col-md-6">
                            <input type="date" class="form-control form-control-sm" id="inputNgaySinh">
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
