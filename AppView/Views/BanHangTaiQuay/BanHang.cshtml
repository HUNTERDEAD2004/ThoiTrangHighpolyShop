    // ===== Sửa hàm tinhPhiShipTuDong =====
    function tinhPhiShipTuDong() {
        // Kiểm tra xem có bật giao hàng không
        if (!$("#giaoHang").is(":checked")) {
            phiShip = 0;
            $('#phiShip').text('0 đ');
            $('#phiShipRow').addClass('d-none');
            capNhatTongTien();
            return;
        }

        // Validate form giao hàng
        if (!validateFormGiaoHang()) {
            phiShip = 0;
            $('#phiShip').text('0 đ');
            $('#phiShipRow').addClass('d-none');
            capNhatTongTien();
            return;
        }

        var wardCode = $("#xaPhuong").val();
        var districtId = $("#quanHuyen").val();

        if (!wardCode || !districtId) {
            phiShip = 0;
            $('#phiShip').text('0 đ');
            $('#phiShipRow').addClass('d-none');
            capNhatTongTien();
            return;
        }

        // ĐẢM BẢO LUÔN CÓ ID HÓA ĐƠN TRƯỚC KHI TÍNH TOÁN
        const activeTab = $(".tabs-box .tab.active");
        if (!activeTab.length) {
            phiShip = 0;
            $('#phiShip').text('0 đ');
            $('#phiShipRow').addClass('d-none');
            capNhatTongTien();
            return;
        }

        const idHoaDon = activeTab.find("span").attr("value");

        // Tính tổng trọng lượng từ giỏ hàng
        let totalWeight = 0;

        // Kiểm tra xem giỏ hàng có tồn tại không
        const gioHangElement = $(`.gioHangContent[data-id="${idHoaDon}"]`);
        if (gioHangElement.length === 0) {
            totalWeight = 1000; // 1kg mặc định
        } else {
            // Tính trọng lượng dựa trên số lượng sản phẩm trong giỏ hàng
            $(`.gioHangContent[data-id="${idHoaDon}"] tr`).each(function() {
                const soLuong = parseInt($(this).find('.so-luong-sp').val()) || 0;
                totalWeight += soLuong * 500; // Mỗi sản phẩm 500g
            });

            // Nếu không có sản phẩm, sử dụng trọng lượng mặc định
            if (totalWeight === 0) {
                totalWeight = 1000; // 1kg mặc định
            }
        }

        // Hiển thị trạng thái đang tính phí
        $('#phiShip').html('<i class="bi bi-arrow-repeat spinner"></i> Đang tính...');
        $('#phiShipRow').removeClass('d-none');

        $.ajax({
            type: "GET",
            url: "https://online-gateway.ghn.vn/shiip/public-api/v2/shipping-order/fee",
            headers: {
                token: GHN_TOKEN,
                "Content-Type": "application/json"
            },
            data: {
                from_district_id: 1454, // ID quận nơi shop đặt (CẦN THAY ĐỔI THEO THỰC TẾ)
                service_type_id: 2,
                to_district_id: districtId,
                to_ward_code: wardCode,
                weight: totalWeight,
                length: 20,
                width: 15,
                height: 10,
                insurance_value: 0,
                coupon: null
            },
            success: function (data) {
                if (data.code === 200) {
                    phiShip = data.data.total;
                    $('#phiShip').text(phiShip.toLocaleString('vi-VN') + ' đ');
                    $('#phiShipRow').removeClass('d-none');

                    // Cập nhật tổng tiền
                    capNhatTongTien();

                    toastr.success("Đã tính phí ship thành công", "Thông báo", { timeOut: 2000 });
                } else {
                    console.error("Lỗi tính phí ship:", data.message);
                    $('#phiShip').text('0 đ');
                    phiShip = 0;
                    capNhatTongTien();
                    toastr.error("Không thể tính phí ship", "Lỗi", { timeOut: 3000 });
                }
            },
            error: function (xhr, status, error) {
                console.error("Lỗi khi tính phí ship:", error);
                $('#phiShip').text('0 đ');
                phiShip = 0;
                capNhatTongTien();
                toastr.error("Lỗi kết nối khi tính phí ship", "Lỗi", { timeOut: 3000 });
            }
        });
    }

