    // Hàm tính tiền thừa trả khách (FIXED)
    function updateTienThua() {
        // Lấy thành tiền (đã bao gồm cả phí ship và giảm giá voucher)
        const thanhTienText = $('#khachPhaiTra').text().replace(' đ', '').replace(/\./g, '');
        const thanhTien = parseFloat(thanhTienText) || 0;

        const tienKhachDua = parseFloat($('#tienKhachDua').val()) || 0;
        const tienThua = tienKhachDua - thanhTien;

        $('#tienThua').text(tienThua >= 0 ? tienThua.toLocaleString('vi-VN') + ' đ' : '0 đ');
    }

