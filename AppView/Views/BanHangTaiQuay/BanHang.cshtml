        if (hinhThuc === "tienmat") {
            idPhuongThucTT = "9b6289bf-5e83-419a-94d5-926abb264961"; // GUID tiền mặt
        } else if (hinhThuc === "chuyenkhoan") {
            idPhuongThucTT = "f29cd85d-0251-4b50-8867-6a88891417f6"; // GUID chuyển khoản
        }

        $.ajax({
            url: "/BanHangTaiQuay/AddHDCho",
            type: "POST",
            dataType: 'json',
            data: { idKhachHang: idKhachHang, idPhuongThucTT: idPhuongThucTT },
            success: function (response) {
                if (response.success) {
                    loadHDCHO(function () { activeTab(1); });
                } else {
                    toastr.error(response.message, "Error Alert", { timeOut: 1000 });
                }
            },
            error: function () {
                toastr.error('Thêm thất bại', "Error Alert", { timeOut: 1000 });
            }
        });
    }


    // ===== Xóa hóa đơn chờ =====
    function deleteHDCho(idhd) {
        Swal.fire({
            title: 'Xóa hóa đơn chờ?',
            text: "Hành động này không thể hoàn tác!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Vâng, xóa ngay!',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: `/BanHangTaiQuay/deleteHd/${idhd}`, // Đảm bảo có phương thức này trong controller
                    type: "DELETE",
                    dataType: 'json',
                    contentType: 'application/json',
                    success: function (response) {
                        if (response.success) {
                            toastr.success(response.message);

                            // Load lại danh sách hóa đơn
                            loadHDCHO(function () {
                                var remainingTabs = $(".tabs-box .tab");
                                if (remainingTabs.length > 0) {
                                    activeTab(0);
                                } else {
                                    $(".product-list").empty();
                                    toggleProductSection(false);
                                }
                            });
                        } else {
                            toastr.error(response.message);
                        }
                    },
                    error: function (response) {
                        toastr.error('Xóa thất bại', 'Error Alert', { timeOut: 300 });
                    }
                });
            }
        });
    }

    // ===== Load danh sách hóa đơn chờ =====
    async function loadHDCHO(callback) {
        try {
            const data = await $.ajax({
                url: "https://localhost:7095/api/HoaDon/GetAllHDCho",
                type: "GET",
                dataType: "json"
            });

            $(".tabs-box").empty();
            $("#invoicePages").empty(); // Xóa hết page cũ

            if (data.length === 0) {
                $("#invoicePages").append(`
        <div class="invoice-page" id="page-empty">
            <p class="text-muted">Chưa có hóa đơn nào. Vui lòng tạo mới.</p>
        </div>
    `);
                toggleProductSection(false);
            } else {
                toggleProductSection(true);

                data.forEach((item, index) => {
                    const itemID = item.id;
                    const tabName = item.trangThaiGiaoHang === 1 ? `Hóa đơn ${index + 1}` : item.ghiChu;

                    $(".tabs-box").append(`
            <li class="tab" onclick="gethdct('${itemID}')">
                <span value="${itemID}">
                    <a>${tabName}</a>
                    <a style="padding-left: 10px;" onclick="deleteHDCho('${itemID}')"><i class="fas fa-times"></i></a>
                </span>
            </li>`);

                    $("#invoicePages").append(`
            <div class="invoice-page" id="page-${itemID}" style="display:none;">
                <div class="gioHangContent" data-id="${itemID}">
                    <p class="text-muted">Chưa có sản phẩm nào.</p>
                </div>
            </div>`);
                });

                gethdct(data[0].id);
            }

            if (callback) setTimeout(callback, 50);

        } catch (error) {
            console.log('Error:', error);
        }
    }

    // ===== Xóa sản phẩm khỏi giỏ hàng =====
    function xoaSanPhamKhoiGio(idHoaDon, idCTHD) {
        if (!confirm('Bạn có chắc muốn xóa sản phẩm này khỏi giỏ hàng?')) {
            return;
        }

        // Tìm dòng chứa sản phẩm đang xóa
        const row = $(`tr:has(button[onclick*="xoaSanPhamKhoiGio('${idHoaDon}', '${idCTHD}')"])`);

        // Hiển thị loading trên dòng đó
        row.html(`
            <td colspan="6" class="text-center py-2">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                Đang xóa sản phẩm...
            </td>
        `);

        // Gọi API xóa chi tiết hóa đơn
        $.ajax({
            url: `/BanHangTaiQuay/deleteHdct/${idCTHD}`,
            method: 'DELETE',
            success: function (response) {
                if (response.success) {
                    toastr.success(response.message || 'Xóa sản phẩm thành công');
                    // Load lại toàn bộ giỏ hàng
                    loadChiTietHoaDon(idHoaDon);
                } else {
                    toastr.error(response.message || 'Xóa sản phẩm thất bại');
                    // Load lại để hiển thị lại dữ liệu
                    loadChiTietHoaDon(idHoaDon);
                }
            },
            error: function (xhr, status, error) {
                console.error("Lỗi khi xóa sản phẩm:", error);
                console.log("Chi tiết lỗi:", xhr.responseText);
                toastr.error('Lỗi khi xóa sản phẩm');
                // Load lại để hiển thị lại dữ liệu
                loadChiTietHoaDon(idHoaDon);
            }
        });
    }

    // ===== Lấy chi tiết hóa đơn =====
    function gethdct(id) {
        // Ẩn tất cả page
        $(".invoice-page").hide();

        // Hiện page của hóa đơn được chọn
        const page = $("#page-" + id);
        if (page.length) {
            page.show();
        } else {
            $("#page-empty").show();
        }

        // Active tab
        $(".tabs-box .tab").removeClass("active");
        $(`.tabs-box .tab span[value="${id}"]`).closest('.tab').addClass("active");

        // TODO: Load chi tiết hóa đơn từ API
        loadChiTietHoaDon(id);
    }

        // Hàm xử lý khách hàng cho hóa đơn
    function xuLyKhachHangChoHoaDon(hoaDonData) {
        if (hoaDonData && hoaDonData.idKhachHang) {
            // Nếu hóa đơn có khách hàng
            currentKhachHangId = hoaDonData.idKhachHang;

            const khachHang = {
                id: hoaDonData.idKhachHang,
                ten: hoaDonData.tenKhachHang || '',
                sdt: hoaDonData.sdtKhachHang || ''
            };

            chonKhachHang(khachHang);

            // Load địa chỉ nếu có
            if (hoaDonData.idKhachHang !== KHACH_LE.id) {
                loadDiaChiKhachHang(hoaDonData.idKhachHang);
            }
        } else {
            // Nếu không có khách hàng, reset về khách lẻ
            resetKhachHang();
        }
    }

    // ===== Sửa hàm loadChiTietHoaDon để đảm bảo cập nhật tổng tiền =====
    function loadChiTietHoaDon(idHoaDon) {
            const container = $(`.gioHangContent[data-id="${idHoaDon}"]`);
            container.html('<div class="text-center py-3"><div class="spinner-border spinner-border-sm" role="status"></div> Đang tải dữ liệu...</div>');

            $.ajax({
                url: `/BanHangTaiQuay/getCTHD/${idHoaDon}`,
                method: 'GET',
                success: function (response) {
                    if (!response || !response.success) {
                        console.error("API trả về response không thành công:", response);
                        container.html('<p class="text-danger">Lỗi khi tải dữ liệu: ' + (response?.message || 'Unknown error') + '</p>');

                        // VẪN CẬP NHẬT TỔNG TIỀN NGAY CẢ KHI CÓ LỖI
                        capNhatTongTien();
                        return;
                    }

                    container.empty();

                    if (response.data && response.data.length > 0) {
                        let html = '<table class="table table-sm">';
                        html += '<thead><tr><th>Sản phẩm</th><th>Phân loại</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th><th>Thao tác</th></tr></thead>';
                        html += '<tbody>';

                        let tongTien = 0;
                        response.data.forEach(item => {
                            // Sử dụng GiaKM cho hóa đơn chưa thanh toán
                            const donGia = item.giaKM || 0;
                            const thanhTien = (item.soLuong || 0) * donGia;
                            tongTien += thanhTien;

                            html += `
                                <tr>
                                    <td>${item.ten || 'N/A'}</td>
                                    <td>${item.phanLoai || 'N/A'}</td>
                                    <td>
                                        <div class="input-group input-group-sm" style="width: 100px;">
                                            <button class="btn btn-outline-secondary btn-minus" type="button" onclick="giamSoLuong('${idHoaDon}', '${item.id}', ${item.soLuong})">-</button>
                                            <input type="number" class="form-control text-center so-luong-sp" value="${item.soLuong || 0}"
                                                   min="1" data-id="${item.id}" data-hoadon="${idHoaDon}"
                                                   onchange="capNhatSoLuong('${idHoaDon}', '${item.id}', this.value)">
                                            <button class="btn btn-outline-secondary btn-plus" type="button" onclick="tangSoLuong('${idHoaDon}', '${item.id}', ${item.soLuong})">+</button>
                                        </div>
                                    </td>
                                    <td>${donGia.toLocaleString('vi-VN')} đ</td>
                                    <td>${thanhTien.toLocaleString('vi-VN')} đ</td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" onclick="xoaSanPhamKhoiGio('${idHoaDon}', '${item.id}')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>`;
                        });

                        html += '</tbody></table>';
                        html += `<div class="fw-bold mt-2">Tổng tiền: ${tongTien.toLocaleString('vi-VN')} đ</div>`;

                        container.html(html);

                        // Cập nhật tổng tiền
                        $('#tongTien').text(tongTien.toLocaleString('vi-VN') + ' đ');
                        $('#khachPhaiTra').text(tongTien.toLocaleString('vi-VN') + ' đ');

                        // CẬP NHẬT PHẦN NÀY: Sử dụng hàm chonKhachHang thay vì chỉ cập nhật input
                        if (response.hoaDon && response.hoaDon.idKhachHang) {
                            // Tạo object khách hàng từ dữ liệu response
                            const khachHang = {
                                id: response.hoaDon.idKhachHang,
                                ten: response.hoaDon.tenKhachHang || '',
                                sdt: response.hoaDon.sdtKhachHang || ''
                            };

                            // Sử dụng hàm chonKhachHang để cập nhật đầy đủ thông tin
                            chonKhachHang(khachHang);
                        } else {
                            // Nếu không có khách hàng, reset về khách lẻ
                            resetKhachHang();
                        }
                    } else {
                        container.html('<p class="text-muted">Chưa có sản phẩm nào.</p>');

                        // Reset tổng tiền
                        $('#tongTien').text('0 đ');
                        $('#khachPhaiTra').text('0 đ');

                        // Reset về khách lẻ nếu không có sản phẩm
                        resetKhachHang();
                    }

                    // LUÔN GỌI CẬP NHẬT TỔNG TIỀN SAU KHI TẢI XONG
                    capNhatTongTien();
                },
                error: function (xhr, status, error) {
                    console.error("Lỗi khi tải chi tiết hóa đơn:", error);
                    container.html('<p class="text-danger">Lỗi khi tải dữ liệu. Vui lòng kiểm tra kết nối.</p>');

                    // VẪN CẬP NHẬT TỔNG TIỀN NGAY CẢ KHI CÓ LỖI
                    capNhatTongTien();
                }
            });
    }

    // ===== Cập nhật số lượng sản phẩm =====
    function capNhatSoLuong(idHoaDon, idCTHD, soLuong) {
        // Validate số lượng
        soLuong = parseInt(soLuong);
        if (isNaN(soLuong) || soLuong < 1) {
            toastr.warning('Số lượng phải lớn hơn 0');
            // Load lại để reset giá trị
            loadChiTietHoaDon(idHoaDon);
            return;
        }

        // Hiển thị loading
        const inputElement = $(`.so-luong-sp[data-id="${idCTHD}"]`);
        inputElement.prop('disabled', true);

        // Gọi API UpdateSL đã có
        $.ajax({
            url: `/BanHangTaiQuay/UpdateSL?idhdct=${idCTHD}&sl=${soLuong}`,
            method: 'POST',
            success: function (response) {
                if (response.success) {
                    toastr.success(response.message || 'Cập nhật số lượng thành công');
                    // Load lại giỏ hàng
                    loadChiTietHoaDon(idHoaDon);
                } else {
                    toastr.error(response.message || 'Cập nhật số lượng thất bại');
                    // Load lại để reset giá trị
                    loadChiTietHoaDon(idHoaDon);
                }
            },
            error: function (xhr, status, error) {
                console.error("Lỗi khi cập nhật số lượng:", error);
                toastr.error('Lỗi khi cập nhật số lượng');
                // Load lại để reset giá trị
                loadChiTietHoaDon(idHoaDon);
            }
        });
    }

    // ===== Tăng số lượng sản phẩm =====
    function tangSoLuong(idHoaDon, idCTHD, soLuongHienTai) {
        const soLuongMoi = parseInt(soLuongHienTai) + 1;
        capNhatSoLuong(idHoaDon, idCTHD, soLuongMoi);
    }

    // ===== Giảm số lượng sản phẩm =====
    function giamSoLuong(idHoaDon, idCTHD, soLuongHienTai) {
        if (soLuongHienTai <= 1) {
            // Nếu số lượng = 1, hỏi có muốn xóa không
            if (confirm('Số lượng đang là 1. Bạn có muốn xóa sản phẩm này không?')) {
                xoaSanPhamKhoiGio(idHoaDon, idCTHD);
            }
            return;
        }
        const soLuongMoi = parseInt(soLuongHienTai) - 1;
        capNhatSoLuong(idHoaDon, idCTHD, soLuongMoi);
    }

    // Xử lý sự kiện khi người dùng nhập trực tiếp vào input số lượng
    $(document).on('blur', '.so-luong-sp', function() {
        const idHoaDon = $(this).data('hoadon');
        const idCTHD = $(this).data('id');
        const soLuong = $(this).val();

        capNhatSoLuong(idHoaDon, idCTHD, soLuong);
    });

    // Ngăn không cho nhập ký tự không phải số
    $(document).on('keypress', '.so-luong-sp', function(e) {
        if (e.which < 48 || e.which > 57) {
            e.preventDefault();
        }
    });

    // Xử lý khi nhấn Enter trong input số lượng
    $(document).on('keypress', '.so-luong-sp', function(e) {
        if (e.which === 13) { // Enter key
            e.preventDefault();
            $(this).blur(); // Kích hoạt sự kiện blur
        }
    });

    // ===== Tạo khách hàng nhanh =====
    $(document).on("click", "#btn-saveKH", function () {
        let tenKhachHang = $("#inputTenKhachHang").val().trim();
        let sdt = $("#inputSDT").val().trim();
        let email = $("#inputEmail").val().trim();
        let ngaySinh = $("#inputNgaySinh").val();
        let gioiTinh = $("input[name='gioitinh']:checked").val();
        let diaChi = $("#inputDiaChi").val().trim();

        if (!tenKhachHang) {
            $("#validatekh").text("Tên khách hàng không được để trống!");
            return;
        }

        // Validate số điện thoại
        const phoneRegex = /^(0[3|5|7|8|9])+([0-9]{8})$/;
        if (sdt && !phoneRegex.test(sdt)) {
            $("#validatekh").text("Số điện thoại không hợp lệ!");
            return;
        }

        $("#validatekh").text("");

        let khachHang = {
            Ten: tenKhachHang,
            GioiTinh: gioiTinh,
            NgaySinh: ngaySinh,
            Email: email,
            DiaChi: diaChi,
            SDT: sdt
        };

        $.ajax({
            url: "/BanHangTaiQuay/AddKhachHang",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(khachHang),
            success: function (response) {
                if (response.success) {
                    toastr.success("Thêm khách hàng thành công!");

                    // Gán tên KH vào đúng input chọn khách hàng
                    $("#formGiaoHangContainer input.form-control").val(tenKhachHang);
                    $("#tenNguoiNhan").val(tenKhachHang);
                    $("#sdtNguoiNhan").val(sdt);

                    // Ẩn modal + reset form
                    $("#modalTaoKhachHang").modal("hide");
                    $("#formTaoKhachHang")[0].reset();
                } else {
                    toastr.error(response.message || "Thêm khách hàng thất bại!");
                }
            },
            error: function () {
                toastr.error("Có lỗi xảy ra khi thêm khách hàng!");
            }
        });
    });

    // ===== Thanh toán hóa đơn (ĐÃ SỬA ĐỂ PHÙ HỢP VỚI CONTROLLER) =====
    function thanhToanHoaDon() {
        // Lấy ID hóa đơn đang active
        const activeTab = $(".tabs-box .tab.active");
        if (!activeTab.length) {
            toastr.warning("Vui lòng chọn hóa đơn để thanh toán");
            return;
        }

        const idHoaDon = activeTab.find("span").attr("value");

        // Kiểm tra xem có sản phẩm trong giỏ hàng không
        const gioHangElement = $(`.gioHangContent[data-id="${idHoaDon}"]`);
        if (gioHangElement.find('table').length === 0) {
            toastr.warning("Vui lòng thêm sản phẩm vào giỏ hàng trước khi thanh toán");
            return;
        }

        // Validate thông tin
        if ($("#giaoHang").is(":checked") && !validateFormGiaoHang()) {
            toastr.warning("Vui lòng điền đầy đủ thông tin giao hàng");
            return;
        }

        // Lấy thông tin đăng nhập từ session (nếu có)
        let idNhanVien = "00000000-0000-0000-0000-000000000000"; // Giá trị mặc định
        try {
            const sessionData = localStorage.getItem('LoginInfor') || sessionStorage.getItem('LoginInfor');
            if (sessionData) {
                const loginInfo = JSON.parse(sessionData);
                idNhanVien = loginInfo.Id || idNhanVien;
            }
        } catch (e) {
            console.error("Không thể lấy thông tin đăng nhập:", e);
        }

        // Lấy tổng tiền từ giao diện
        const thanhTienText = $('#khachPhaiTra').text().replace(' đ', '').replace(/\./g, '');
        const thanhTien = parseFloat(thanhTienText) || 0;

        if (thanhTien <= 0) {
            toastr.warning("Tổng tiền thanh toán phải lớn hơn 0");
            return;
        }

        // Xác định ID phương thức thanh toán
        let idPhuongThucTT = null;
        const hinhThuc = $("#hinhThucThanhToan").val();

        if (hinhThuc === "tienmat") {
            idPhuongThucTT = "9b6289bf-5e83-419a-94d5-926abb264961"; // GUID tiền mặt
        } else if (hinhThuc === "chuyenkhoan") {
            idPhuongThucTT = "f29cd85d-0251-4b50-8867-6a88891417f6"; // GUID chuyển khoản
        }

        // Thu thập dữ liệu thanh toán - ĐẢM BẢO KHỚP VỚI C# REQUEST
        
        const thanhToanData = {
            Id: idHoaDon,
            IdNhanVien: idNhanVien,
            IdKhachHang: $("#khachHangId").val(),
            IDPhuongThucThanhToan: idPhuongThucTT, // ĐÚNG: IDPhuongThucThanhToan (viết hoa)
            IdVoucher: currentVoucher && currentVoucher.id
            ? currentVoucher.id
            : "00000000-0000-0000-0000-000000000000",
            TongTien: thanhTien,
            TienShip: phiShip, // ĐÚNG: TienShip (viết hoa)
            GhiChu: $("#note").val(),
            tenNguoiNhan: $("#tenNguoiNhan").val(),
            sdtNguoiNhan: $("#sdtNguoiNhan").val(),
            diaChi: getDiaChiDayDu(),
        };

        console.log("Dữ liệu gửi đi:", thanhToanData); // Debug

        // Hiển thị loading
        const originalText = $("#btnThanhToan").html();
        $("#btnThanhToan").html('<span class="spinner-border spinner-border-sm" role="status"></span> Đang xử lý...');
        $("#btnThanhToan").prop("disabled", true);

        // Gửi request thanh toán
        $.ajax({
            url: "/BanHangTaiQuay/ThanhToan",
            type: "POST",
            contentType: "application/json",
            dataType: "json",
            data: JSON.stringify(thanhToanData),
            success: function (response) {
                // Khôi phục trạng thái nút
                $("#btnThanhToan").html(originalText);
                $("#btnThanhToan").prop("disabled", false);

                if (response.success) {
                    toastr.success("Thanh toán thành công!");

                    // Xử lý chuyển hướng nếu là thanh toán VNPay
                    if (response.PaymentUrl) {
                        window.location.href = response.PaymentUrl;
                    } else {
                        // Reset form cho thanh toán tại quầy
                        xoaVoucher();
                        resetFormGiaoHang();
                        $("#giaoHang").prop("checked", false);
                        toggleGiaoHangForm();
                        loadHDCHO();
                    }
                } else {
                    toastr.error(response.message || "Thanh toán thất bại!");
                }
            },
            error: function (xhr, status, error) {
                // Khôi phục trạng thái nút
                $("#btnThanhToan").html(originalText);
                $("#btnThanhToan").prop("disabled", false);

                console.error("Lỗi khi thanh toán:", error, xhr.responseText);
                toastr.error("Có lỗi xảy ra khi thanh toán: " + (xhr.responseJSON?.message || error));
            }
        });
    }

    // Hàm mở modal chi tiết sản phẩm
    function moModalChiTietSanPham(sanPhamId) {
        $("#chitietsanphambody").load("/BanHangTaiQuay/ChiTietSanPham/" + sanPhamId, function () {
            $("#chitietsanpham").modal("show");
        });
    }

    //Thêm SP vào Hóa đơn
    function addCTSP(idctsp) {
        var activeTab = $(".tabs-box .tab").filter(".active");
        var elementValue = activeTab.find("span").attr("value");
        var request = { IdHoaDon: elementValue, IdChiTietSanPham: idctsp, SoLuong: 1 }
        $.ajax({
            url: "/BanHangTaiQuay/addHdct",
            async: false,
            type: 'POST',
            dataType: 'json',
            data: request,
            success: function (response) {
                if (response.success === true) {
                    toastr.success(response.message, "Success Alert", { timeOut: 1000 });
                    gethdct(request.IdHoaDon);
                    FilterPL();
                } else {
                    toastr.error(response.message, 'Error Alert', { timeOut: 1000 });
                }
            },
            error: function (response) {
                toastr.error(response.message, 'Error Alert', { timeOut: 1000 });
            }
        });
    }

    // Biến toàn cục lưu trữ
    let currentVoucher = null;
    let availableVouchers = [];
    let lastTongTien = 0;
    let isFirstLoad = true;

    // Hàm tự động tải voucher khi có thay đổi
    function tuDongTaiVoucher() {
        const tongTien = layTongTienHang();

        // Chỉ tải khi có tổng tiền > 0 và khác lần trước
        if (tongTien > 0 && tongTien !== lastTongTien) {
            lastTongTien = tongTien;
            taiDanhSachVoucher();
        }
    }

    // Hàm tải danh sách voucher khả dụng
    async function taiDanhSachVoucher() {
        const tongTien = layTongTienHang();

        if (tongTien <= 0) {
            $('#voucherSelect').html('<option value="">-- Chưa có sản phẩm --</option>');
            $('#voucherCount').text('0 voucher').removeClass('bg-success').addClass('bg-secondary');
            return;
        }

        try {
            if (isFirstLoad) {
                $('#voucherSelect').html('<option value="">-- Đang tải voucher --</option>');
            }

            const response = await fetch(`/BanHangTaiQuay/GetVouchers?tongTien=${tongTien}`);

            if (!response.ok) {
                throw new Error('Không thể tải danh sách voucher');
            }

            const vouchers = await response.json();
            availableVouchers = vouchers;

            hienThiDanhSachVoucher(availableVouchers);

            // Hiển thị thông báo toastr cho lần đầu tiên
            if (isFirstLoad && vouchers.length > 0) {
                toastr.success(`Đã tải ${vouchers.length} voucher khả dụng`, "Thông báo", { timeOut: 2000 });
                isFirstLoad = false;
            }

        } catch (error) {
            console.error('Lỗi khi tải voucher:', error);
            $('#voucherSelect').html('<option value="">-- Lỗi tải voucher --</option>');
            toastr.error('Không thể tải danh sách voucher', "Lỗi", { timeOut: 3000 });
        }
    }

    // Hàm hiển thị danh sách voucher
    function hienThiDanhSachVoucher(vouchers) {
        const select = $('#voucherSelect');

        if (vouchers.length === 0) {
            select.html('<option value="">-- Không có voucher khả dụng --</option>');
            $('#voucherCount').text('0 voucher').removeClass('bg-success').addClass('bg-secondary');
            return;
        }

        select.empty().append('<option value="" selected>-- Chọn voucher --</option>');

        vouchers.forEach(voucher => {
            const discountText = voucher.hinhThucGiamGia === 1 ?
                `Giảm ${voucher.giaTri}%` :
                `Giảm ${voucher.giaTri.toLocaleString('vi-VN')}đ`;

            const maxDiscount = voucher.giaTriToiDa ?
                ` (Tối đa ${voucher.giaTriToiDa.toLocaleString('vi-VN')}đ)` : '';

            const text = `${voucher.maVoucher} - ${discountText}${maxDiscount}`;

            select.append($('<option>', {
                value: voucher.id,
                text: text,
                'data-voucher': JSON.stringify(voucher)
            }));
        });

        // Cập nhật badge số lượng voucher
        $('#voucherCount').text(`${vouchers.length} voucher`).removeClass('bg-secondary').addClass('bg-success');
    }

    // Hàm xử lý khi chọn voucher
    function chonVoucher() {
        const selectedId = $('#voucherSelect').val();

        if (!selectedId) {
            xoaVoucher();
            return;
        }

        const voucherJson = $('#voucherSelect option:selected').data('voucher');
        if (voucherJson) {
            try {
                currentVoucher = JSON.parse(voucherJson);
                hienThiThongTinVoucher(currentVoucher);
                $('#voucherDiscountRow').show();
                capNhatTongTien();

                toastr.success(`Đã áp dụng voucher ${currentVoucher.maVoucher}`, "Thành công", { timeOut: 2000 });

            } catch (e) {
                console.error('Lỗi khi parse voucher:', e);
                toastr.error('Lỗi khi áp dụng voucher', "Lỗi", { timeOut: 3000 });
            }
        }
    }

    // Hàm hiển thị thông tin voucher
    function hienThiThongTinVoucher(voucher) {
        const discountText = voucher.hinhThucGiamGia === 1 ?
            `Giảm ${voucher.giaTri}%` :
            `Giảm ${voucher.giaTri.toLocaleString('vi-VN')}đ`;

        let html = `
            <div class="voucher-detail">
                <div class="d-flex justify-content-between align-items-center">
                    <strong>${voucher.maVoucher}</strong>
                    <a href="#" onclick="xoaVoucher(); return false;" class="text-danger" title="Bỏ chọn">
                        <i class="bi bi-x-circle"></i>
                    </a>
                </div>
                <div class="small">${discountText}`;

        if (voucher.giaTriToiDa) {
            html += ` (Tối đa ${voucher.giaTriToiDa.toLocaleString('vi-VN')}đ)`;
        }

        html += `</div></div>`;

        $('#voucherInfo').html(html).show();
    }

    // Hàm xóa voucher
    function xoaVoucher() {
        if (currentVoucher) {
            toastr.info(`Đã bỏ chọn voucher ${currentVoucher.maVoucher}`, "Thông báo", { timeOut: 2000 });
        }

        currentVoucher = null;
        $('#voucherSelect').val('');
        $('#voucherInfo').hide();
        $('#voucherDiscountRow').hide();
        capNhatTongTien();
    }

    // Hàm tính giảm giá voucher
    function tinhGiamGiaVoucher(tongTienHang) {
        if (!currentVoucher) return 0;

        let discount = 0;

        if (currentVoucher.hinhThucGiamGia === 1) { // Giảm theo %
            discount = tongTienHang * currentVoucher.giaTri / 100;

            // Kiểm tra giới hạn tối đa nếu có
            if (currentVoucher.giaTriToiDa && discount > currentVoucher.giaTriToiDa) {
                discount = currentVoucher.giaTriToiDa;
            }
        } else { // Giảm theo số tiền cố định
            discount = currentVoucher.giaTri;
            
            // Không giảm quá tổng tiền hàngR
            if (discount > tongTienHang) {
                discount = tongTienHang;
            }
        }

        return discount;
    }

    // Hàm lấy tổng tiền hàng từ giỏ hàng (FIXED)
    function layTongTienHang() {
        const activeTab = $(".tabs-box .tab.active");
        if (!activeTab.length) return 0;

        const idHoaDon = activeTab.find("span").attr("value");
        let tongTien = 0;

        // Tìm giỏ hàng tương ứng
        const gioHangElement = $(`.gioHangContent[data-id="${idHoaDon}"]`);
        if (gioHangElement.length === 0) return 0;

        // Kiểm tra xem có bảng sản phẩm không
        const table = gioHangElement.find('table');
        if (table.length === 0) return 0;

        // Duyệt qua từng dòng sản phẩm trong bảng
        table.find('tbody tr').each(function() {
            // Lấy số lượng từ input
            const soLuongInput = $(this).find('.so-luong-sp');
            const soLuong = soLuongInput.length ? parseInt(soLuongInput.val()) || 0 : 0;

            // Lấy đơn giá từ cột thứ 4 (index 3)
            const donGiaText = $(this).find('td:nth-child(4)').text().trim();
            const donGia = parseFloat(donGiaText.replace(/\./g, '').replace(' đ', '')) || 0;

            // Tính thành tiền và cộng vào tổng
            tongTien += soLuong * donGia;
        });

        return tongTien;
    }

        // ===== Sửa hàm capNhatTongTien để đảm bảo luôn hiển thị đúng =====
    function capNhatTongTien() {
        // ĐẢM BẢO LUÔN CÓ HÓA ĐƠN ACTIVE TRƯỚC KHI TÍNH TOÁN
        const activeTab = $(".tabs-box .tab.active");
        if (!activeTab.length) {
            // Nếu không có hóa đơn active, reset tất cả giá trị
            $('#tongTien').text('0 đ');
            $('#voucherDiscountRow').hide();
            $('#phiShipRow').addClass('d-none');
            $('#thanhTien').text('0 đ');
            $('#thanhTienRow').removeClass('d-none');
            $('#khachPhaiTra').text('0 đ');

            const isChuyenKhoan = $("#hinhThucThanhToan").val() === "chuyenkhoan";
            $("#khachPhaiTraRow").toggle(!isChuyenKhoan);
            $("#tienKhachDuaRow").toggle(!isChuyenKhoan);
            $("#tienThuaRow").toggle(!isChuyenKhoan);

            if (!isChuyenKhoan) {
                updateTienThua();
            }

            return;
        }

        const idHoaDon = activeTab.find("span").attr("value");
        const tongTienHang = layTongTienHang();
        const giamGiaVoucher = tinhGiamGiaVoucher(tongTienHang);
        const isGiaoHang = $("#giaoHang").is(":checked");
        const isChuyenKhoan = $("#hinhThucThanhToan").val() === "chuyenkhoan";

        // Tính toán ĐÚNG:
        // 1. Tổng tiền hàng (đã đúng)
        // 2. Trừ giảm giá voucher (nếu có)
        const tienSauGiamGia = Math.max(0, tongTienHang - giamGiaVoucher);

        // 3. Cộng phí ship (nếu có giao hàng)
        let thanhTien = tienSauGiamGia;
        if (isGiaoHang) {
            thanhTien += phiShip;
        }

        // Cập nhật giao diện
        $('#tongTien').text(tongTienHang.toLocaleString('vi-VN') + ' đ');

        // Hiển thị thông tin voucher
        if (currentVoucher && giamGiaVoucher > 0) {
            $('#voucherDiscount').text('-' + giamGiaVoucher.toLocaleString('vi-VN') + ' đ');
            $('#voucherDiscountRow').show();
        } else {
            $('#voucherDiscountRow').hide();
        }

        // Hiển thị phí ship nếu có giao hàng
        if (isGiaoHang) {
            $('#phiShip').text(phiShip.toLocaleString('vi-VN') + ' đ');
            $('#phiShipRow').removeClass('d-none');
        } else {
            $('#phiShipRow').addClass('d-none');
        }

        // Hiển thị thành tiền (tổng tiền hàng - giảm giá + phí ship)
        $('#thanhTien').text(thanhTien.toLocaleString('vi-VN') + ' đ');
        $('#thanhTienRow').removeClass('d-none');

        // Khách phải trả = thành tiền
        $('#khachPhaiTra').text(thanhTien.toLocaleString('vi-VN') + ' đ');

        // Chỉ hiển thị phần tiền mặt khi không phải chuyển khoản
        $("#khachPhaiTraRow").toggle(!isChuyenKhoan);
        $("#tienKhachDuaRow").toggle(!isChuyenKhoan);
        $("#tienThuaRow").toggle(!isChuyenKhoan);

        // Cập nhật tiền thừa nếu không phải chuyển khoản
        if (!isChuyenKhoan) {
            updateTienThua();
        }

        // Tự động tải voucher nếu tổng tiền thay đổi
        tuDongTaiVoucher();

        // DEBUG: Hiển thị thông tin tổng tiền trong console để kiểm tra
        console.log("Tổng tiền hàng:", tongTienHang, "Giảm giá:", giamGiaVoucher, "Phí ship:", phiShip, "Thành tiền:", thanhTien);
    }

    // Theo dõi thay đổi giỏ hàng để tự động tải voucher
    function theoDoiThayDoiGioHang() {
        // Sử dụng MutationObserver để theo dõi thay đổi trong giỏ hàng
        const observer = new MutationObserver(function(mutations) {
            clearTimeout(window.voucherTimeout);
            window.voucherTimeout = setTimeout(tuDongTaiVoucher, 500);
        });

        // Theo dõi tất cả các giỏ hàng
        $('.gioHangContent').each(function() {
            observer.observe(this, {
                childList: true,
                subtree: true,
                characterData: true
            });
        });
    }

    // Khởi tạo khi trang tải xong
    $(document).ready(function() {
        // Tải voucher ngay khi trang load
        setTimeout(tuDongTaiVoucher, 1000);

        // Thiết lập theo dõi thay đổi giỏ hàng
        theoDoiThayDoiGioHang();

        // Tải lại voucher khi chuyển tab hóa đơn
        $(document).on('click', '.tabs-box .tab', function() {
            setTimeout(tuDongTaiVoucher, 300);
        });

        // Tải lại voucher khi thêm/xóa sản phẩm
        $(document).on('ajaxComplete', function() {
            setTimeout(tuDongTaiVoucher, 300);
        });
    });
</script>