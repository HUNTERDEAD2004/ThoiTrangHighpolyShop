    // Hàm kiểm tra thông tin địa chỉ
    function kiemTraDiaChi() {
        if (!$("#giaoHang").is(":checked")) return false;

        const hasRequiredAddress = $('#tinhThanh').val() && $('#quanHuyen').val() && $('#xaPhuong').val();
        const hasDetailAddress = $('#diaChiChiTiet').val().trim();

        return { hasRequiredAddress, hasDetailAddress };
    }

    // Sự kiện change cho các trường địa chỉ
    $('#tinhThanh, #quanHuyen, #xaPhuong, #diaChiChiTiet').change(function() {
        capNhatTongTien();

        const addressInfo = kiemTraDiaChi();
        if (!addressInfo) return;

        clearTimeout(window.shipTimeout);
        window.shipTimeout = setTimeout(function() {
            if (addressInfo.hasRequiredAddress) {
                tinhPhiShipTuDong();
            } else {
                phiShip = 0;
                $('#phiShip').text('0 đ');
                $('#phiShipRow').addClass('d-none');
                capNhatTongTien();
            }
        }, 500);
    });

