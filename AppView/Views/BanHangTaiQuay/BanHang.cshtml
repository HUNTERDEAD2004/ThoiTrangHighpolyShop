    // ===== Chọn địa chỉ từ danh sách =====
    function chonDiaChiTuDanhSach() {
        const selectedOption = $("#selectDiaChi option:selected");
        if (!selectedOption.val()) return; // Không làm gì nếu chọn option rỗng

        // Lấy dữ liệu từ data attributes
        const diaChiChiTiet = selectedOption.data('diachict') || '';
        const tinhValue = selectedOption.data('tinh') || '';
        const huyenValue = selectedOption.data('huyen') || '';
        const xaValue = selectedOption.data('xa') || '';

        // Điền thông tin vào form
        $("#diaChiChiTiet").val(diaChiChiTiet);

        // Tìm và chọn tỉnh/thành phố phù hợp
        if (tinhValue) {
            const tinhOption = $(`#tinhThanh option:contains('${tinhValue}')`).first();
            if (tinhOption.length) {
                tinhOption.prop('selected', true);
                tinh = tinhValue;
                loadQuanHuyen(); // Load quận/huyện sau khi chọn tỉnh

                // Đợi một chút để load quận/huyện xong rồi chọn
                setTimeout(() => {
                    if (huyenValue) {
                        const huyenOption = $(`#quanHuyen option:contains('${huyenValue}')`).first();
                        if (huyenOption.length) {
                            huyenOption.prop('selected', true);
                            huyen = huyenValue;
                            loadXaPhuong(); // Load xã/phường sau khi chọn huyện

                            // Đợi một chút để load xã/phường xong rồi chọn
                            setTimeout(() => {
                                if (xaValue) {
                                    const xaOption = $(`#xaPhuong option:contains('${xaValue}')`).first();
                                    if (xaOption.length) {
                                        xaOption.prop('selected', true);
                                        xa = xaValue;

                                        // Tự động tính phí ship sau khi điền đầy đủ địa chỉ
                                        setTimeout(() => {
                                            tinhPhiShipTuDong();
                                        }, 500);
                                    }
                                }
                            }, 300);
                        }
                    }
                }, 300);
            }
        }
    }

