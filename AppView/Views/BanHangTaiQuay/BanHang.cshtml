                </form>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btn-saveKH" class="btn btn-primary btn-sm">Lưu</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Chi Tiết Sản Phẩm -->
<div class="modal border-0 rounded-0" id="chitietsanpham" tabindex="-1">
    <div class="modal-dialog modal-xl" id="modalchitietsanpham">
        <div class="modal-content" id="modalchitietsanpham-content">
            <div class="modal-header bg-primary">
                <h5 class="modal-title fw-700 text-white align-center">CHI TIẾT SẢN PHẨM</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="chitietsanphambody">
                <!-- Nội dung sẽ được load từ Partial View -->
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/html5-qrcode"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Token API GHN
    const GHN_TOKEN = '9f4e42e4-fde8-11ed-a281-3aa62a37e0a5';
    const SHOP_ID = '4643378';

    // Khai báo biến phân trang
    let pageIndexsp = 1;
    let pageSizesp = 10;

    // Biến toàn cục
    let phiShip = 0;
    let tinh = "";
    let huyen = "";
    let xa = "";
    let currentKhachHangId = null;

    $(document).ready(function () {
        // Load danh sách hóa đơn chờ
        loadHDCHO(function () {
            const $tabs = $(".tabs-box .tab");

            if ($tabs.length > 0) {
                // Lấy ID tab đầu tiên
                const firstTabId = $tabs.first().find("span").attr("value");
                gethdct(firstTabId); // Hiển thị giỏ hàng của tab đầu tiên
            } else {
                // Nếu không có hóa đơn thì ẩn/disable phần thanh toán
                toggleProductSection(false);
            }
        });

        // Load danh sách tỉnh/thành phố
        loadTinhThanh();

        // Xử lý sự kiện input để validate
        $('.form-control').on('input', function () {
            $(this).removeClass('is-invalid');
        });

        $('.form-select').change(function () {
            $(this).removeClass('is-invalid');
        });

        // Mặc định ẩn form giao hàng
        toggleGiaoHangForm();

        // Khởi tạo sự kiện thay đổi hình thức thanh toán
        $("#hinhThucThanhToan").on("change", onHinhThucThanhToanChange);

