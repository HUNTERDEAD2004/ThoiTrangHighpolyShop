@using AppData.ViewModels
@model PaymentResultViewModel
@{
    ViewData["Title"] = "Kết quả thanh toán";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body text-center p-5">
                    @if (Model.Success)
                    {
                        <div class="text-success mb-4">
                            <i class="bi bi-check-circle-fill" style="font-size: 4rem;"></i>
                        </div>
                        <h3 class="text-success">Thanh toán thành công!</h3>
                        <p class="text-muted">@Model.Message</p>

                        <div class="mt-4 p-3 bg-light rounded">
                            <p><strong>Mã đơn hàng:</strong> @Model.OrderId</p>
                            <p><strong>Số tiền:</strong> @Model.Amount đ</p>
                        </div>
                    }
                    else
                    {
                        <div class="text-danger mb-4">
                            <i class="bi bi-x-circle-fill" style="font-size: 4rem;"></i>
                        </div>
                        <h3 class="text-danger">Thanh toán thất bại</h3>
                        <p class="text-muted">@Model.Message</p>
                    }

                    <div class="mt-4">
                        <a asp-controller="BanHangTaiQuay" asp-action="BanHang" class="btn btn-primary">
                            <i class="bi bi-arrow-left"></i> Quay lại bán hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>