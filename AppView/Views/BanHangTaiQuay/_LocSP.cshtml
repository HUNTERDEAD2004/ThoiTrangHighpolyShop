@using AppData.Models
@{
    var lstLSP = ViewData["lstLSP"] as List<LoaiSP>;
    <style>
        input[type="checkbox"] {
            margin: 5px 0 15px 0;
            cursor: pointer;
        }

        label {
            font-family: "Poppins", sans-serif;
            font-weight: 500;
            color: #1f194c;
            letter-spacing: 0.5px;
            cursor: pointer;
        }
    </style>
}
<div class="card d-flex flex-column h-100">
    <div class="overflow-auto scroll-cthd p-3" style="height:700px">
        <!-- Danh mục -->
        <div class="accordion accordion-flush" id="faq-group-1">
            <div class="accordion-item pb-2">
                <h2 class="accordion-header text-white fw-bolder px-3" style="background:#7690DA">
                    <button class="accordion-button collapsed" data-bs-target="#faqsOne-1" type="button" data-bs-toggle="collapse">
                        <span class="text-white fw-bolder">DANH MỤC HÀNG</span>
                    </button>
                </h2>
                <div id="faqsOne-1" class="accordion-collapse collapse show px-3 py-1" data-bs-parent="#faq-group-1">
                    @foreach (var item in lstLSP)
                    {
                        <div class="form-check">
                            <input type="checkbox" id="@item.ID" name="dm">
                            <label for="@item.ID">@item.Ten</label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Giá sản phẩm -->
        <div class="accordion accordion-flush" id="faq-group-2">
            <div class="accordion-item pb-1">
                <h2 class="accordion-header text-white fw-bolder px-3" style="background:#7690DA">
                    <button class="accordion-button collapsed" data-bs-target="#faqsOne-2" type="button" data-bs-toggle="collapse">
                        <span class="text-white fw-bolder">GIÁ SẢN PHẨM</span>
                    </button>
                </h2>
                <div id="faqsOne-2" class="accordion-collapse collapse show px-3 py-1" data-bs-parent="#faq-group-2">
                    <div class="accordion-body">
                        @{
                            var giaOptions = new[]
                            {
                        new { Id = "1", Label = "Dưới 100,000" },
                        new { Id = "2", Label = "100,000 - 200,000" },
                        new { Id = "3", Label = "200,000 - 300,000" },
                        new { Id = "4", Label = "300,000 - 400,000" },
                        new { Id = "5", Label = "400,000 - 500,000" },
                        new { Id = "6", Label = "Trên 500,000" }
                        };
                        }
                        @foreach (var g in giaOptions)
                        {
                            <div class="form-check">
                                <input type="radio" name="kgia" id="@g.Id">
                                <label for="@g.Id">@g.Label</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Nút -->
    <div class="mt-auto d-flex">
        <button class="btn btn-outline-primary w-50 m-2" onclick="resetFilter()">THIẾT LẬP LẠI</button>
        <button class="btn btn-primary w-50 m-2 " onclick="loc()">ÁP DỤNG</button>
    </div>
</div>

<!-- Script -->
<script>
    // Reset bộ lọc
    function resetFilter() {
        $("#locspbody").load("/BanHangTaiQuay/ShowFilterSP");
    }

    // Áp dụng lọc
    function loc() {
        $('#pagingsp').twbsPagination('destroy');
        filterSP();
    }

    // Lọc dữ liệu
    function filterSP() {
        let lstdm = [];
        document.querySelectorAll('input[type="checkbox"][name="dm"]:checked')
            .forEach(cb => lstdm.push(cb.id));

        let locgia = $('input[name="kgia"]:checked').attr('id');

        let request = {
            lstDM: lstdm,
            pageSize: pageSizesp,
            page: pageIndexsp,
            khoangGia: locgia
        };

        $.ajax({
            url: "/BanHangTaiQuay/LocSP",
            type: "POST",
            dataType: "json",
            data: request,
            success: function (response) {
                $("#locsp").modal("hide");
                $(".product-list").empty();

                if (response.data.length === 0) {
                    $(".product-list").append(`<span>Không có sản phẩm nào</span>`);
                } else {
                    response.data.forEach(sp => {
                        $(".product-list").append(`
                            <li class="product-item d-flex flex-row" onclick="showSPDetail('${sp.id}')">
                                <div class="product-img">
                                    <img src="${sp.anh}" class="img-fluid rounded-start" alt="...">
                                </div>
                                <div class="product-detail d-flex flex-column flex-grow-1">
                                    <span class="product-name mt-1">${sp.ten}</span>
                                    <div class="product-infor mt-auto">
                                        <span style="flex-basis:100%">
                                            <b style="color:blue;font-size:14px; font-weight:700">
                                                ${sp.giaBan.toLocaleString()}
                                            </b>
                                        </span>
                                    </div>
                                </div>
                            </li>`);
                    });

                    pagingsp(response.total, function () {
                        filterSP();
                    });
                }
            },
            error: function (err) {
                console.log('Error:', err);
            }
        });
    }
</script>
