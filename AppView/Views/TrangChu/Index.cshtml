@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

<style>
    .set-bg {
        background-size: contain !important; /* hoặc 'cover' nếu muốn full nhưng không mờ */
        background-repeat: no-repeat;
        background-position: center center;
        image-rendering: auto;
    }

    .stars-outer {
        position: relative;
        display: inline-block;
    }

    .stars-inner {
        position: absolute;
        top: 0;
        left: 0;
        white-space: nowrap;
        overflow: hidden;
        width: auto;
    }

    .stars-outer::before {
        content: "\f005 \f005 \f005 \f005 \f005";
        font-family: 'Font Awesome 5 Free';
        font-weight: 900;
        font-size: 14px;
        color: #ccc;
    }

    .stars-inner::before {
        content: "\f005 \f005 \f005 \f005 \f005";
        font-family: 'Font Awesome 5 Free';
        font-weight: 900;
        color: #f7941d;
        font-size: 14px;
    }
</style>

<!-- Hero Section Begin -->
<section class="hero">
    <div class="hero__slider owl-carousel">
        <div class="hero__items set-bg" data-setbg="/img/hero/thoi-trang-nam.jpg">
            <div class="container">
                <div class="row">
                    <div class="col-xl-5 col-lg-7 col-md-8">
                        <div class="hero__text">
                            <h6>Thời trang nam Shop</h6>
                            <p>Thương hiệu tạo ra những sản phẩm thiết yếu sang trọng. Cam kết vững chắc về chất lượng vượt trội.</p>
                            <a href="Home/Shop" class="primary-btn">Mua sắm ngay <span class="arrow_right"></span></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero__items set-bg" data-setbg="/img/hero/thoitrang2.jpg">
            <div class="container">
                <div class="row">
                    <div class="col-xl-5 col-lg-7 col-md-8">
                        <div class="hero__text">
                            <h6>Thời trang nam Shop</h6>
                            <p>Thương hiệu tạo ra những sản phẩm thiết yếu sang trọng. Cam kết vững chắc về chất lượng vượt trội.</p>
                            <a href="Home/Shop" class="primary-btn">Mua sắm ngay <span class="arrow_right"></span></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Hero Section End -->

<!-- Banner Section Begin -->
<section class="banner spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-7 offset-lg-4">
                <div class="banner__item">
                    <div class="banner__item__pic">
                        <img src="/img/banner/banner-1.jpg" alt="">
                    </div>
                    <div class="banner__item__text">
                        <h2>Phân loại đa dạng</h2>
                        <a href="Home/Shop">Mua sắm ngay</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="banner__item banner__item--middle">
                    <div class="banner__item__pic">
                        <img src="/img/banner/banner4.png" alt="">
                    </div>
                    <div class="banner__item__text">
                        <h2>Thiết kế hiện đại</h2>
                        <a href="Home/Shop">Mua sắm ngay</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="banner__item banner__item--last">
                    <div class="banner__item__pic">
                        <img src="/img/banner/banner3.png" alt="">
                    </div>
                    <div class="banner__item__text">
                        <h2>Trẻ trung</h2>
                        <a href="Home/Shop">Mua sắm ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>a
</section>
<!-- Banner Section End -->

<!-- Product Section Begin -->
<section class="product spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <ul class="filter__controls">
                    <li class="active" data-filter="*" onclick="FilterSPHome(2)">Bán chạy nhất</li>
                    <li data-filter=".new-arrivals" onclick="FilterSPHome(1)">Sản phẩm mới</li>
                    <li data-filter=".hot-sales" onclick="FilterSPHome(3)">Đánh giá cao</li>
                </ul>
            </div>
        </div>
        <div class="row product__filter"></div>
    </div>
</section>
<!-- Product Section End -->

<script src="/js/jquery-3.3.1.min.js"></script>
<script>
    $(document).ready(function () {
        FilterSPHome(2);
    });

    const starsTotal = 5;

    function getRatings(id, ratings) {
        const starPercentage = (ratings / starsTotal) * 100;
        const starPercentageRounded = `${Math.round(starPercentage / 10) * 10}%`;
        $(`.${id} .stars-inner`).css('width', starPercentageRounded);
    }

    function addCart(idctsp) {
        $.ajax({
            async: true,
            type: 'POST',
            dataType: "json",
            data: { id: idctsp },
            url: '/Home/AddToCart',
            success: function (response) {
                if (response.success == true) {
                    toastr.success(response.message, 'Success Alert', { timeOut: 300 });
                } else {
                    toastr.error(response.message, 'Error Alert', { timeOut: 300 });
                }
            },
            error: function (response) {
                console.error("Lỗi thêm giỏ hàng:", response);
                toastr.error("Lỗi thêm vào giỏ hàng", 'Error Alert', { timeOut: 300 });
            }
        });

        $.ajax({
            async: true,
            type: 'POST',
            dataType: "json",
            data: { sl: 1 },
            url: '/Home/TongSoLuong',
            success: function (response) {
                if (response.success == true) {
                    $('#tongsoluong').text(response.sl);
                }
            },
            error: function (response) {
                console.error("Lỗi cập nhật tổng số lượng:", response);
            }
        });
    }

        function FilterSPHome(index) {
        $.ajax({
            type: "GET",
            url: "/TrangChu/FilterSPHome/" + index,
            dataType: 'json',
            success: function (response) {
                $(".product__filter").empty();

                if (!response || !Array.isArray(response.data)) {
                    console.error("Dữ liệu trả về không hợp lệ:", response);
                    toastr.error("Không thể tải sản phẩm", 'Error', { timeOut: 300 });
                    return;
                }

                for (let i = 0; i < response.data.length; i++) {
                    const item = response.data[i] || {};
                    const id = item.id ? item.id.substring(0, 8) : `prod-${i}`;

                    const giaGoc = typeof item.giaGoc === "number" ? item.giaGoc : 0;
                    const giaBan = typeof item.giaBan === "number" ? item.giaBan : 0;
                    const soSao = typeof item.soSao === "number" ? item.soSao : 0;
                    const khuyenMai = typeof item.khuyenMai === "number" ? item.khuyenMai : null;

                    const khuyenMaiHTML = khuyenMai == null ? '' :
                        khuyenMai <= 100
                            ? `<span class="label">-${khuyenMai}%</span>`
                            : `<span class="label">-${Number(khuyenMai).toLocaleString()} VND</span>`;

                    const productHTML = `
                        <div class="col-lg-3 col-md-6 col-sm-6 mix new-arrivals">
                            <div class="product__item sale ${id}">
                                <a href="/Home/ProductDetail?idSanPham=${item.id || ''}">
                                    <div class="product__item__pic" style="background-image: url('${item.anh || '/img/no-image.png'}');">
                                        ${khuyenMaiHTML}
                                        <ul class="product__hover">
                                            <li><a href="/Home/ProductDetail?idSanPham=${item.id || ''}"><img src="img/icon/search.png" alt=""></a></li>
                                        </ul>
                                    </div>
                                </a>
                                <div class="product__item__text">
                                    <h6>${item.ten || 'Không rõ tên'}</h6>
                                    <a onclick="addCart('${item.idCTSP || ''}')" class="add-cart">+ Thêm vào giỏ hàng</a>
                                    <div class="stars-outer">
                                        <div class="stars-inner"></div>
                                    </div>
                                    ${
                                        giaBan !== giaGoc && giaGoc > 0
                                            ? `<h5>${giaBan.toLocaleString()} VND</h5><span style="font-size:14px; color:#3a3b3c;"><del>${giaGoc.toLocaleString()} VND</del></span>`
                                            : `<h5>${giaBan.toLocaleString()} VND</h5>`
                                    }
                                </div>
                            </div>
                        </div>`;

                    $(".product__filter").append(productHTML);
                    getRatings(id, soSao);
                }
            },
            error: function (response) {
                console.error("Lỗi khi lọc sản phẩm:", response);
                toastr.error("Lỗi khi tải sản phẩm", 'Error', { timeOut: 300 });
            }
        });
    }
</script>
