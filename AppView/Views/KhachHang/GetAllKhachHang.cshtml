@model AppView.PhanTrang.PhanTrangKhachHang

@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
    int stt = 1;
}

<div class="container-fluid">
    <h1 class="text-center mb-4"><b>Quản lý khách hàng</b></h1>

    <div class="row mb-3 align-items-center">
        <!-- Nút Thêm mới -->
        <div class="col-auto">
            <a class="btn btn-dark text-white px-4 py-2 custom-hover" asp-action="Create">
                <i class="fa fa-plus"></i> Thêm mới
            </a>
        </div>

        <!-- Select Sắp xếp -->
        <div class="col-auto">
            <select id="SortOrder" class="form-select form-select-sm">
                <option value="">-- Sắp xếp --</option>
                <option value="ten_asc">Tên A → Z</option>
                <option value="ten_desc">Tên Z → A</option>
            </select>
        </div>

        <!-- Form tìm kiếm -->
        <div class="col">
            <form id="searchForm" asp-action="GetAllKHTheoTimKiem" asp-controller="KhachHang" method="get" class="d-flex gap-2">
                <input type="text" name="Ten" class="form-control" placeholder="Tìm kiếm theo tên khách hàng">
                <input type="text" name="SDT" class="form-control" placeholder="Tìm kiếm theo SDT khách hàng">
                <input type="hidden" id="SortOrderHidden" name="SortOrder" value="">
                <button class="btn btn-secondary text-white" type="submit">
                    <i class="fa fa-search"></i>
                </button>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table table-bordered table-hover">
                <tr>
                    <th>STT</th>
                    <th>Mã KH</th>
                    <th>Tên</th>
                    <th>Giới tính</th>
                    <th>Email</th>
                    <th>Ngày sinh</th>
                    <th>SDT</th>
                    <th>Địa chỉ</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.listkh)
                {
                    <tr>
                        <td class="text-center align-middle">@stt</td>
                        <td class="align-middle"><strong>@item.MaKhachHang</strong></td>
                        <td class="align-middle">@item.Ten</td>
                        <td class="text-center align-middle">
                            @(item.GioiTinh == 0 ? "Nữ" : item.GioiTinh == 1 ? "Nam" : "")
                        </td>
                        <td class="align-middle"><small>@item.Email</small></td>
                        <td class="text-center align-middle">@item.NgaySinh</td>
                        <td class="align-middle">@item.SDT</td>
                        <td class="align-middle"><small>@item.DiaChi</small></td>
                        <td class="text-center align-middle">
                            @if (item.TrangThai == 0)
                            {
                                <span class="badge bg-danger">Không hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>
                        <td class="text-center align-middle">
                            <div class="btn-group" role="group">
                                <!-- Nút Sửa: màu vàng -->
                                <a asp-action="Updates" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning text-white"
                                   title="Sửa">
                                    <i class="fa fa-edit"></i>
                                </a>

                                <!-- Nút Lịch sử: giữ màu đen trắng -->
                                <a asp-action="GetAllLSTDByIDKH" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-dark text-white"
                                   title="Lịch sử">
                                    <i class="fa fa-history"></i>
                                </a>

                                <!-- Nút Xóa: màu đỏ -->
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger text-white"
                                   title="Xóa"
                                   onclick="return confirm('Bạn có chắc muốn xóa khách hàng này?');">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </div>
                        </td>

                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-center mt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm">
                @if (Model.PagingInfo.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="/KhachHang/GetAllKhachHang?ProductPage=@(Model.PagingInfo.CurrentPage - 1)" aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.PagingInfo.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PagingInfo.CurrentPage ? "active" : "")">
                        <a class="page-link" href="/KhachHang/GetAllKhachHang?ProductPage=@i">@i</a>
                    </li>
                }

                @if (Model.PagingInfo.CurrentPage < Model.PagingInfo.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="/KhachHang/GetAllKhachHang?ProductPage=@(Model.PagingInfo.CurrentPage + 1)" aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>

<style>
    .table th, .table td {
        vertical-align: middle;
        font-size: 0.875rem;
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }

    .btn-group .btn {
        margin: 0 2px;
    }

    .badge {
        font-size: 0.75rem;
        padding: 0.35em 0.65em;
    }
    /* Header table đen chữ trắng */
    .table thead th {
        background-color: #000; /* nền đen */
        color: #fff; /* chữ trắng */
        text-align: center;
    }

    /* Tô màu khi hover dòng */
    .table tbody tr:hover {
        background-color: #f2f2f2;
    }

    /* Căn giữa nội dung trong các cột trạng thái và thao tác */
    .table td {
        vertical-align: middle;
        text-align: center;
    }
</style>
    
<script>
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
    // Khi chọn option, gán vào input ẩn và submit form
    document.getElementById("SortOrder").addEventListener("change", function () {
        document.getElementById("SortOrderHidden").value = this.value;
        document.getElementById("searchForm").submit();
    });

    // Khi load trang, giữ trạng thái select
    const params = new URLSearchParams(window.location.search);
    const sortOrder = params.get("SortOrder");
    if (sortOrder) {
        document.getElementById("SortOrder").value = sortOrder;
        document.getElementById("SortOrderHidden").value = sortOrder;
    }
</script>
