@model AppView.PhanTrang.PhanTrangKhachHang
@using AppData.Models;
@using AppData.ViewModels;
@using Newtonsoft.Json;
@{
    LoginViewModel loginInfor = new LoginViewModel();
    string session = Context.Session.GetString("LoginInfor");
    if (session != null)
    {
        loginInfor = JsonConvert.DeserializeObject<LoginViewModel>(Context.Session.GetString("LoginInfor"));
    }
    ViewData["Title"] = "Danh sách khách hàng";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
    int stt = 1;
}

<div class="container-fluid">
    <h1 class="text-center mb-4"><b>Quản lý khách hàng</b></h1>

    <div class="row mb-3 align-items-center">
        <!-- Nút Thêm mới -->
        <div class="col-auto">
            <a class="btn btn-dark text-white px-4 py-2 custom-hover" asp-action="Create">
                <i class="fa fa-plus"></i> Thêm mới
            </a>
        </div>

        <!-- Select Sắp xếp -->
        <div class="col-auto">
            <select id="SortOrder" class="form-select form-select-sm">
                <option value="">-- Sắp xếp --</option>
                <option value="ten_asc">Tên A → Z</option>
                <option value="ten_desc">Tên Z → A</option>
            </select>
        </div>

        <!-- Form tìm kiếm -->
        <div class="col">
            <form id="searchForm" asp-action="GetAllKHTheoTimKiem" asp-controller="KhachHang" method="get" class="d-flex gap-2">
                <input type="text" name="Ten" class="form-control" placeholder="Tìm kiếm theo tên khách hàng">
                <input type="text" name="SDT" class="form-control" placeholder="Tìm kiếm theo SDT khách hàng">
                <input type="hidden" id="SortOrderHidden" name="SortOrder" value="">
                <button class="btn btn-secondary text-white" type="submit">
                    <i class="fa fa-search"></i>
                </button>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table table-bordered table-hover">
                <tr>
                    <th>STT</th>
                    <th>Mã KH</th>
                    <th>Tên</th>
                    <th>Giới tính</th>
                    <th>Email</th>
                    <th>Ngày sinh</th>
                    <th>SDT</th>
                    <th>Địa chỉ</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.listkh)
                {
                    <tr>
                        <td class="text-center align-middle">@stt</td>
                        <td class="align-middle"><strong>@item.MaKhachHang</strong></td>
                        <td class="align-middle">@item.Ten</td>
                        <td class="text-center align-middle">
                            @(item.GioiTinh == 0 ? "Nữ" : item.GioiTinh == 1 ? "Nam" : "")
                        </td>
                        <td class="align-middle"><small>@item.Email</small></td>
                        <td class="text-center align-middle">@item.NgaySinh</td>
                        <td class="align-middle">@item.SDT</td>
                        <td class="align-middle">
                            @if (item.DiaChiList != null && item.DiaChiList.Any())
                            {
                                <ul class="list-unstyled mb-0 text-start">
                                    @foreach (var dc in item.DiaChiList)
                                    {
                                        <li>
                                            <small>
                                                @dc.DiaChiChiTiet, @dc.Xa, @dc.Huyen, @dc.Tinh
                                                @if (dc.IsDefault)
                                                {
                                                    <span class="badge bg-primary">Mặc định</span>
                                                }
                                            </small>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <small class="text-muted">Chưa có địa chỉ</small>
                            }
                        </td>

                        <td class="text-center align-middle">
                            @if (item.TrangThai == 0)
                            {
                                <span class="badge bg-danger">Không hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>
                        <td class="text-center align-middle">
                            <div class="btn-group" role="group">
                                <a asp-action="Updates" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning text-white" title="Sửa">
                                    <i class="fa fa-edit"></i>
                                </a>
                                <a asp-action="GetAllLSTDByIDKH" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-dark text-white" title="Lịch sử">
                                    <i class="fa fa-history"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger text-white" title="Xóa"
                                   onclick="return confirm('Bạn có chắc muốn xóa khách hàng này?');">
                                    <i class="fa fa-trash"></i>
                                </a>
                                <!-- Nút Thêm địa chỉ -->
                                <button type="button" class="btn btn-sm btn-primary text-white"
                                        data-toggle="modal" data-target="#addAddressModal"
                                        onclick="setCurrentKH('@item.Id')">
                                    <i class="fa fa-map-marker-alt"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>

    <!-- Modal Thêm địa chỉ khách hàng -->
    <div class="modal fade" id="addAddressModal" tabindex="-1" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm địa chỉ mới</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <label>Tỉnh</label>
                    <select id="newProvince" class="form-control">
                        <option value="">-- Chọn tỉnh --</option>
                    </select>
                    <label>Huyện</label>
                    <select id="newDistrict" class="form-control">
                        <option value="">-- Chọn huyện --</option>
                    </select>
                    <label>Xã</label>
                    <select id="newWard" class="form-control">
                        <option value="">-- Chọn xã --</option>
                    </select>
                    <label>Địa chỉ chi tiết</label>
                    <input type="text" class="form-control" id="newChiTiet" placeholder="Nhập địa chỉ chi tiết">
                    <div class="form-check mt-2">
                        <input type="checkbox" class="form-check-input" id="isDefaultAddress">
                        <label class="form-check-label">Đặt làm mặc định</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Huỷ</button>
                    <button class="btn btn-primary" onclick="submitNewAddress()">Lưu địa chỉ</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/jquery-3.3.1.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<style>
    /* Căn giữa nội dung trong các cột trạng thái và thao tác */
    .table td {
        vertical-align: middle;
        text-align: center;
    }
</style>

<script>
    var currentKHId = null;

    function setCurrentKH(id) {
        currentKHId = id;
        loadProvinces();
    }

    function loadProvinces() {
        $.ajax({
            type: "GET",
            url: "https://online-gateway.ghn.vn/shiip/public-api/master-data/province",
            headers: { token: '1ab503a2-5824-11f0-99f8-027692bb547c' },
            dataType: "json",
            success: function (data) {
                $('#newProvince').empty().append('<option value="">-- Chọn tỉnh --</option>');
                data.data.forEach(p => {
                    $('#newProvince').append(`<option value="${p.ProvinceID}">${p.ProvinceName}</option>`);
                });
            }
        });
    }

    $("#newProvince").on("change", function () {
        var provinceId = $(this).val();
        if (!provinceId) return;

        $.ajax({
            type: "GET",
            url: "https://online-gateway.ghn.vn/shiip/public-api/master-data/district?province_id=" + provinceId,
            headers: { token: '1ab503a2-5824-11f0-99f8-027692bb547c' },
            dataType: "json",
            success: function (data) {
                $('#newDistrict').empty().append('<option value="">-- Chọn huyện --</option>');
                data.data.forEach(d => {
                    $('#newDistrict').append(`<option value="${d.DistrictID}">${d.DistrictName}</option>`);
                });
            }
        });
    });

    $("#newDistrict").on("change", function () {
        var districtId = $(this).val();
        if (!districtId) return;

        $.ajax({
            type: "GET",
            url: "https://online-gateway.ghn.vn/shiip/public-api/master-data/ward?district_id=" + districtId,
            headers: { token: '1ab503a2-5824-11f0-99f8-027692bb547c' },
            dataType: "json",
            success: function (data) {
                $('#newWard').empty().append('<option value="">-- Chọn xã --</option>');
                data.data.forEach(w => {
                    $('#newWard').append(`<option value="${w.WardCode}">${w.WardName}</option>`);
                });
            }
        });
    });

    function submitNewAddress() {
        if (!currentKHId) {
            alert("Không xác định khách hàng!");
            return;
        }

        var diaChiMoi = {
            tinh: $("#newProvince option:selected").text().trim(),
            huyen: $("#newDistrict option:selected").text().trim(),
            xa: $("#newWard option:selected").text().trim(),
            diaChiChiTiet: $("#newChiTiet").val(),
            isDefault: $("#isDefaultAddress").is(":checked")
        };

        if (!diaChiMoi.tinh || !diaChiMoi.huyen || !diaChiMoi.xa || !diaChiMoi.diaChiChiTiet) {
            alert("Vui lòng điền đầy đủ thông tin địa chỉ!");
            return;
        }

        $.ajax({
            url: `https://localhost:7095/api/DiaChi/khachhang/${currentKHId}/diachi`,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(diaChiMoi),
            success: function () {
                alert("✅ Đã thêm địa chỉ mới");
                $('#addAddressModal').modal('hide');
                location.reload();
            },
            error: function () {
                alert("❌ Không thể thêm địa chỉ");
            }
        });
    }

    // Tooltip bootstrap
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Giữ trạng thái sort order
    document.getElementById("SortOrder").addEventListener("change", function () {
        document.getElementById("SortOrderHidden").value = this.value;
        document.getElementById("searchForm").submit();
    });

    const params = new URLSearchParams(window.location.search);
    const sortOrder = params.get("SortOrder");
    if (sortOrder) {
        document.getElementById("SortOrder").value = sortOrder;
        document.getElementById("SortOrderHidden").value = sortOrder;
    }
</script>

