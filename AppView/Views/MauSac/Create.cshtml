@model AppData.Models.MauSac

@{
    ViewData["Title"] = "Create";
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.1/dist/jquery.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.7.0/css/all.css" integrity="sha384-lZN37f5QGtY3VHgisS14W3ExzMWZxybE1SJSEsQp9S+oqd12jhcu+A56Ebc1zFSJ" crossorigin="anonymous">
}

<h1>Thêm mới màu sắc</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger">
                @ViewBag.ErrorMessage
            </div>
        }
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group" hidden>
                <label asp-for="ID" class="control-label"></label>
                <input asp-for="ID" class="form-control" />
                <span asp-validation-for="ID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ten" class="control-label">Tên</label>
                <input asp-for="Ten" class="form-control" autocomplete="off" />
                <div id="emptyNameError" class="invalid-feedback d-none">Vui lòng nhập tên màu sắc!</div>
            </div>
            <div class="form-group">
                <label asp-for="Ma" class="control-label">Mã</label>
                <input asp-for="Ma" type="color" class="form-control" />
                <div id="maNameError" class="invalid-feedback d-none">Vui lòng chọn mã màu sắc!</div>
            </div>
            <div class="form-group" hidden>
                <label asp-for="TrangThai" class="control-label"></label>
                <input asp-for="TrangThai" class="form-control" />
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-dark text-white px-4 py-2 custom-hover" style="margin-top: 10px" />
                <a asp-action="Show" asp-controller="MauSac" class="btn btn-outline-orange me-2" style="margin-top: 10px"> <i class="fas fa-arrow-left"></i> Quay lại</a>
            </div>
        </form>
    </div>
</div>
<div id="toastMessage" style="position: fixed; top: 20px; right: 20px; padding: 12px 20px; border-radius: 6px; display: none; color: #fff; z-index: 9999;"></div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $("input[name='Ten']").on("input", function () {
        $(this).removeClass("is-invalid");
        $("#emptyNameError").text("");
    });
    $("input[name='Ma']").on("input", function () {
        $(this).removeClass("is-invalid");
        $("#maNameError").text("");
    });
    $("form").submit(function () {
        var tenInput = $("input[name='Ten']");
        var maInput = $("input[name='Ma']");
        var tenValue = tenInput.val();
        var maValue = maInput.val();
        if (tenValue.trim() === "") {
            tenInput.addClass("is-invalid");
            $("#emptyNameError").text("Tên không được bỏ trống");
            return false;
        }
        if (maValue.trim() === "") {
            tmaenInput.addClass("is-invalid");
            $("#maNameError").text("ma không được bỏ trống");
            return false;
        }
        return true;
    });
    function showMessage(message, type = 'success') {
        const toast = $("#toastMessage");
        toast.stop(true, true);
        toast.text(message);

        switch(type) {
            case 'success': toast.css('background-color', '#28a745'); break;
            case 'danger':
            case 'error': toast.css('background-color', '#dc3545'); break;
            case 'warning': toast.css('background-color', '#ffc107; color:#212529'); break;
            default: toast.css('background-color', '#17a2b8'); break;
        }

        toast.fadeIn(400).delay(3000).fadeOut(400);
    }

    $(document).ready(function(){
        var message = @Html.Raw(Json.Serialize(TempData["AlertMessage"] ?? ""));
        var type = @Html.Raw(Json.Serialize(TempData["AlertType"] ?? "success"));
        if(message) {
            showMessage(message, type);
        }
    });
</script>
<style>
    .btn-outline-orange {
        background-color: #fff;
        color: #000 !important;
        border: 1px solid #ff6600;
        transition: 0.3s;
    }

        .btn-outline-orange:hover {
            background-color: #ff6600;
            color: #fff !important;
        }
</style>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
