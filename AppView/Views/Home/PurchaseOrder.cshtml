@using AppData.ViewModels
@model List<DonMuaViewModel>

@{
    Layout = "_Layout";
}

<style>
    #navbar {
        display: flex;
        justify-content: space-evenly;
        align-items: center;
        padding: 10px 0;
        background-color: white;
    }

    #AllHoaDon {
        background-color: white;
    }

    #navbar div label span {
        cursor: pointer;
        padding: 10px;
    }

    #navbar input[type="radio"] {
        display: none;
    }

    #navbar label input[type="radio"]:checked ~ span {
        border-bottom: 1px solid black;
    }

    .VrgkXA {
        padding: 12px 0;
        margin: 12px 0;
        display: flex;
        align-items: center;
        background: white;
        border-radius: 2px;
        box-shadow: 0 1px 1px 0 rgba(0, 0, 0, .05);
    }

        .VrgkXA > input {
            flex: 1;
            font-size: 14px;
            line-height: 16px;
            border: 0;
            outline: none;
            background-color: inherit;
        }
</style>

<section style="background-color: #eee;">
    <div class="container py-5">
        <div class="row mb-4">
            <div class="col">
                <nav aria-label="breadcrumb" class="bg-light rounded-3 p-3">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Đơn mua</li>
                    </ol>
                </nav>
            </div>
        </div>

        <!-- FILTER -->
        <div class="row">
            <div class="col">
                <div onchange="LocHoaDon()" id="navbar">
                    @foreach (var option in new[] {
                    new { Value = "0", Label = "Tất cả" },
                    new { Value = "2", Label = "Chờ xác nhận" },
                    new { Value = "11", Label = "Đã xác nhận" },
                    new { Value = "10", Label = "Chờ đóng hàng" },
                    new { Value = "3", Label = "Đang giao" },
                    new { Value = "6", Label = "Hoàn thành" },
                    new { Value = "7", Label = "Đã hủy" },
                    new { Value = "5", Label = "Hoàn hàng" }
                    })
                    {
                        <div>
                            <label>
                                <input type="radio" name="menu" value="@option.Value" @(option.Value == "0" ? "checked" : "") />
                                <span>@option.Label</span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- SEARCH -->
        <div class="VrgkXA">
            <svg width="19px" height="19px" viewBox="0 0 19 19">
                <g stroke-width="1" fill="none">
                    <g transform="translate(-399, -221)" stroke-width="2">
                        <g transform="translate(400, 222)">
                            <circle cx="7" cy="7" r="7"></circle>
                            <path d="M12,12 L16.98,16.92" stroke-linecap="round" stroke-linejoin="round"></path>
                        </g>
                    </g>
                </g>
            </svg>
            <input id="search" oninput="LocHoaDon()" placeholder="Bạn có thể tìm kiếm mã hóa đơn" />
        </div>

        <!-- TABLE -->
        <div id="AllHoaDon">
            <table class="table table-bordered bg-white">
                <thead class="thead-light">
                    <tr>
                        <th>Mã đơn hàng</th>
                        <th>Ngày đặt</th>
                        <th>Ngày thanh toán</th>
                        <th>Ngày nhận hàng</th>
                        <th>Thành tiền</th>
                        <th>Trạng thái</th>
                        <th>Loại hóa đơn</th>
                    </tr>
                </thead>
                <tbody id="DShoaDon"></tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <div class="row">
            <div class="col-lg-12 text-center">
                <ul id="pagination-demo" class="pagination justify-content-center" style="display: none;"></ul>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="/js/jquery-3.3.1.min.js"></script>
    <script src="~/Admin/js/jquery.twbsPagination.min.js"></script>

    <script>
        var pageIndex = 1;
        var pagesize = 5;

        $(document).ready(function () {
            FilterHoaDon();
        });

        function LocHoaDon() {
            $('#pagination-demo').twbsPagination('destroy');
            FilterHoaDon();
        }

              function FilterHoaDon() {
            pageIndex = 1;

            var status = $('input[name="menu"]:checked').val();
            var keyword = $('#search').val();

            var data = {
                TrangThaiGiaoHang: status,
                page: pageIndex,
                pageSize: pagesize,
                maHoaDon: keyword // CHỈ sửa dòng này
            };

            $.ajax({
                url: "https://localhost:7095/api/HoaDon/tra-cuu",
                type: "GET",
                data: data,
                success: function (response) {
                    $('#DShoaDon').empty();

                    if (response.data.length === 0) {
                        $('#DShoaDon').append('<tr><td colspan="7" class="text-center">Không tìm thấy hóa đơn nào.</td></tr>');
                        paginghd(0);
                        return;
                    }

                    for (let i = 0; i < response.data.length; i++) {
                        let row = `
                        <tr>
                            <th><a href="PurchaseOrderDetail?idHoaDon=${response.data[i].idHoaDon}">${response.data[i].maHD}</a></th>
                            <td>${response.data[i].ngaytao1}</td>
                            <td>${response.data[i].ngaythanhtoan1 || 'Chờ xử lý'}</td>
                            <td>${response.data[i].ngaynhanhang1 || 'Chờ xử lý'}</td>
                            <td>${Intl.NumberFormat().format(response.data[i].tongTien)} VNĐ</td>
                            <td>${getTrangThaiLabel(response.data[i].trangThaiGiaoHang)}</td>
                            <td>${response.data[i].loaiHoaDon === 0 ? 'Mua hàng online' : 'Mua hàng tại quầy'}</td>
                        </tr>`;
                        $('#DShoaDon').append(row);
                    }

                    paginghd(response.total, function () {
                        FilterHoaDon();
                    });
                },
                error: function (err) {
                    console.log("Lỗi:", err);
                }
            });
        }

        function paginghd(totalrow, callback) {
            var totalpages = Math.ceil(totalrow / pagesize);

            if (totalpages === 0) {
                $('#pagination-demo').hide();
                return;
            }

            if (pageIndex < 1) pageIndex = 1;
            if (pageIndex > totalpages) pageIndex = totalpages;

            $('#pagination-demo').twbsPagination('destroy');
            $('#pagination-demo').show();

            $('#pagination-demo').twbsPagination({
                totalPages: totalpages,
                startPage: pageIndex,
                visiblePages: 5,
                first: 'Đầu',
                last: 'Cuối',
                prev: 'Trước',
                next: 'Tiếp',
                onPageClick: function (event, page) {
                    pageIndex = page;
                    setTimeout(callback, 200);
                }
            });
        }

            function getTrangThaiLabel(status) {
            switch (status) {
                case 2: return 'Chờ xác nhận';
                case 11: return 'Đã xác nhận'; 
                case 10: return 'Chờ đóng hàng';
                case 3: return 'Đang giao hàng';
                case 6: return 'Hoàn thành';
                case 7: return 'Đã hủy';
                case 5: return 'Hoàn hàng';
                case 9: return 'Chờ xác nhận hoàn hàng';
                case 8: return 'Chờ xác nhận hủy';
                case 4: return 'Đang hoàn hàng';
                default: return 'Không xác định';
            }
        }

    </script>
}
