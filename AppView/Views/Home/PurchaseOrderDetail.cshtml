@using AppData.ViewModels
@model List<DonMuaChiTietViewModel>

@{
    Layout = "_Layout";

    var firstItem = Model.FirstOrDefault();
    if (firstItem == null)
    {
        <div class="alert alert-danger">Không tìm thấy đơn hàng.</div>
        return;
    }

    var trangThaiText = firstItem.TrangThaiGiaoHang switch
    {
        2 => "Chờ xác nhận",
        11 => "Đã xác nhận",
        10 => "Chờ đóng hàng",
        3 => "Đang giao hàng",
        6 => "Hoàn thành",
        7 => "Đơn hủy",
        8 => "Chờ xác nhận hủy",
        9 => "Chờ xác nhận hoàn hàng",
        4 => "Đang hoàn hàng",
        5 => "Hoàn hàng thành công",
        _ => "Không xác định"
    };

    int tongTienHang = Model.Sum(x => x.DonGia * x.SoLuong);
    int tienShip = firstItem.TienShip;
    int? giaTriGiam = firstItem.GiaTri;
    int? hinhThucGiamGia = firstItem.HinhThucGiamGia;
    int diemSudung = firstItem.lichSuTichDiems.FirstOrDefault(x => x.TrangThai == 0)?.Diem ?? 0;
    int diemTich = firstItem.lichSuTichDiems.FirstOrDefault(x => x.TrangThai == 1)?.Diem ?? 0;
    int tileTieuDiem = firstItem.TiLeTieuDiem;
    int tileTichDiem = firstItem.TiLeTichDiem;

    int tienGiam = 0;
    if (hinhThucGiamGia == 1) tienGiam = (int)(tongTienHang * (double)(giaTriGiam ?? 0) / 100);
    else if (hinhThucGiamGia == 0) tienGiam = giaTriGiam ?? 0;

    int tienTruDiem = diemSudung * tileTieuDiem;
    int tongThanhToan = tongTienHang + tienShip - tienGiam - tienTruDiem;

    bool choHuy = firstItem.TrangThaiGiaoHang == 2;
    bool choHoan = firstItem.TrangThaiGiaoHang == 6 && DateTime.Now.Subtract(Convert.ToDateTime(firstItem.NgayThanhToan)).TotalDays < 3 && Model.All(x => x.TrangThaiDanhGia == 0);
    bool choHoanTacHuy = firstItem.TrangThaiGiaoHang == 8;
    bool choHoanTacHoan = firstItem.TrangThaiGiaoHang == 9;
    bool choXacNhanGiaoThanhCong = firstItem.TrangThaiGiaoHang == 3;

    string FormatVND(int number) => number.ToString("n0").Replace(',', '.') + " VNĐ";
}

<section style="background:#eee;">
    <div class="container py-4">

        <!-- Breadcrumb -->
        <nav class="bg-light rounded-3 p-3 mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="PurchaseOrder">Đơn mua</a></li>
                <li class="breadcrumb-item active">@trangThaiText</li>
            </ol>
        </nav>

        <!-- Chi tiết sản phẩm -->
        <div class="table-responsive bg-white rounded shadow-sm">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="/img/product/@item.DuongDan" width="60" height="60" class="me-2" />
                                    <div>
                                        <strong>@item.TenSanPham</strong><br />
                                        @item.TenKichCo / @item.TenMau
                                    </div>
                                </div>
                            </td>
                            <td>@FormatVND(item.DonGia)</td>
                            <td>@item.SoLuong</td>
                            <td>@FormatVND(item.DonGia * item.SoLuong)</td>
                            <td>
                                @if (item.TrangThaiGiaoHang == 6 && item.TrangThaiDanhGia == 0)
                                {
                                    <a class="btn btn-dark btn-sm" asp-controller="Home" asp-action="ReviewProducts" asp-route-idCTHD="@item.IDCTHD">Đánh giá</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Tổng tiền -->
        <div class="mt-4 bg-white rounded shadow-sm p-3">
            <h5>Thông tin đơn hàng</h5>
            <ul class="list-unstyled">
                <li>Giá sản phẩm: <strong>@FormatVND(tongTienHang)</strong></li>
                <li>Phí vận chuyển: <strong>@FormatVND(tienShip)</strong></li>
                @if (tienGiam > 0)
                {
                    <li>Voucher: <strong>-@FormatVND(tienGiam)</strong></li>
                }
                @if (tienTruDiem > 0)
                {
                    <li>Điểm sử dụng: <strong>-@FormatVND(tienTruDiem)</strong></li>
                }
                <li><strong>Tổng thanh toán: @FormatVND(tongThanhToan)</strong></li>
            </ul>
        </div>

        <!-- Địa chỉ và thanh toán -->
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="bg-light p-3 rounded">
                    <h5>Địa chỉ nhận hàng</h5>
                    <p class="mb-1"><strong>@firstItem.TenNguoiNhan</strong></p>
                    <p class="mb-1">@firstItem.DiaChi</p>
                    <p class="mb-1">@firstItem.SDT</p>
                    <p class="mb-0">@firstItem.Email</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="bg-light p-3 rounded">
                    <h5>Thông tin khác</h5>
                    <p class="mb-1">Phương thức thanh toán: <strong>@firstItem.PhuongThucThanhToan</strong></p>
                    @if (diemTich > 0)
                    {
                        <p class="mb-0">Điểm tích lũy: <strong>@(diemTich.ToString("n0"))</strong></p>
                    }
                </div>
            </div>
        </div>

        <!-- Nút hành động -->
        <div class="mt-4 text-end">
            @if (choHuy)
            {
                <a class="btn btn-outline-danger" asp-controller="Home" asp-action="HuyDonHang" asp-route-idHoaDon="@firstItem.ID">Hủy đơn hàng</a>
            }
            else if (choHoan)
            {
                <a class="btn btn-outline-dark" asp-controller="Home" asp-action="DoiTraHang" asp-route-idHoaDon="@firstItem.ID">Hoàn hàng</a>
            }
            else if (choHoanTacHuy)
            {
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="HoanTacHuyDonHang" asp-route-idHoaDon="@firstItem.ID">Hoàn tác hủy đơn</a>
            }
            else if (choHoanTacHoan)
            {
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="HoanTacDoiTraHang" asp-route-idHoaDon="@firstItem.ID">Hoàn tác hoàn hàng</a>
            }
            else if (choXacNhanGiaoThanhCong)
            {
                <a class="btn btn-success" asp-controller="Home" asp-action="XacNhanGHTC" asp-route-idHoaDon="@firstItem.ID">Xác nhận đã nhận hàng</a>
            }
        </div>
    </div>
</section>
