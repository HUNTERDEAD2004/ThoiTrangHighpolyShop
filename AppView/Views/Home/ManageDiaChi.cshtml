@model AppData.ViewModels.LoginViewModel
@{
    Layout = "_Layout";
}

<section class="container py-4">
    <ul class="nav nav-tabs" id="accountTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-toggle="tab" href="#profile">Hồ sơ</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#password">Đổi mật khẩu</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#diachi">Địa chỉ</a>
        </li>
    </ul>

    <div class="tab-content pt-3" id="accountTabContent">
        <div class="tab-pane fade show active" id="profile">
            <partial name="_ProfilePartial" model="Model" />
        </div>
        <div class="tab-pane fade" id="password">
            <partial name="_ChangePasswordPartial" model="Model" />
        </div>
        <div class="tab-pane fade" id="diachi">
            <div class="card p-3">
                <h5 class="mb-3">Danh sách địa chỉ</h5>
                <form id="formDiaChi">
                    <div id="listDiaChi"></div>
                </form>
                <a href="/Home/Add" class="btn btn-danger mt-3">➕ Thêm địa chỉ</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            const hash = window.location.hash;
            if (hash) {
                $('#accountTab a[href="' + hash + '"]').tab('show');
            }
            $('#accountTab a').on('click', function (e) {
                e.preventDefault();
                $(this).tab('show');
                history.replaceState(null, null, this.hash);
            });
            loadDiaChi();
        });

        function loadDiaChi() {
            const userId = '@Model.Id';
            const diaChiDaChon = localStorage.getItem("diaChiDaChon");
            $.get(`https://localhost:7095/api/DiaChi/khachhang/${userId}/diachi`, function (data) {
                let html = '';
                let checkedFound = false;
                data.forEach(dc => {
                    let checked = '';
                    if (diaChiDaChon && dc.idDiaChi === diaChiDaChon) {
                        checked = 'checked';
                        checkedFound = true;
                    } else if (!diaChiDaChon && dc.isDefault && !checkedFound) {
                        checked = 'checked';
                        checkedFound = true;
                    }
                    html += `
                        <div class="border rounded p-2 mb-2 ${dc.isDefault ? 'border-danger' : ''}">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <label class="mb-0">
                                        <input type="radio" name="chonDiaChi" value="${dc.idDiaChi}" ${checked} style="accent-color: red;">
                                        <span>${dc.diaChiChiTiet}, ${dc.xa}, ${dc.huyen}, ${dc.tinh}</span>
                                        ${dc.isDefault ? '<div class="text-danger font-weight-bold">(Mặc định)</div>' : ''}
                                    </label>
                                </div>
                                <div>
                                    <button onclick="suaDiaChi('${dc.idDiaChi}')" type="button" class="btn btn-warning btn-sm mr-1">Sửa</button>
                                    <button onclick="xoaDiaChi('${dc.idDiaChi}')" type="button" class="btn btn-danger btn-sm">Xóa</button>
                                </div>
                            </div>
                        </div>`;
                });
                $('#listDiaChi').html(html);
            });
        }

        $(document).on("change", "input[name='chonDiaChi']", function () {
            localStorage.setItem("diaChiDaChon", $(this).val());
        });

        function xoaDiaChi(id) {
            Swal.fire({
                title: 'Bạn chắc chắn xóa?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy'
            }).then(result => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: `https://localhost:7095/api/DiaChi/diachi/${id}`,
                        type: 'DELETE',
                        success: function () {
                            toastr.success("Xóa thành công");
                            loadDiaChi();
                        },
                        error: function () {
                            toastr.error("Lỗi xóa địa chỉ");
                        }
                    });
                }
            });
        }

        function suaDiaChi(id) {
            $.get(`https://localhost:7095/api/DiaChi/diachi/${id}`, function (dc) {
                Swal.fire({
                    title: 'Chỉnh sửa địa chỉ',
                    html:
                        `<input id="Tinh" class="swal2-input" placeholder="Tỉnh/TP" value="${dc.tinh}">
                         <input id="Huyen" class="swal2-input" placeholder="Quận/Huyện" value="${dc.huyen}">
                         <input id="Xa" class="swal2-input" placeholder="Phường/Xã" value="${dc.xa}">
                         <input id="ChiTiet" class="swal2-input" placeholder="Địa chỉ chi tiết" value="${dc.diaChiChiTiet}">
                         <label><input type="checkbox" id="IsDefault" ${dc.isDefault ? 'checked' : ''}> Đặt làm mặc định</label>`,
                    focusConfirm: false,
                    showCancelButton: true,
                    preConfirm: () => {
                        return {
                            tinh: document.getElementById("Tinh").value,
                            huyen: document.getElementById("Huyen").value,
                            xa: document.getElementById("Xa").value,
                            diaChiChiTiet: document.getElementById("ChiTiet").value,
                            isDefault: document.getElementById("IsDefault").checked
                        };
                    }
                }).then(result => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: `https://localhost:7095/api/DiaChi/diachi/${id}`,
                            type: 'PUT',
                            contentType: 'application/json',
                            data: JSON.stringify(result.value),
                            success: function () {
                                toastr.success("Cập nhật thành công");
                                loadDiaChi();
                            },
                            error: function () {
                                toastr.error("Lỗi cập nhật địa chỉ");
                            }
                        });
                    }
                });
            });
        }
    </script>
}
