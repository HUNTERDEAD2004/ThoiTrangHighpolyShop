@model AppData.ViewModels.KhachHangViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="row mt-3">
    <div class="col-4"></div>
    <div class="col-4">
        <h3 class="text-center mb-3"><strong>Đăng ký</strong></h3>

        <div class="tab-content" style="border-radius: 1rem;">
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form asp-action="Register" id="registerForm">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Email -->
                <div class="form-group">
                    <label asp-for="Email" class="control-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Tên -->
                <div class="form-group">
                    <label asp-for="Ten" class="control-label">Tên</label>
                    <input asp-for="Ten" class="form-control" />
                    <span asp-validation-for="Ten" class="text-danger"></span>
                </div>
                <!-- Giới tính -->
                <div class="form-group">
                    <label class="control-label">Giới tính</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="gioiTinh" value="1" asp-for="GioiTinh">
                        <label class="form-check-label" for="flexRadioDefault1">
                            Nam
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="gioiTinh" value="0" asp-for="GioiTinh">
                        <label class="form-check-label" for="flexRadioDefault2">
                            Nữ
                        </label>
                    </div>
                </div>

                <!-- Ngày sinh -->
                <div class="form-group">
                    <label asp-for="NgaySinh" class="control-label">Ngày sinh</label>
                    <input asp-for="NgaySinh" type="date" class="form-control" />
                    <span asp-validation-for="NgaySinh" class="text-danger"></span>
                </div>
                <!-- SĐT -->
                <div class="form-group">
                    <label asp-for="SDT" class="control-label">Số điện thoại</label>
                    <input asp-for="SDT" class="form-control" />
                    <span asp-validation-for="SDT" class="text-danger"></span>
                </div>

                <!-- Mật khẩu -->
                <div class="form-group">
                    <label asp-for="Password" class="control-label">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Nhập lại mật khẩu -->
                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="control-label">Nhập lại mật khẩu</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

              

                <!-- Hidden Fields -->
                <input type="hidden" asp-for="DiemTich" value="0" />
                <input type="hidden" asp-for="TrangThai" value="1" />

                <!-- Submit -->
                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary btn-block">Đăng ký</button>
                </div>

                <div class="text-center mt-2">
                    <p>Bạn đã có tài khoản? <a asp-action="Login">Đăng nhập</a></p>
                </div>
            </form>
        </div>
    </div>
    <div class="col-4"></div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
