@model AppData.ViewModels.SanPham.DonMuaSuccessViewModel
@{
    Layout = "_Layout";
}
<div class="container my-4" style="max-width:930px">
    <div class="success-w">
        @if (Model.TongTien < 0)
        {
            <div class="alert alert-danger" role="alert">
                <i class="fas fa-times-circle me-2"></i>Đặt hàng thất bại do chứa sản phẩm hết hàng
            </div>
        }
        else
        {
            <div class="alert alert-success" role="alert">
                <i class="fas fa-check-circle me-2"></i>Đặt hàng thành công
            </div>

            <div class="row mb-3">
                <div class="col-lg-6"><strong>Tên: </strong>@Model.Ten</div>
                <div class="col-lg-6"><strong>Email: </strong>@Model.Email</div>
            </div>
            <div class="row mb-3">
                <div class="col-lg-6"><strong>SĐT: </strong>@Model.SDT</div>
                <div class="col-lg-6"><strong>Phương thức thanh toán: </strong>@Model.PhuongThucThanhToan</div>
            </div>
            <div class="row mb-3">
                <div class="col-lg-6"><strong>Tổng tiền: </strong>@Model.TongTien.ToString("n0") VND</div>
                <div class="col-lg-6"><strong>Mã voucher: </strong>@Model.MaVoucher</div>
            </div>
            <div class="row mb-3">
                <div class="col-lg-12"><strong>Địa chỉ: </strong>@Model.DiaChi</div>
            </div>

            <div class="row mb-3">
                <div class="col-lg-12"><strong>Ghi chú: </strong>@Model.GhiChu</div>
            </div>

            @if (Model.GioHangs != null && Model.GioHangs.Any())
            {
                <div class="shopping__cart__table mt-3">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:60px; text-align:center">STT</th>
                                <th>Sản phẩm</th>
                                <th style="text-align:center">Giá bán</th>
                                <th style="text-align:center">Số lượng</th>
                                <th style="text-align:center">Tổng cộng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int stt = 1;
                            }
                            @foreach (var item in Model.GioHangs)
                            {
                                <tr>
                                    <td style="text-align:center">@stt</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="/img/product/@(item.Anh ?? "default.jpg")"
                                                 alt="Ảnh" class="me-2 rounded" style="height:60px;width:50px;object-fit:cover">
                                            <div>
                                                <div class="fw-bold">@item.Ten</div>
                                                <small class="text-muted">@item.MauSac / @item.KichCo</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.DonGia?.ToString("n0") VND</td>
                                    <td class="text-center fw-bold">@item.SoLuong</td>
                                    <td class="text-center">@((item.DonGia * item.SoLuong)?.ToString("n0")) VND</td>
                                </tr>
                                stt++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-warning mt-3">Không có sản phẩm trong giỏ hàng.</div>
            }

            <div class="d-flex justify-content-end mt-4">
                <button onclick="location.href='/Admin/QuanLyHoaDon/ExportPDF/@Model.ID'"
                        class="btn btn-outline-secondary me-2">
                    <i class="fas fa-file-pdf me-1"></i> Xuất PDF
                </button>
                <a asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-home me-1"></i> Quay về trang chủ
                </a>
            </div>
        }
    </div>
</div>
