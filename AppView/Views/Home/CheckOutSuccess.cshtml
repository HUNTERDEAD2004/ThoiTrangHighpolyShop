@model AppData.ViewModels.SanPham.DonMuaSuccessViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Đặt hàng thành công";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    .success-container {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .success-card {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        border: none;
        backdrop-filter: blur(10px);
        animation: fadeInUp 0.6s ease-out;
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(45deg, #28a745, #20c997);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        animation: bounce 0.8s ease-in-out;
    }

        .success-icon i {
            font-size: 2.5rem;
            color: white;
        }

    .order-code-container {
        background: linear-gradient(45deg, #f8f9fa, #e9ecef);
        border-radius: 15px;
        padding: 20px;
        margin: 25px 0;
        border: 2px dashed #dee2e6;
        position: relative;
    }

    .order-code {
        font-family: 'Courier New', monospace;
        font-size: 1.3rem;
        font-weight: bold;
        color: #495057;
        letter-spacing: 2px;
    }

    .copy-btn {
        background: linear-gradient(45deg, #007bff, #0056b3);
        border: none;
        color: white;
        border-radius: 10px;
        width: 45px;
        height: 45px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
    }

        .copy-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 123, 255, 0.4);
            background: linear-gradient(45deg, #0056b3, #004085);
        }

        .copy-btn:active {
            transform: translateY(0);
        }

    .copy-success {
        background: linear-gradient(45deg, #28a745, #20c997) !important;
    }

    .home-btn {
        background: linear-gradient(45deg, #667eea, #764ba2);
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        color: white;
        display: inline-block;
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
    }

        .home-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(102, 126, 234, 0.4);
            color: white;
            text-decoration: none;
        }

    .email-highlight {
        background: linear-gradient(45deg, #ffc107, #fd7e14);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: bold;
    }

    .pulse-animation {
        animation: pulse 0.5s ease-in-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes bounce {
        0%, 20%, 50%, 80%, 100% {
            transform: translateY(0);
        }

        40% {
            transform: translateY(-10px);
        }

        60% {
            transform: translateY(-5px);
        }
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    @@media (max-width: 768px) {
        .success-card {
            margin: 10px;
            border-radius: 15px;
        }

        .order-code {
            font-size: 1.1rem;
            letter-spacing: 1px;
        }

        .success-container {
            padding: 20px 10px;
        }
    }
</style>

<div class="success-container">
    <div class="container" style="max-width: 650px;">
        <div class="card success-card">
            <div class="card-body p-5 text-center">
                <!-- Success Icon -->
                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>

                <!-- Success Message -->
                <h2 class="text-success fw-bold mb-3">
                    <i class="fas fa-heart me-2"></i>
                    Cảm ơn bạn đã mua hàng!
                </h2>

                <p class="mb-4 text-muted" style="font-size: 1.1rem; line-height: 1.6;">
                    Đơn hàng của bạn đang được xử lý.<br />
                    Vui lòng kiểm tra email <span class="email-highlight">@Model.Email</span> để biết thêm chi tiết.
                </p>

                <!-- Order Code Section -->
                <div class="order-code-container">
                    <div class="mb-2">
                        <i class="fas fa-receipt me-2 text-primary"></i>
                        <span class="fw-bold text-dark">Mã đơn hàng</span>
                    </div>
                    <div class="d-flex justify-content-center align-items-center">
                        <span id="orderCode" class="order-code me-3">#@Model.MaHoaDon</span>
                        <button id="copyBtn" class="btn copy-btn"
                                data-bs-toggle="tooltip"
                                data-bs-placement="top"
                                title="Sao chép mã đơn hàng">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                    <small class="text-muted mt-2 d-block">
                        <i class="fas fa-info-circle me-1"></i>
                        Lưu lại mã này để tra cứu đơn hàng
                    </small>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-action="Index" class="home-btn">
                        <i class="fas fa-home me-2"></i>Quay về trang chủ
                    </a>
                    <a asp-action="PurchaseOrder" asp-route-id="@Model.MaHoaDon" class="btn btn-outline-primary" style="border-radius: 50px; padding: 12px 25px;">
                        <i class="fas fa-search me-2"></i>Theo dõi đơn hàng
                    </a>
                </div>

                <!-- Additional Info -->
                <div class="mt-4 pt-4 border-top">
                    <div class="row g-3 text-center">
                        <div class="col-md-6">
                            <div class="text-primary mb-3">
                                <i class="fas fa-shipping-fast fa-2x"></i>
                            </div>
                            <small class="text-muted">
                                <strong>Giao hàng nhanh</strong><br>
                                2-3 ngày làm việc
                            </small>
                        </div>
                        <div class="col-md-4">
                            <div class="text-success mb-3">
                                <i class="fas fa-shield-alt fa-2x"></i>
                            </div>
                            <small class="text-muted">
                                <strong>Bảo hành chính hãng</strong><br>
                                Hỗ trợ 24/7
                            </small>
                        </div>
                      
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const copyBtn = document.getElementById("copyBtn");
            const orderCodeElement = document.getElementById("orderCode");

            // Khởi tạo tooltip
            let tooltip;
            try {
                tooltip = new bootstrap.Tooltip(copyBtn);
            } catch (e) {
                console.warn('Bootstrap tooltip not available');
            }

            copyBtn.addEventListener("click", function (e) {
                e.preventDefault();

                // Lấy mã đơn hàng và loại bỏ dấu #
                const fullCode = orderCodeElement.innerText || orderCodeElement.textContent;
                const codeOnly = fullCode.replace("#", "").trim();

                console.log("Attempting to copy:", codeOnly);

                // Thử phương pháp 1: Clipboard API (hiện đại)
                if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(codeOnly)
                        .then(() => {
                            console.log("Clipboard API success");
                            showCopySuccess(codeOnly);
                        })
                        .catch(err => {
                            console.log("Clipboard API failed, trying fallback:", err);
                            fallbackCopy(codeOnly);
                        });
                } else {
                    // Thử phương pháp 2: execCommand (tương thích rộng)
                    console.log("Using fallback method");
                    fallbackCopy(codeOnly);
                }
            });

            function showCopySuccess(code) {
                const icon = copyBtn.querySelector("i");
                const originalClass = icon.className;

                // Thay đổi giao diện
                icon.className = "fas fa-check";
                copyBtn.classList.add("copy-success", "pulse-animation");

                // Cập nhật tooltip nếu có
                if (tooltip) {
                    try {
                        copyBtn.setAttribute("data-bs-original-title", "Đã sao chép: " + code);
                        tooltip.show();
                    } catch (e) {
                        console.warn('Tooltip update failed');
                    }
                } else {
                    // Hiển thị thông báo đơn giản
                    const originalText = copyBtn.getAttribute("title") || "Sao chép";
                    copyBtn.setAttribute("title", "Đã sao chép: " + code);
                    setTimeout(() => {
                        copyBtn.setAttribute("title", originalText);
                    }, 2000);
                }

                // Reset sau 2 giây
                setTimeout(() => {
                    icon.className = originalClass;
                    copyBtn.classList.remove("copy-success", "pulse-animation");

                    if (tooltip) {
                        try {
                            copyBtn.setAttribute("data-bs-original-title", "Sao chép mã đơn hàng");
                            tooltip.hide();
                        } catch (e) {
                            console.warn('Tooltip reset failed');
                        }
                    }
                }, 2000);

                console.log("Copy success feedback shown");
            }

            function fallbackCopy(code) {
                let successful = false;

                // Phương pháp 1: Textarea
                try {
                    const textArea = document.createElement("textarea");
                    textArea.value = code;
                    textArea.style.position = "fixed";
                    textArea.style.left = "-9999px";
                    textArea.style.top = "-9999px";
                    textArea.style.opacity = "0";
                    textArea.setAttribute("readonly", "");

                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();
                    textArea.setSelectionRange(0, textArea.value.length);

                    successful = document.execCommand('copy');
                    document.body.removeChild(textArea);

                    if (successful) {
                        console.log("Textarea method success");
                        showCopySuccess(code);
                        return;
                    }
                } catch (err) {
                    console.log("Textarea method failed:", err);
                }

                // Phương pháp 2: Selection API
                try {
                    const range = document.createRange();
                    const span = document.createElement('span');
                    span.textContent = code;
                    span.style.position = 'fixed';
                    span.style.left = '-9999px';

                    document.body.appendChild(span);
                    range.selectNodeContents(span);

                    const selection = window.getSelection();
                    selection.removeAllRanges();
                    selection.addRange(range);

                    successful = document.execCommand('copy');
                    selection.removeAllRanges();
                    document.body.removeChild(span);

                    if (successful) {
                        console.log("Selection method success");
                        showCopySuccess(code);
                        return;
                    }
                } catch (err) {
                    console.log("Selection method failed:", err);
                }

                // Phương pháp cuối: Prompt user
                try {
                    if (window.prompt) {
                        const userCopy = window.prompt("Không thể tự động sao chép. Vui lòng sao chép mã bên dưới:", code);
                        if (userCopy !== null) {
                            showCopySuccess(code);
                        }
                    } else {
                        alert("Mã đơn hàng của bạn là: " + code);
                        showCopySuccess(code);
                    }
                } catch (err) {
                    console.error("All copy methods failed:", err);
                    alert("Không thể sao chép. Mã đơn hàng: " + code);
                }
            }

            // Animation khi hover vào order code
            if (orderCodeElement) {
                orderCodeElement.addEventListener("mouseenter", function() {
                    this.style.transform = "scale(1.05)";
                    this.style.transition = "transform 0.2s ease";
                });

                orderCodeElement.addEventListener("mouseleave", function() {
                    this.style.transform = "scale(1)";
                });
            }
        });
    </script>
}