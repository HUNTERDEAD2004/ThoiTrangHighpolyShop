@model AppData.ViewModels.NhanVienViewModel

@{
    ViewData["Title"] = "Thêm mới nhân viên";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/nv.css" />

<div class="container mt-5 mb-5">
    <h2 class="text-center mb-4 fw-bold">Thêm mới nhân viên</h2>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
    }

    <form asp-controller="NhanVien" asp-action="Create" method="post" class="shadow p-4 rounded bg-light">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Ten" class="form-label">Tên</label>
                <input asp-for="Ten" class="form-control" />
                <span asp-validation-for="Ten" class="text-danger small"></span>
            </div>

            @* <div class="col-md-6" > *@
            @*     <label asp-for="MaNhanVien" class="form-label">Mã nhân viên</label> *@
            @*     <input asp-for="MaNhanVien" class="form-control" readonly /> *@
            @* </div> *@
            <input type="hidden" asp-for="MaNhanVien" />

            <div class="col-md-6">
                <label class="form-label d-block">Giới tính</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="GioiTinh" value="1" checked />
                    <label class="form-check-label">Nam</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="GioiTinh" value="0" />
                    <label class="form-check-label">Nữ</label>
                </div>
            </div>

            <div class="col-md-6">
                <label asp-for="NgaySinh" class="form-label">Ngày sinh</label>
                <input asp-for="NgaySinh" type="date" class="form-control" />
                <span asp-validation-for="NgaySinh" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DiaChi" class="form-label">Địa chỉ</label>
                <input asp-for="DiaChi" class="form-control" />
                <span asp-validation-for="DiaChi" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div id="passwordErrorMessage" class="text-danger small"></div>
            </div>

            <div class="col-md-6">
                <label asp-for="SDT" class="form-label">Số điện thoại</label>
                <input asp-for="SDT" class="form-control" />
                <span asp-validation-for="SDT" class="text-danger small"></span>
                <div id="sdtErrorMessage" class="text-danger small"></div>
            </div>

            <input type="hidden" asp-for="TrangThai" value="1" />
            <input type="hidden" asp-for="IDVaiTro" value="952C1A5D-74FF-4DAF-BA88-135C5440809C" />

            <div class="col-12 text-end mt-4">
                <button type="submit" class="btn btn-dark text-white px-4 py-2 custom-hover">
                    <i class="fas fa-save me-2"></i> Lưu
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $("form").submit(function () {
            var isValid = true;

            // Reset error
            $("input").removeClass("is-invalid");
            $(".text-danger.small").text("");

            // 🔹 Tên (bắt buộc)
            var ten = $("input[name='Ten']").val().trim();
            if (ten === "") {
                $("input[name='Ten']").addClass("is-invalid");
                $("input[name='Ten']").after('<div class="text-danger small">Vui lòng nhập tên.</div>');
                isValid = false;
            }

            // 🔹 Mã nhân viên (readonly => bỏ qua nếu tự sinh)

           

            // 🔹 SDT (bắt buộc + đúng định dạng)
            var sdt = $("input[name='SDT']").val().trim();
            var sdtRegex = /^0\d{9}$/;
            if (sdt === "" || !(/^\d+$/.test(sdt)) || !sdtRegex.test(sdt)) {
                $("input[name='SDT']").addClass("is-invalid");
                $("input[name='SDT']").after('<div class="text-danger small">Số điện thoại không đúng định dạng.</div>');
                isValid = false;
            }

            // 🔹 Password (bắt buộc + >= 6 ký tự)
            var password = $("input[name='Password']").val().trim();
            if (password === "" || password.length < 6) {
                $("input[name='Password']").addClass("is-invalid");
                $("input[name='Password']").after('<div class="text-danger small">Mật khẩu phải từ 6 ký tự trở lên.</div>');
                isValid = false;
            }

            // 🔹 Ngày sinh (bắt buộc + >= 16 tuổi)
            var ngaySinhStr = $("input[name='NgaySinh']").val();
            if (!ngaySinhStr) {
                $("input[name='NgaySinh']").addClass("is-invalid");
                $("input[name='NgaySinh']").after('<div class="text-danger small">Vui lòng nhập ngày sinh.</div>');
                isValid = false;
            } else {
                var ngaySinh = new Date(ngaySinhStr);
                var today = new Date();
                var tuoi = today.getFullYear() - ngaySinh.getFullYear();
                var monthDiff = today.getMonth() - ngaySinh.getMonth();
                if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < ngaySinh.getDate())) {
                    tuoi--;
                }

                if (tuoi < 16) {
                    $("input[name='NgaySinh']").addClass("is-invalid");
                    $("input[name='NgaySinh']").after('<div class="text-danger small">Nhân viên phải từ 16 tuổi trở lên.</div>');
                    isValid = false;
                }
            }

            // 🔹 Địa chỉ (bắt buộc)
            var diaChi = $("input[name='DiaChi']").val().trim();
            if (diaChi === "") {
                $("input[name='DiaChi']").addClass("is-invalid");
                $("input[name='DiaChi']").after('<div class="text-danger small">Vui lòng nhập địa chỉ.</div>');
                isValid = false;
            }

            return isValid;
        });
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}

