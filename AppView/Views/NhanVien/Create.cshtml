@model AppData.ViewModels.NhanVienViewModel

@{
    ViewData["Title"] = "Thêm mới nhân viên";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/nv.css" />

<div class="container mt-5 mb-5">
    <h2 class="text-center mb-4 fw-bold">Thêm mới nhân viên</h2>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
    }

    <form asp-controller="NhanVien" asp-action="Create" method="post" class="shadow p-4 rounded bg-light">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Ten" class="form-label">Tên</label>
                <input asp-for="Ten" class="form-control" />
                <span asp-validation-for="Ten" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="MaNhanVien" class="form-label">Mã nhân viên</label>
                <input asp-for="MaNhanVien" class="form-control" />
                <span asp-validation-for="MaNhanVien" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label d-block">Giới tính</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="GioiTinh" value="1" checked />
                    <label class="form-check-label">Nam</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="GioiTinh" value="0" />
                    <label class="form-check-label">Nữ</label>
                </div>
            </div>

            <div class="col-md-6">
                <label asp-for="NgaySinh" class="form-label">Ngày sinh</label>
                <input asp-for="NgaySinh" type="date" class="form-control" />
                <span asp-validation-for="NgaySinh" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DiaChi" class="form-label">Địa chỉ</label>
                <input asp-for="DiaChi" class="form-control" />
                <span asp-validation-for="DiaChi" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div id="passwordErrorMessage" class="text-danger small"></div>
            </div>

            <div class="col-md-6">
                <label asp-for="SDT" class="form-label">Số điện thoại</label>
                <input asp-for="SDT" class="form-control" />
                <span asp-validation-for="SDT" class="text-danger small"></span>
                <div id="sdtErrorMessage" class="text-danger small"></div>
            </div>

            <input type="hidden" asp-for="TrangThai" value="1" />
            <input type="hidden" asp-for="IDVaiTro" value="952C1A5D-74FF-4DAF-BA88-135C5440809C" />

            <div class="col-12 text-end mt-4">
                <button type="submit" class="btn btn-success px-4">
                    <i class="fas fa-save me-2"></i> Lưu
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $("input[name='SDT']").on("input", function () {
            $(this).removeClass("is-invalid");
            $("#sdtErrorMessage").text("");
        });

        $("input[name='Password']").on("input", function () {
            $(this).removeClass("is-invalid");
            $("#passwordErrorMessage").text("");
        });

        $("form").submit(function () {
            var password = $("input[name='Password']").val().trim();
            if (password !== "" && password.length < 6) {
                $("input[name='Password']").addClass("is-invalid");
                $("#passwordErrorMessage").text("Mật khẩu phải từ 6 ký tự trở lên.");
                return false;
            }

            var sdt = $("input[name='SDT']").val().trim();
            var sdtRegex = /^0\d{9}$/;
            if (sdt !== "" && (!(/^\d+$/.test(sdt)) || !sdtRegex.test(sdt))) {
                $("input[name='SDT']").addClass("is-invalid");
                $("#sdtErrorMessage").text("Số điện thoại không đúng định dạng.");
                return false;
            }

            return true;
        });
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}
