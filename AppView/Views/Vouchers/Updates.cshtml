@model AppData.ViewModels.VoucherView

@{
    ViewData["Title"] = "CẬP NHẬT MÃ GIẢM GIÁ";
    Layout = "_LayoutForAdmin";
}

<div class="container mt-4">
    <h3 class="text-center mb-4 text-primary">CẬP NHẬT MÃ GIẢM GIÁ</h3>

    <form asp-action="Updates" method="post">
        @Html.AntiForgeryToken()

        <!-- Hiển thị lỗi -->
        <div asp-validation-summary="All" class="alert alert-danger"></div>

        <!-- Hidden Id -->
        <input type="hidden" asp-for="Id" />
        <div class="col-md-6">
            <label class="form-label">TÊN VOUCHER</label>
            <input asp-for="Ten" class="form-control" />
            <span asp-validation-for="Ten" class="text-danger"></span>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">MÃ GIẢM GIÁ</label>
                <input asp-for="MaVoucher" class="form-control" />
                <span asp-validation-for="MaVoucher" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">MÔ TẢ</label>
                <input asp-for="MoTa" class="form-control" />
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">GIÁ TRỊ GIẢM</label>
                <div class="input-group">
                    <input asp-for="GiaTri" class="form-control" type="number" min="0" />
                    <span class="input-group-text">
                        <input type="radio" asp-for="HinhThucGiamGia" value="1" class="form-check-input me-1" /> %
                        <input type="radio" asp-for="HinhThucGiamGia" value="0" class="form-check-input ms-3 me-1" /> VND
                    </span>
                </div>
                <span asp-validation-for="GiaTri" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">SỐ LƯỢNG</label>
                <input asp-for="SoLuong" class="form-control" type="number" min="0" />
                <span asp-validation-for="SoLuong" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">ĐƠN HÀNG TỐI THIỂU</label>
                <input asp-for="GiaTriToiThieu" class="form-control" type="number" min="0" />
                <span asp-validation-for="GiaTriToiThieu" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">GIẢM TỐI ĐA</label>
                <input asp-for="GiaTriToiDa" class="form-control" type="number" min="0" />
                <span asp-validation-for="GiaTriToiDa" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">NGÀY BẮT ĐẦU</label>
                <input asp-for="NgayApDung" type="datetime-local" class="form-control" />
                <span asp-validation-for="NgayApDung" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">NGÀY KẾT THÚC</label>
                <input asp-for="NgayKetThuc" type="datetime-local" class="form-control" />
                <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2">
            <a asp-action="GetAllVoucher" class="btn btn-secondary">QUAY LẠI</a>
            <button type="submit" class="btn btn-success">LƯU THAY ĐỔI</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(document).ready(function () {
        @if (TempData["Success"] != null)
        {
            <text>
                    showSuccessAlert('@Html.Raw(TempData["Success"])');
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
                    showErrorAlert('@Html.Raw(TempData["Error"])');
            </text>
        }
                        });

        function showSuccessAlert(message) {
            const alertHtml = `
                                <div class="alert alert-success alert-dismissible fade show position-fixed"
                                     style="top: 20px; right: 20px; z-index: 1050; min-width: 300px;" role="alert">
                                    <i class="fa fa-check-circle me-2"></i>
                                    ${message}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            `;
            $('body').append(alertHtml);
            setTimeout(function () {
                $('.alert-success').fadeOut(function () { $(this).remove(); });
            }, 5000);
        }

        function showErrorAlert(message) {
            const alertHtml = `
                                <div class="alert alert-danger alert-dismissible fade show position-fixed"
                                     style="top: 20px; right: 20px; z-index: 1050; min-width: 300px;" role="alert">
                                    <i class="fa fa-exclamation-circle me-2"></i>
                                    ${message}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            `;
            $('body').append(alertHtml);
            setTimeout(function () {
                $('.alert-danger').fadeOut(function () { $(this).remove(); });
            }, 7000);
        }
    </script>
}
