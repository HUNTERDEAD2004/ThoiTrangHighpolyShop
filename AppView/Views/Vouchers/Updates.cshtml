@model AppData.ViewModels.VoucherView

@{
    ViewData["Title"] = "CẬP NHẬT MÃ GIẢM GIÁ";
    Layout = "_LayoutForAdmin";
}

<div class="container mt-4">
    <h3 class="text-center mb-4 text-primary">CẬP NHẬT MÃ GIẢM GIÁ</h3>

    <form asp-action="Updates" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <!-- Hidden Id -->
        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">MÃ GIẢM GIÁ</label>
                <input asp-for="MaVoucher" class="form-control" />
                <span asp-validation-for="MaVoucher" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">MÔ TẢ</label>
                <input asp-for="MoTa" class="form-control" />
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">GIÁ TRỊ GIẢM</label>
                <div class="input-group">
                    <input asp-for="GiaTri" class="form-control" type="number" min="0" />
                    <div class="input-group-text">
                        <div class="form-check me-2">
                            <input class="form-check-input" type="radio" asp-for="HinhThucGiamGia" value="1" />
                            <label class="form-check-label">%</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="HinhThucGiamGia" value="0" />
                            <label class="form-check-label">VND</label>
                        </div>
                    </div>
                </div>
                <span asp-validation-for="GiaTri" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">SỐ LƯỢNG</label>
                <input asp-for="SoLuong" class="form-control" type="number" min="0" />
                <span asp-validation-for="SoLuong" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">ĐƠN HÀNG TỐI THIỂU</label>
                <input asp-for="GiaTriToiThieu" class="form-control" type="number" min="0" />
                <span asp-validation-for="GiaTriToiThieu" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">GIẢM TỐI ĐA</label>
                <input asp-for="GiaTriToiDa" class="form-control" type="number" min="0" />
                <span asp-validation-for="GiaTriToiDa" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">NGÀY BẮT ĐẦU</label>
                <input asp-for="NgayApDung" type="datetime-local"
                       value="@Model.NgayApDung.ToString("yyyy-MM-ddTHH:mm")"
                       class="form-control" />
                <span asp-validation-for="NgayApDung" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">NGÀY KẾT THÚC</label>
                <input asp-for="NgayKetThuc" type="datetime-local"
                       value="@Model.NgayKetThuc.ToString("yyyy-MM-ddTHH:mm")"
                       class="form-control" />
                <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2">
            <a asp-action="GetAllVoucher" class="btn btn-secondary">QUAY LẠI</a>
            <button type="submit" class="btn btn-success">LƯU THAY ĐỔI</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
