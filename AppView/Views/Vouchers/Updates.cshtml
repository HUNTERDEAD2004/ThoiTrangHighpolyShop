@model AppData.ViewModels.VoucherView

@{
    ViewData["Title"] = "Cập nhật Voucher";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
}

<h1 class="mb-4">Cập nhật phiếu giảm giá</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Updates">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- ID -->
            <div class="form-group" hidden>
                <label class="control-label">ID</label>
                <input asp-for="Id" class="form-control" />
            </div>

            <!-- Mã Voucher -->
            <div class="form-group" hidden>
                <label class="control-label">Mã Voucher</label>
                <input asp-for="Ten" class="form-control" />
            </div>

            <!-- Hình thức giảm giá -->
           

            <!-- Giá trị giảm -->
            <div class="form-group mb-3">
                <label class="control-label">Giá trị giảm</label>
                <input asp-for="GiaTri" class="form-control" type="number" min="0" />
                <span class="text-danger">@ViewData["GiaTri"]</span>
            </div>

            <!-- Giảm tối đa -->
            <div class="form-group mb-3">
                <label class="control-label">Giảm tối đa</label>
                <input asp-for="GiaTriToiDa" class="form-control" type="number" min="0" />
                <span class="text-danger">@ViewData["GiaTriToiDa"]</span>
            </div>

            <!-- Đơn hàng tối thiểu -->
            <div class="form-group mb-3">
                <label class="control-label">Đơn hàng tối thiểu</label>
                <input asp-for="GiaTriToiThieu" class="form-control" type="number" min="0" />
                <span class="text-danger">@ViewData["GiaTriToiThieu"]</span>
            </div>

            <!-- Ngày áp dụng -->
            <div class="form-group mb-3">
                <label class="control-label">Ngày áp dụng</label>
                <input asp-for="NgayApDung" class="form-control" type="date" />
                <span class="text-danger">@ViewData["NgayApDung"]</span>
            </div>

            <!-- Ngày kết thúc -->
            <div class="form-group mb-3">
                <label class="control-label">Ngày kết thúc</label>
                <input asp-for="NgayKetThuc" class="form-control" type="date" />
                <span class="text-danger">@ViewData["NgayKetThuc"]</span>
                <span class="text-danger">@ViewData["Ngay"]</span>
            </div>

            <!-- Số lượng -->
            <div class="form-group mb-3">
                <label class="control-label">Số lượng</label>
                <input asp-for="SoLuong" class="form-control" type="number" min="0" />
                <span class="text-danger">@ViewData["SoLuong"]</span>
            </div>

            <!-- Mô tả -->
            <div class="form-group mb-3">
                <label class="control-label">Mô tả</label>
                <input asp-for="MoTa" class="form-control" />
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <!-- Submit -->
            <div class="form-group mt-4">
                <input type="submit" value="Lưu thay đổi" class="btn btn-success" />
                <a asp-action="GetAllVoucher" class="btn btn-secondary ms-2">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
