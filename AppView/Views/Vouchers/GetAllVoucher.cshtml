@model AppView.PhanTrang.PhanTrangVouchers
@{
    ViewData["Title"] = "Quản lý Voucher";
    int stt = 1;
    var now = DateTime.Now;
}

<h2 class="text-center text-uppercase mt-4 mb-4 text-primary font-weight-bold">Quản lý Voucher</h2>
<div class="row g-3 align-items-end mb-3">
    <form asp-action="FilterVouchers" method="get" class="col-10 row g-3">
        <div class="col-md-3">
            <label class="form-label fw-semibold">Tối thiểu:</label>
            <input type="number" name="MinValue" class="form-control form-control-sm" placeholder="Nhập giảm giá tối thiểu" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold">Tối đa:</label>
            <input type="number" name="MaxValue" class="form-control form-control-sm" placeholder="Nhập giảm giá tối đa" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold">Ngày bắt đầu:</label>
            <input type="date" name="StartDate" class="form-control form-control-sm" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="w-100">
                <label class="form-label fw-semibold">Ngày kết thúc:</label>
                <div class="input-group">
                    <input type="date" name="EndDate" class="form-control form-control-sm" />
                    <button type="submit" class="btn btn-dark btn-sm">
                        <i class="fa fa-filter"></i> Lọc
                    </button>
                </div>
            </div>
        </div>
    </form>

    <!-- Nút Thêm -->
    <div class="col-2 text-end">
        <a class="btn btn-dark btn-sm" asp-action="Create">
            <i class="fa fa-plus"></i> Thêm mới
        </a>
    </div>
</div>

<!-- Tiêu đề + Tìm kiếm cùng dòng -->
<div class="row align-items-center mb-3">
    <!-- Tiêu đề -->
    <div class="col-md-6 d-flex align-items-center">
        <h5 class="fw-bold text-dark mb-0">
            <i class="fa fa-tags text-primary me-2"></i> Danh sách phiếu giảm giá
        </h5>
    </div>

    <!-- Form tìm kiếm bên phải -->
    <div class="col-md-6 d-flex justify-content-end">
        <form asp-action="TimKiemTenVC" asp-controller="Vouchers" method="get" class="input-group input-group-sm w-auto">
            <input type="text" name="Ten" class="form-control" placeholder="Tìm mã Voucher">
            <button type="submit" class="btn btn-outline-primary">
                <i class="fa fa-search"></i>
            </button>
        </form>
    </div>
</div>

    <!-- Nút thêm mới -->
   

<div class="table-responsive">
    <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-dark text-center">
            <tr>
                <th>STT</th>
                <th>Mã Voucher</th>
                <th>Hình thức</th>
                <th>Giá trị Giảm</th>
                <th>Đơn hàng tối thiểu</th>
                <th>Giảm tối đa</th>
            
                <th>Ngày áp dụng</th>
                <th>Ngày kết thúc</th>
                <th>Số lượng</th>
                <th>Mô tả</th>
                <th>Trạng thái</th>
                <th>Tình trạng</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.listvouchers
            .Where(x => x.GiaTri <= x.GiaTriToiDa
            && x.GiaTriToiThieu >= x.GiaTri
            && x.GiaTriToiThieu > x.GiaTriToiDa))
            {
                <tr>
                    <td>@(stt++)</td>
                    <td><strong>@item.Ten</strong></td>
                    <td>@(item.HinhThucGiamGia == 0 ? "Tiền mặt" : "Phần trăm")</td>
                    <td>
                        @(item.HinhThucGiamGia == 0
                            ? item.GiaTri.ToString("n0") + " VND"
                            : item.GiaTri + " %")
                    </td>
                    <td>@item.GiaTriToiThieu.ToString("n0") VND</td>
                    <td>@item.GiaTriToiDa.ToString("n0") VND</td>
                    <td>@item.NgayApDung.ToString("dd/MM/yyyy")</td>
                    <td>@item.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                    <td>@item.SoLuong</td>
                    <td>@item.MoTa</td>

                   

                    @* Trạng thái (không lưu DB) - có badge màu khi Hoạt động *@
                    <td>
                        @* Trạng thái: hoạt động khi Sắp diễn ra hoặc Đang diễn ra *@
                        @{
                            string trangThaiText = "";
                            string trangThaiColor = "";

                            if (item.NgayKetThuc < now)
                            {
                                trangThaiText = "Không hoạt động";
                                trangThaiColor = "badge bg-primary";
                            }
                            else if (now >= item.NgayApDung && now <= item.NgayKetThuc)
                            {
                                trangThaiText = "Hoạt động";
                                trangThaiColor = "badge bg-primary";
                            }
                            else if (now < item.NgayApDung)
                            {
                                trangThaiText = "Hoạt động";
                                trangThaiColor = "badge bg-primary";
                            }
                            else
                            {
                                trangThaiText = "Không xác định";
                                trangThaiColor = "badge bg-primary";
                            }
                        }
                        <span class="badge bg-@trangThaiColor">@trangThaiText</span>
                    </td>

                    <td>
                        @{
                            string tinhTrangText = "";
                            string tinhTrangColor = "";

                            if (item.NgayKetThuc < now)
                            {
                                tinhTrangText = "Đã kết thúc";
                                tinhTrangColor = "badge bg-primary";
                            }
                            else if (now >= item.NgayApDung && now <= item.NgayKetThuc)
                            {
                                tinhTrangText = "Đang diễn ra";
                                tinhTrangColor = "badge bg-primary";
                            }
                            else if (now < item.NgayApDung)
                            {
                                tinhTrangText = "Sắp diễn ra";
                                tinhTrangColor = "badge bg-primary ";
                            }
                            else
                            {
                                tinhTrangText = "Không xác định";
                                tinhTrangColor = "badge bg-primary";
                            }
                        }

                        <span class="badge bg-@tinhTrangColor">@tinhTrangText</span>
                    </td>

                    <td>
                         <div class="btn-group" role="group">
                            <!-- Chỉnh sửa -->
                            <a class="btn btn-warning btn-sm" asp-action="Updates" asp-route-id="@item.Id" title="Chỉnh sửa">
                                <i class="fa fa-edit"></i>
                            </a>
        <!-- Xem chi tiết -->
                            <a class="btn btn-dark btn-sm" asp-action="Details" asp-route-id="@item.Id" title="Chi tiết">
            <i class="fa fa-eye"></i>
        </a>

       

        <!-- Xóa -->
        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa?')" style="display:inline;">
            <button type="submit" class="btn btn-sm btn-danger" title="Xóa">
                <i class="fa fa-trash"></i>
            </button>
        </form>
    </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav aria-label="Page navigation" class="mt-4">
    <ul class="pagination justify-content-center">
        @for (int i = 1; i <= Model.PagingInfo.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PagingInfo.CurrentPage ? "active" : "")">
                <a class="page-link" href="/Vouchers/GetAllVoucher?ProductPage=@i">@i</a>
            </li>
        }
    </ul>
</nav>
