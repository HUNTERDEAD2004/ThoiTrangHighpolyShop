@model IEnumerable<AppData.ViewModels.SanPham.UploadAnhViewModel>
@{
    ViewData["Title"] = "Quản lý ảnh theo biến thể";
    string? id = ViewData["IDSanPham"] as string;
}
<h2>Quản lý ảnh theo màu sản phẩm</h2>

<table class="table" style="width:500px">
    <thead>
        <tr>
            <th>Ảnh</th>
            <th>Tên màu</th>
            <th>Mã màu</th>
            <th>Thêm</th>       <!-- Thêm -->
            <th>Cập nhật</th>   <!-- Sửa -->
            <th>Xoá</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.DuongDan))
                    {
                        <img src="@item.DuongDan" style="width:70px;height:80px" />
                    }
                    else
                    {
                        <span style="color:red;">Chưa có ảnh</span>
                    }


                </td>
                <td>@item.TenMau</td>
                <td>
                    <input type="color" value="@item.MaMau" style="border:none;width:27px;height:25px" disabled />
                </td>
                <!-- ✅ Nút thêm -->
                <td>
                    <label for="add_@item.IDChiTietSanPham" class="btn btn-primary">Thêm</label><br />
                    <input id="add_@item.IDChiTietSanPham" type="file" multiple style="display: none;"
                           onchange="AddImage(event, '@item.IDChiTietSanPham')" />
                </td>
                <!-- ✅ Nút sửa -->
                <td>
                    <label for="update_@item.IDChiTietSanPham" class="btn btn-success">Sửa</label><br />
                    <input id="update_@item.IDChiTietSanPham" type="file" style="display: none;"
                           onchange="UpdateImage(event,'@item.IDChiTietSanPham','@item.DuongDan')" />
                </td>
                <!-- ✅ Nút xoá -->
                <td>
                    <a class="btn btn-danger"
                       asp-action="DeleteImage"
                       asp-route-id="@item.IDAnh"
                       asp-route-idSanPham="@id"
                       asp-route-duongDan="@item.DuongDan">Xoá</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
        function AddImage(event, idChiTiet) {
        const files = event.target.files;
        const formData = new FormData();

        for (let i = 0; i < files.length; i++) {
            if (!files[i].type.startsWith("image/")) {
                alert("Chỉ chấp nhận file ảnh!");
                return;
            }

            // Phải đặt tên field theo đúng index của model
            formData.append(`[${i}].Image`, files[i]);
            formData.append(`[${i}].IDChiTietSanPham`, idChiTiet);
        }

        fetch("/Admin/AddImage", {
            method: "POST",
            body: formData
        }).then(res => {
            if (res.ok) location.reload();
            else alert("Thêm ảnh thất bại.");
        }).catch(err => {
            alert("Lỗi hệ thống!");
            console.error(err);
        });
    }

    function UpdateImage(event, id, duongdan) {
        var file = event.target.files[0]; // Sửa lại từ 'value' thành 'file'

        if (!file.type.startsWith("image/")) {
            alert("Chỉ chấp nhận file ảnh!");
            return;
        }

        var formData = new FormData();
        formData.append("file", file);
        formData.append("id", id);
        formData.append("duongDan", duongdan);
        formData.append("idSanPham", '@id');

        fetch("/Admin/UpdateImage", {
            method: 'POST',
            body: formData
        }).then(res => {
            if (res.ok) location.reload();
            else alert("Cập nhật ảnh thất bại.");
        });
    }

</script>

