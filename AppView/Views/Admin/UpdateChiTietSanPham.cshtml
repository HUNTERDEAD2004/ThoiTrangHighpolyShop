@model AppData.ViewModels.SanPham.ChiTietSanPhamUpdateRequest

@{
    ViewData["Title"] = "UpdateBiếnThểSảnPhẩm";
}

<h1>Cập nhật biến thể sản phẩm</h1>

<form asp-action="UpdateChiTietSanPham" id="myForm">
    <table class="table">
        <thead>
            <tr>
                <th>Tên màu sắc</th>
                <th>Mã màu sắc</th>
                <th>Kích cỡ</th>
                <th>Số lượng</th>
                <th>Giá bán</th>
                <th>Mặc định</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.ChiTietSanPhams.Count; i++)
            {
                <tr>
                    <td>
                        <input type="text" asp-for="ChiTietSanPhams[i].TenMauSac" style="border:none;background-color:white" readonly>
                    </td>
                    <td>
                        <input type="color" value="@Model.ChiTietSanPhams[i].MaMau" style="border:none;width:27px;height:25px" readonly disabled>
                    </td>
                    <td>
                        <input type="text" asp-for="ChiTietSanPhams[i].TenKichCo" style="border:none;background-color:white" readonly>
                    </td>
                    <td>
                        <input type="number" asp-for="ChiTietSanPhams[i].SoLuong" class="form-control" />
                    </td>
                    <td>
                        <input type="number" asp-for="ChiTietSanPhams[i].GiaBan" class="form-control" />
                    </td>
                    <td>
                        <input type="radio" asp-for="TrangThai" value="@Model.ChiTietSanPhams[i].IDChiTietSanPham" />
                    </td>

                    <!-- Hidden input để đảm bảo binding đúng -->
                    <td><input type="hidden" asp-for="ChiTietSanPhams[i].IDChiTietSanPham" /></td>
                    <td><input type="hidden" asp-for="ChiTietSanPhams[i].IDMauSac" /></td>
                    <td><input type="hidden" asp-for="ChiTietSanPhams[i].IDKichCo" /></td>
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-primary" type="submit">Lưu</button>
</form>

<script src="/js/jquery-3.3.1.min.js"></script>
<script>
    $(".btn").on("click", function (event) {
        event.preventDefault();
        let valid = true;

        $("input[type='number']").each(function () {
            if (parseFloat($(this).val()) < 0) {
                alert("Giá bán và số lượng không được âm");
                valid = false;
                return false;
            }
        });

        if (!valid) return;

        if ($("input[name='TrangThai']:checked").length === 0) {
        alert("Bạn chưa chọn biến thể mặc định.");
        return;
        }

        $("#myForm").submit();
    });
</script>
