@model AppData.ViewModels.SanPham.SanPhamRequest

<h1 class="mb-4 text-center">Thêm sản phẩm</h1>
<hr />
<form asp-action="AddSanPham" enctype="multipart/form-data" id="formAddSanPham" onsubmit="return disableSubmit(this)">
    <div class="row">
        <!-- Cột trái -->
        <div class="col-md-6">
            <!-- Tên -->
            <div class="form-group mb-3">
                <label asp-for="Ten" class="control-label fw-bold"></label>
                <input asp-for="Ten" class="form-control" autocomplete="off" />
                <span asp-validation-for="Ten" class="text-danger"></span>
            </div>

            <!-- Mô tả -->
            <div class="form-group mb-3">
                <label asp-for="MoTa" class="control-label fw-bold"></label>
                <input asp-for="MoTa" class="form-control" autocomplete="off" />
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <!-- CHẤT LIỆU -->
            <div class="form-group mb-3">
                <label for="ChatLieuID" class="control-label fw-bold">Chất liệu</label>
                <div class="d-flex gap-2">
                    <select name="IDChatLieu" id="ChatLieuID" class="form-select flex-grow-1"></select>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="taoMoiChatLieu()">➕</button>
                </div>
            </div>

            <!-- LOẠI SẢN PHẨM CHA & CON -->
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Loại sản phẩm</label>
                <div class="d-flex gap-2">
                    <select name="IDLoaiSPCha" id="LoaiSPChaID" class="form-select" onchange="loadLoaiSPCon()"></select>
                    <select name="IDLoaiSP" id="LoaiSPConID" class="form-select"></select>
                </div>
            </div>

            <!-- Ảnh đại diện -->
            <div class="form-group mb-4">
                <label class="control-label fw-bold">Ảnh đại diện</label>
                <input type="file" name="file" class="form-control" accept="image/*" />
                <span asp-validation-for="AnhDaiDien" class="text-danger"></span>
            </div>
        </div>

        <!-- Cột phải -->
        <div class="col-md-6">
            <!-- MÀU SẮC -->
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Màu sắc</label>
                <div id="lstMauSac" class="d-flex flex-wrap gap-2">
                    <!-- JS sẽ render tại đây -->
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="themBienTheMauSac()"> Thêm biến thể màu</button>
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="taoMoiMauSac()"> Thêm màu</button>
                </div>
            </div>

            <!-- KÍCH CỠ -->
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Kích cỡ</label>
                <div id="lstKichCo" class="d-flex flex-wrap gap-2">
                    <!-- JS sẽ render tại đây -->
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="themBienTheKichCo()"> Thêm biến thể kích cỡ</button>
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="taoMoiKichCo()"> Thêm kích cỡ</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Nút submit -->
    <div class="form-group text-center mt-4">
        <input type="submit" value=" Thêm sản phẩm" class="btn btn-secondary px-4 py-2" />
    </div>
</form>

<style>
    .form-group {
        margin-bottom: 16px;
    }

    .form-control, .form-select {
        height: 42px;
    }

    .btn-secondary {
        background: #6c757d !important;
        color: #fff !important;
        border: none;
    }

        .btn-secondary:hover {
            background: #5a6268 !important;
        }

    .gap-2 {
        gap: 8px;
    }

    #lstMauSac > div,
    #lstKichCo > div {
        width: 48%;
    }
</style>

<script src="~/js/jquery-3.3.1.min.js"></script>
<script>
    let countChatLieu = 0, countKichCo = 0, countMauSac = 0;
    let lstMauSac = [];
    let lstChatLieu = [];
    let lstKichCo = []; 
    let lstLoaiSP = [];

    $(document).ready(function () {
        // Gọi dữ liệu chất liệu
        $.get("/Admin/GetAllChatLieu", function (res) {
        const select = $("#ChatLieuID");
        select.empty().append('<option value="">-- Chọn chất liệu --</option>');
        res.forEach(x => {
            select.append(`<option value="${x.id}">${x.ten}</option>`);
        });
        });

        // Gọi dữ liệu kích cỡ
        $.get("/Admin/GetAllKichCo", function (res) {
            lstKichCo = res.map(x => ({ id: x.id, ten: x.ten }));
            themBienTheKichCo();
        });

        // Gọi dữ liệu màu sắc
        $.get("/Admin/GetAllMauSac", function (res) {
        if (!res || res.length === 0) return;

        lstMauSac = res.map(x => ({ id: x.id, ten: x.ten, ma: x.ma?.toLowerCase() || "#000" }));
        countMauSac = 0;
        $("#lstMauSac").empty();
        themBienTheMauSac();
        });

        // Gọi dữ liệu loại sản phẩm cha
        $.get("/Admin/GetLoaiSPCha", function (res) {
        const cha = $("#LoaiSPChaID");
        cha.empty().append('<option value="">-- Chọn loại cha --</option>');
        res.forEach(x => {
        cha.append(`<option value="${x.id}">${x.ten}</option>`);
        });
        });
     });

    // --- Tạo mới Chất liệu ---
    function taoMoiChatLieu() {
        const ten = prompt("Nhập tên chất liệu mới:");
        if (!ten) return;

        $.post("/Admin/TaoChatLieuMoiTuSanPham" + { ten: ten }, function (res) {
            if (res.success) {
                alert("Thêm thành công!");
                $.get("/Admin/GetAllChatLieu", function (data) {
                    const select = $("#ChatLieuID");
                    select.empty().append('<option value="">-- Chọn chất liệu --</option>');
                    data.forEach(x => {
                        select.append(`<option value="${x.id}" ${x.ten === ten ? 'selected' : ''}>${x.ten}</option>`);
                    });
                });
            } else {
                alert("Thêm thất bại!");
            }
        });
    }

    // --- Tạo mới Kích cỡ ---
    function taoMoiKichCo() {
        const ten = prompt("Nhập kích cỡ mới:");
        if (!ten) return;

        $.post("/Admin/TaoKichCoTuSanPhamAsync", { ten: ten }, function (res) {
            if (res.success) {
                alert("Đã thêm!");
                $.get("/Admin/GetAllKichCo", function (data) {
                    lstKichCo = data;
                    $("#lstKichCo").empty();
                    countKichCo = 0;
                    themBienTheKichCo();
                });
            }
        });
    }

    // --- Tạo mới Màu sắc ---
    function taoMoiMauSac() {
        const ten = prompt("Tên màu:");
        const ma = prompt("Mã hex màu (#xxxxxx):");
        if (!ten || !ma) return;

        $.ajax({
            url: "/Admin/TaoMauMoiTuSanPham",
            type: "POST",
            data: { ten: ten, ma: ma, trangthai: 1 }, // ví dụ trạng thái mặc định là 1 (đang dùng)
            success: function (res) {
                alert("Thêm thành công!");
                $.get("/Admin/GetAllMauSac", function (data) {
                    lstMauSac = data.map(x => ({ id: x.id, ten: x.ten, ma: x.ma.toLowerCase() }));
                    $("#lstMauSac").empty();
                    countMauSac = 0;
                    themBienTheMauSac();
                });
            },
            error: function () {
                alert("Thêm thất bại!");
            }
        });
    }


    // --- Tạo mới Loại sản phẩm ---
    function taoMoiLoaiSPCha() {
        const ten = prompt("Nhập tên loại sản phẩm cha:");
        if (!ten) return;

        $.post("/LoaiSP/save", { ten: ten }, function (res) {
            if (res.success) {
                $.get("/Admin/GetLoaiSPCha", function (data) {
                    const select = $("#LoaiSPChaID");
                    select.empty().append('<option value="">-- Chọn loại cha --</option>');
                    data.forEach(x => {
                        select.append(`<option value="${x.id}" ${x.ten === ten ? 'selected' : ''}>${x.ten}</option>`);
                    });
                    loadLoaiSPCon();
                });
            }
        });
    }

    // --- Tạo mới Loại sản phẩm ---

    // --- Kích cỡ ---
    function themBienTheKichCo() {
        const id = countKichCo;
        const html = `
        <div class="d-flex align-items-center gap-2" id="kichco${id}">
            <select name="IDKichCos[${id}]" class="form-select" style="width: 250px;">
                ${lstKichCo.map(x => `<option value="${x.id}">${x.ten}</option>`).join("")}
            </select>
            <button type="button" class="btn btn-danger btn-sm" onclick="xoaKichCo(${id})">-</button>
        </div>`;
    $("#lstKichCo").append(html);
    countKichCo++;
    }

    function xoaKichCo(id) {
        $(`#kichco${id}`).remove();
    }

    // --- Màu sắc ---
    function themBienTheMauSac() {
        const id = countMauSac;

        const html = `
        <div class="d-flex align-items-center gap-2" id="mau${id}">
            <select id="selectMau${id}" name="IDMauSacs[${id}]" class="form-select" style="width: 250px;" onchange="changeMauSac(${id})">
                ${lstMauSac.map(x => `<option value="${x.id}">${x.ten}</option>`).join('')}
            </select>
            <input name="MauSacs[${id}].Ma" type="color" class="form-control" style="width: 60px;" id="maMau${id}" value="${lstMauSac[0]?.ma || '#000'}" />
            <button type="button" class="btn btn-danger btn-sm" onclick="xoaMau(${id})">-</button>
        </div>`;

        $("#lstMauSac").append(html);
        countMauSac++;
    }

    function changeMauSac(id) {
        const selectedID = document.getElementById(`selectMau${id}`).value;
        const mau = lstMauSac.find(x => x.id == selectedID);
        if (mau) {
            document.getElementById(`maMau${id}`).value = mau.ma;
        }
    }

    function xoaMau(id) {
        $(`#mau${id}`).remove();
    }

    // --- LOẠI SẢN PHẨM ---
   function loadLoaiSPCon() {
    const idCha = $("#LoaiSPChaID").val();
    console.log("ID loại cha đã chọn:", idCha);

    const con = $("#LoaiSPConID");
    con.empty().append('<option value="">-- Chọn loại con --</option>');

    if (!idCha) return;

    $.get("/LoaiSP/GetLoaiSPCon", { idLoaiSPCha: idCha }, function (res) {
        console.log("Loại con trả về:", res);
        res.forEach(x => {
            con.append(`<option value="${x.id}">${x.ten}</option>`);
        });
    }).fail(function (xhr, status, err) {
        console.error("Gọi API lỗi:", status, err);
    });
}


    function disableSubmit(form) {
        const btn = form.querySelector('input[type="submit"], button[type="submit"]');
        if (btn) {
            btn.disabled = true;
            btn.value = "Đang xử lý...";
        }
        return true;
    }

</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}