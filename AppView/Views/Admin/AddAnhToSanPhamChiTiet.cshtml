@using AppData.ViewModels.SanPham
@model List<UploadAnhViewModel>

<h2>Thêm ảnh cho từng màu</h2>

<form asp-action="AddAnhToSanPhamChiTiet" method="post" enctype="multipart/form-data">
    <table class="table">
        <thead>
            <tr>
                <th>Màu</th>
                <th>Ảnh</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>
                        @Model[i].TenMau
                        <input type="hidden" name="IDChiTietSanPhams" value="@Model[i].IDChiTietSanPham" />
                    </td>
                    <td>
                        <input type="file" name="Images" class="form-control" />
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <button type="submit" class="btn btn-success">Lưu ảnh</button>
</form>
