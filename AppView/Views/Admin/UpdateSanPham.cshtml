@model AppData.ViewModels.SanPham.SanPhamRequest

<h1>Cập nhật sản phẩm</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="UpdateSanPham" enctype="multipart/form-data" id="formUpdateSanPham" onsubmit="return disableSubmit(this)">
            <!-- Tên -->
            <div class="form-group">
                <label asp-for="Ten" class="control-label"></label>
                <input asp-for="Ten" class="form-control" autocomplete="off" />
                <span asp-validation-for="Ten" class="text-danger"></span>
            </div>

            <!-- Mô tả -->
            <div class="form-group">
                <label asp-for="MoTa" class="control-label"></label>
                <input asp-for="MoTa" class="form-control" autocomplete="off" />
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <!-- Chất liệu -->
            <div class="form-group">
                <label for="ChatLieuID" class="control-label">Chất liệu</label>
                <select name="IDChatLieu" id="ChatLieuID" class="form-select" style="width: 250px;"></select>
                <button type="button" class="btn btn-success btn-sm" onclick="taoMoiChatLieu()">➕</button>
            </div>

            <!-- Loại sản phẩm -->
            <div class="form-group">
                <label class="control-label">Loại sản phẩm</label>
                <div class="d-flex gap-2">
                    <select name="IDLoaiSPCha" id="LoaiSPChaID" class="form-select" style="width: 200px;" onchange="loadLoaiSPCon()"></select>
                    <select name="IDLoaiSPCon" id="LoaiSPConID" class="form-select" style="width: 200px;"></select>
                </div>
            </div>

            <!-- Ảnh đại diện -->
            <div class="form-group">
                <label class="control-label">Ảnh đại diện (chọn nếu muốn thay đổi)</label>
                <input type="file" name="file" class="form-control" accept="image/*" />
                <span asp-validation-for="AnhDaiDien" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Cập nhật" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<script>
    $(document).ready(function () {
        // Load chất liệu
        $.get("/Admin/GetAllChatLieu", function (res) {
            const select = $("#ChatLieuID");
            select.empty().append('<option value="">-- Chọn chất liệu --</option>');
            res.forEach(x => {
                const selected = "@Model.IDChatLieu" === x.id ? "selected" : "";
                select.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
            });
        });

        // Load loại sản phẩm cha
        $.get("/Admin/GetLoaiSPCha", function (res) {
            const cha = $("#LoaiSPChaID");
            cha.empty().append('<option value="">-- Chọn loại cha --</option>');
            res.forEach(x => {
                const selected = "@Model.IDLoaiSPCha" === x.id ? "selected" : "";
                cha.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
            });

            if ("@Model.IDLoaiSPCha") {
                loadLoaiSPCon("@Model.IDLoaiSPCon");
            }
        });
    });

    function loadLoaiSPCon(selectedConID = "") {
        const idCha = $("#LoaiSPChaID").val();
        const con = $("#LoaiSPConID");
        con.empty().append('<option value="">-- Chọn loại con --</option>');

        if (!idCha) return;

        $.get("/Admin/GetLoaiSPCon", { idLoaiSPCha: idCha }, function (res) {
            res.forEach(x => {
                const selected = selectedConID == x.id ? "selected" : "";
                con.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
            });
        });
    }

    function taoMoiChatLieu() {
        const ten = prompt("Nhập tên chất liệu mới:");
        if (!ten) return;

        $.post("/Admin/TaoChatLieuMoiTuSanPham", { ten: ten }, function (res) {
            if (res.success) {
                alert("Đã thêm!");
                $.get("/Admin/GetAllChatLieu", function (data) {
                    const select = $("#ChatLieuID");
                    select.empty().append('<option value="">-- Chọn chất liệu --</option>');
                    data.forEach(x => {
                        const selected = x.ten === ten ? "selected" : "";
                        select.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
                    });
                });
            }
        });
    }

    function disableSubmit(form) {
        const btn = form.querySelector('input[type="submit"], button[type="submit"]');
        if (btn) {
            btn.disabled = true;
            btn.value = "Đang xử lý...";
        }
        return true;
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
