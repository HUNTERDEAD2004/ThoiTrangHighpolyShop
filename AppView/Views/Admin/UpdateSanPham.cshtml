@model AppData.ViewModels.SanPham.SanPhamUpdateRequest

<h1>Cập nhật sản phẩm</h1>

<hr />
<div class="row">
	<div class="col-md-4">
		<form asp-action="UpdateSanPham" method="post" id="formUpdateSanPham" onsubmit="return disableSubmit(this)">

			<!--ID ẩn để cập nhật đúng sản phẩm -->
			<input type="hidden" asp-for="ID" />

			<!-- Tên -->
			<div class="form-group">
				<label asp-for="Ten" class="control-label"></label>
				<input asp-for="Ten" class="form-control" autocomplete="off" />
				<span asp-validation-for="Ten" class="text-danger"></span>
			</div>

			<!-- Mô tả -->
			<div class="form-group">
				<label asp-for="MoTa" class="control-label"></label>
				<input asp-for="MoTa" class="form-control" autocomplete="off" />
				<span asp-validation-for="MoTa" class="text-danger"></span>
			</div>

			<!-- Chất liệu -->
			<div class="form-group">
				<label for="ChatLieuID" class="control-label">Chất liệu</label>
				<select id="ChatLieuID" asp-for="IDChatLieu" asp-items="ViewBag.ChatLieus" class="form-control"></select>
				<button type="button" class="btn btn-success btn-sm" onclick="taoMoiChatLieu()">➕</button>
			</div>

			<!-- Loại sản phẩm -->
			<div class="form-group">
				<label class="control-label">Loại sản phẩm</label>
				<div class="d-flex gap-2">
					<select id="LoaiSPID" asp-for="IDLoaiSP" asp-items="ViewBag.LoaiSPs" class="form-control"></select>
					<button type="button" class="btn btn-success btn-sm" onclick="taoMoiLoaiSP()">➕</button>
				</div>
			</div>

			<!-- Hiển thị ảnh hiện tại -->
			<div class="form-group">
				<label class="control-label">Ảnh đại diện hiện tại</label><br />
				@if (!string.IsNullOrEmpty(Model.AnhDaiDien))
				{
					<img src="@Url.Content(Model.AnhDaiDien)" alt="Ảnh đại diện" style="max-width:200px; margin-bottom:10px;" id="imgPreview" />
				}
				else
				{
					<p>Chưa có ảnh đại diện</p>
					<img id="imgPreview" style="max-width:200px; margin-bottom:10px; display:none;" />
				}
			</div>

			<!-- Upload ảnh mới -->
			<div class="form-group">
				<label class="control-label">Chọn ảnh đại diện mới (nếu muốn thay đổi)</label>
				<input type="file" id="fileUpload" accept="image/*" />
				<input type="hidden" name="AnhDaiDien" id="AnhDaiDien" value="@Model.AnhDaiDien" />
				<span asp-validation-for="AnhDaiDien" class="text-danger"></span>
			</div>

			<div class="form-group">
				<input type="submit" value="Cập nhật" class="btn btn-primary" />
			</div>
		</form>
	</div>
</div>
<script src="/js/jquery-3.3.1.min.js"></script>
<script>
	let uploadDone = true; // mặc định true nếu không đổi ảnh

	$(document).ready(function () {
		// Load chất liệu
		$.get("/Admin/GetAllChatLieu", function (res) {
			const select = $("#ChatLieuID");
			select.empty().append('<option value="">-- Chọn chất liệu --</option>');
			res.forEach(x => {
				const selected = x.id.toLowerCase() === "@(Model.IDChatLieu.ToString().ToLower())" ? "selected" : "";
				select.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
			});
		});

		// Load loại sản phẩm
		$.get("/Admin/GetAllLoaiSP", function (res) {
			const select = $("#LoaiSPID");
			select.empty().append('<option value="">-- Chọn loại sản phẩm --</option>');
			res.forEach(x => {
				const selected = x.id.toLowerCase() === "@(Model.IDLoaiSP.ToString().ToLower())" ? "selected" : "";
				select.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
			});
		});
	});

	$("#fileUpload").on("change", function () {
		var files = this.files;

		console.log(files);
		if (files.length === 0) return;

		uploadDone = false; // đang upload

		var formData = new FormData();
		for (var i = 0; i < files.length; i++) {
			formData.append("images", files[i]);
		}

		$.ajax({
			url: '/Admin/UploadImages',
			type: 'POST',
			data: formData,
			processData: false,
			contentType: false,
			success: function (data) {
				if (data.length > 0) {
					$("#AnhDaiDien").val(data[0]);
					$("#imgPreview").attr("src", data[0]).show();
					uploadDone = true;
				}
			},
			error: function () {
				alert("Upload ảnh thất bại.");
				uploadDone = true;
			}
		});
	});

	$("#formUpdateSanPham").on("submit", function (e) {
		if (!uploadDone) {
			alert("Vui lòng chờ upload ảnh xong rồi mới cập nhật.");
			e.preventDefault();
			return false;
		}
	});

	function taoMoiLoaiSP() {
		const ten = prompt("Nhập tên loại sản phẩm mới:");
		if (!ten) return;

		$.post("/Admin/TaoLoaiSPMoiTuSanPham", { ten: ten }, function (res) {
			if (res.success) {
				alert("Đã thêm!");
				$.get("/Admin/GetAllLoaiSP", function (data) {
					const select = $("#LoaiSPID");
					select.empty().append('<option value="">-- Chọn loại sản phẩm --</option>');
					data.forEach(x => {
						const selected = x.ten === ten ? "selected" : "";
						select.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
					});
				});
			} else {
				alert("Thêm thất bại.");
			}
		});
	}

	function taoMoiChatLieu() {
		const ten = prompt("Nhập tên chất liệu mới:");
		if (!ten) return;

		$.post("/Admin/TaoChatLieuMoiTuSanPham", { ten: ten }, function (res) {
			if (res.success) {
				alert("Đã thêm!");
				$.get("/Admin/GetAllChatLieu", function (data) {
					const select = $("#ChatLieuID");
					select.empty().append('<option value="">-- Chọn chất liệu --</option>');
					data.forEach(x => {
						const selected = x.ten === ten ? "selected" : "";
						select.append(`<option value="${x.id}" ${selected}>${x.ten}</option>`);
					});
				});
			}
		});
	}

	function disableSubmit(form) {
		const btn = form.querySelector('input[type="submit"], button[type="submit"]');
		if (btn) {
			btn.disabled = true;
			btn.value = "Đang xử lý...";
		}
		return true;
	}
</script>
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
