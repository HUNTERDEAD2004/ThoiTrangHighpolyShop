@{
    ViewData["Title"] = "ProductManager";
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

}

<h1>Danh sách sản phẩm</h1>

<div class="row">
    <div class="col-lg-4">
        <a asp-action="AddSanPham" class="btn-dark-custom"> Thêm sản phẩm</a>
    </div>
    <div class="col-lg-8 d-flex justify-content-end">
        <div class="col-lg-1" style="padding:0px">
            <p style="text-align:end;margin-top:5px;margin-right:5px">Sắp xếp: </p>
        </div>
        <div class="col-lg-3" style="padding:0px;margin-right:5px">
            <select class="form-select" id="sort" onchange="ReloadPagination()">
                <option value="1">Sắp xếp theo mã</option>
                <option value="6">Sắp xếp theo tên</option>
                <option value="2">Sắp xếp theo giá tăng dần</option>
                <option value="3">Sắp xếp theo giá giảm dần</option>
                <option value="4">Sắp xếp theo số lượng tăng dần</option>
                <option value="5">Sắp xếp theo số lượng giảm dần</option>
                <option selected value="7">Sắp xếp theo mới nhất</option>
            </select>
        </div>
        <div class="col-lg-1" style="padding:0px">
            <button class="btn" style="border:1px solid black" type="button" data-bs-toggle="collapse" data-bs-target=".filter"><i class="bx bx-filter-alt"></i></button>
        </div>
    </div>   
</div>
<div class="row filter collapse" style="margin-bottom:10px">
    <div class="col-lg-3" style="padding-left:0px;padding-right:2px">
        <p style="margin:0px;">Tên sản phẩm:</p>
        <input type="text" class="form-control" placeholder="Tìm kiếm theo tên sản phẩm" style="width:100%"  id="searchName">
    </div>
    <div class="col-lg-2" style="padding-left:2px;padding-right:2px">
        <p style="margin:0px">Giá bán từ:</p>
        <select class="form-select" id="priceMin">
            <option value="">Min</option>
            <option value="100000">100.000</option>
            <option value="200000">200.000</option>
            <option value="500000">500.000</option>
            <option value="1000000">1.000.000</option>
            <option value="2000000">2.000.000</option>
            <option value="2000000">5.000.000</option>
            <option value="2000000">10.000.000</option>
        </select>
    </div>
    <div class="col-lg-2" style="padding-left:2px;padding-right:2px">
        <p style="margin:0px">Đến:</p>
        <select class="form-select" id="priceMax">
            <option value="">Max</option>
            <option value="200000">200.000</option>
            <option value="500000">500.000</option>
            <option value="1000000">1.000.000</option>
            <option value="2000000">2.000.000</option>
            <option value="2000000">5.000.000</option>
            <option value="2000000">10.000.000</option>
        </select>
    </div>

    <div class="col-lg-4" style="padding-left:2px;padding-right:2px">
        <p style="margin:0px">Loại sản phẩm:</p>
        <select class="form-select" id="categoryFilter">
            <option value="all" selected>Tất cả</option>
        </select>
    </div>
    <div class="col-lg-1" style="padding-left:2px;padding-right:2px">
        <p style="margin:0px">&ensp;</p>
        <button class="btn btn-primary" type="button" onclick="ReloadPagination()">Lọc</button>
    </div>
</div>
<div class=" row">
    <table class="table">
        <thead>
            <tr>
                <th>
                    STT
                </th>
                <th>
                    Mã
                </th>
                <th>
                    Tên
                </th>
                <th>
                    Ảnh
                </th>
                <th>
                    Giá gốc
                </th>
                <th>
                    Giá bán
                </th>
                <th>
                    Số lượng
                </th>
                <th>
                    Chất liệu
                </th>
                <th>
                    Loại sản phẩm
                </th>
                <th>
                    Trạng thái
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody id="list_products">
        </tbody>
    </table>
</div>

<div class="row">
    <div class="col-lg-12 d-flex justify-content-center">
        <ul id="pagination-demo" class="pagination"></ul>
    </div>
</div>
<script src="/js/jquery-3.3.1.min.js"></script>
<script>
    var pageIndex = 1;
    var pagesize = 10;

    $(document).ready(function () {
        loadsp();
            $.ajax({
            type: "GET",
            dataType: "json",
            url: "/Admin/GetLoaiSP",
            success: function (response) {
            $('#categoryFilter').empty(); // clear trước nếu đã có option cũ
            $('#categoryFilter').append(`<option value="all" selected>Tất cả</option>`);
            for (var i = 0; i < response.length; i++) {
                var option = `<option value="${response[i].ten}">${response[i].ten}</option>`;
                $('#categoryFilter').append(option);
                    }
                }       

            });
    });

    function loadsp() {
        var searchName = $("#searchName").val();
        var min = $("#priceMin").val();
        var max = $("#priceMax").val();
        var sort = $("#sort").val();
        var loaiSP = $("#categoryFilter").val();
        if (loaiSP === null || loaiSP === "all") {
            loaiSP = null;
        }

        var request = {
            page: pageIndex,
            pageSize: pagesize,
            search: searchName,
            minPrice: min,
            maxPrice: max,
            loaiSP: loaiSP,
            sortSP: sort
        };

        $.ajax({
            url: "/Admin/ShowProduct",
            type: "GET",
            data: request,
            success: function (response) {
                $("#list_products").empty();
                $.each(response.data, function (i, item) {
                    let stt = (pageIndex - 1) * pagesize + i + 1;
                    if (item.trangThai == 1) {
                        $("#list_products").append(`
                                <tr>
								    <td>${stt}</td>
                                    <td>${item.ma}</td>
                                    <td>${item.ten}</td>
                                    <td><img src="${item.anh}" style="width:70px;height:80px" /></td>
                                    <td>${item.giaGoc}</td>
                                    <td>${item.giaBan}</td>
                                    <td>${item.soLuong}</td>
                                    <td>${item.chatLieu}</td>
                                    <td>${item.loaiSP}</td>
                                    <td id='hoatDong_${item.id}'<span style="color:green">Hoạt động</span></td>
                                    <td id='xoa_${item.id}'>
                                        <a href='/Admin/ProductDetail?idSanPham=${item.id}' class="btn btn-info btn-sm"  title="Chi tiết"><i class="fas fa-info-circle"></i></a>
                                        <a href='/Admin/UpdateSanPham?id=${item.id}' class="btn btn-warning btn-sm" title="Sửa"><i class="fas fa-edit"></i></a>
                                    <button type='button' onclick="xoa('${item.id}',0)" class="btn btn-danger btn-sm"  title="Xóa"><i class="fas fa-trash-alt"></i></button>
                                </td>
                                </tr>`);
                    } else {
                        $("#list_products").append(`
                                <tr>
                                    <td>${stt}</td>
                                    <td>${item.ma}</td>
                                    <td>${item.ten}</td>
                                    <td><img src="${item.anh}" style="width:70px;height:80px" /></td>
                                    <td>${item.giaGoc}</td>
                                    <td>${item.giaBan}</td>
                                    <td>${item.soLuong}</td>
                                    <td>${item.chatLieu}</td>
                                    <td>${item.loaiSP}</td>
                                    <td id='hoatDong_${item.id}'<span style="color:red">Không hoạt động</span></td>
                                    <td id='xoa_${item.id}'>
                                        <a href='/Admin/ProductDetail?idSanPham=${item.id}' class="btn btn-info btn-sm" title="Chi tiết"><i class="fas fa-info-circle"></i></a>
                                        <a href='/Admin/UpdateSanPham?id=${item.id}' class="btn btn-warning btn-sm" title="Sửa"><i class="fas fa-edit"></i></a>
                                    <button type='button' onclick="xoa('${item.id}',1)" class="btn btn-success btn-sm" title="Hoàn tác"><i class="fas fa-undo-alt"></i></button>
                                </td>
                                </tr>`);
                    }
                });

                pagingsp(response.total, function () {
                    loadsp();
                });
            },
            error: function (err) {
                console.log('Error:', err);
            }
        });
    }

    function pagingsp(totalrow, callback) {
        var totalgages = Math.ceil(totalrow / pagesize);
        $("#pagination-demo").twbsPagination({
            totalPages: totalgages,
            visiblePages: 7,
            initiateStartPageClick: false,
            onPageClick: function (event, page) {
                pageIndex = page;
                setTimeout(callback, 200);
            }
        });
    }


    function ReloadPagination() {
        $("#pagination-demo").twbsPagination('destroy');
        loadsp();
    }

    function xoa(id, status) {
        $.ajax({
            type: "post",
            dataType: "json",
            data: { idSanPham: id, trangThai: status },
            url: "/Admin/UpdateTrangThaiSanPham",
            success: function (response) {
                if (response.status) {
                    if (response.ketQua == 0) {
                        document.getElementById("hoatDong_" + id).innerHTML = '<span style="color:red">Không hoạt động</span>';
                        var ip = document.getElementById("xoa_" + id);
                        ip.removeChild(ip.children[2]);
                        $("#xoa_" + id).append("<button type='button' class='btn btn-success btn-sm' title='Hoàn tác' onclick=\"xoa('" + id + "',1)\">" + "<i class='fas fa-undo-alt'></i></button>");
                    } else if (response.ketQua == 1) {
                        document.getElementById("hoatDong_" + id).innerHTML = '<span style="color:green">Hoạt động</span>';
                        var ip = document.getElementById("xoa_" + id);
                        ip.removeChild(ip.children[2]);
                        $("#xoa_" + id).append("<button type='button' class='btn btn-danger btn-sm' title='Xóa' onclick=\"xoa('" + id + "',0)\">" + "<i class='fas fa-trash-alt'></i></button>");
                    }
                } else {
                    alert('Error');
                }
            }
        });
    }
</script>



<style>
    /* Nút đen sáng với chữ trắng */
    .btn-dark-custom {
        background: #333; /* đen sáng */
        color: #fff !important; /* chữ trắng */
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        font-size: 15px;
        font-weight: 500;
        transition: 0.3s ease;
        display: inline-block;
        text-decoration: none;
    }

        .btn-dark-custom:hover {
            background: #000; /* đậm hơn khi hover */
            color: #fff !important;
            text-decoration: none;
        }
    /* Nút đen/xám mặc định */
    .btn-dark-gray {
        background: #333; /* màu đen xám */
        color: #fff !important; /* chữ trắng */
        border: 1px solid #333;
        padding: 6px 12px;
        border-radius: 6px;
        transition: all 0.3s ease;
        text-decoration: none; /* bỏ gạch chân ở thẻ a */
        display: inline-block;
    }

        /* Hover đảo màu */
        .btn-dark-gray:hover {
            background: #fff; /* nền trắng */
            color: #333 !important; /* chữ đen */
            border: 1px solid #333;
        }

        /* Các nút liền nhau sẽ có khoảng cách */
        .btn-dark-gray + .btn-dark-gray {
            margin-left: 6px;
        }
</style>
