@model AppData.ViewModels.SanPham.ChiTietSanPhamUpdateRequest

@{
    ViewData["Title"] = "Thêm chi tiết sản phẩm";
    string idSanPham = TempData["IDSanPham"] as string;
}

<h1>Thêm chi tiết sản phẩm</h1>

<hr />
<form asp-action="AddChiTietSanPham" id="formAddChiTietSanPham">
    <div class="row justify-content-center">
        <!-- Cột chính: màu sắc + kích cỡ -->
        <div class="col-md-6">
            <!-- MÀU SẮC -->
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Màu sắc</label>
                <div id="lstMauSac" class="d-flex flex-wrap gap-2 mb-2">
                    <!-- JS render -->
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="themBienTheMauSac()">
                        Thêm biến thể màu
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="taoMoiMauSac()">
                        Thêm màu
                    </button>
                </div>
            </div>

            <!-- KÍCH CỠ -->
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Kích cỡ</label>
                <div id="lstKichCo" class="d-flex flex-wrap gap-2 mb-2">
                    <!-- JS render -->
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="themBienTheKichCo()">
                        Thêm biến thể kích cỡ
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm flex-grow-1" onclick="taoMoiKichCo()">
                        Thêm kích cỡ
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Nút submit -->
    <div class="form-group text-center mt-4">
        <input type="submit" value="Thêm chi tiết sản phẩm" class="btn btn-secondary px-4 py-2" />
        <a asp-action="ProductDetail" asp-controller="Admin" asp-route-idSanPham="@idSanPham" class="btn btn-outline-orange me-2"> <i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
</form>


<script src="~/js/jquery-3.3.1.min.js"></script>
<script>
    let countKichCo = 0, countMauSac = 0;
    let lstMauSac = [];
    let lstKichCo = [];

    $(document).ready(function () {
        $.get("/Admin/GetAllKichCo", function (res) {
            lstKichCo = res.map(x => ({ id: x.id, ten: x.ten }));
            themBienTheKichCo();
        });

        $.get("/Admin/GetAllMauSac", function (res) {
            if (!res || res.length === 0) return;

            lstMauSac = res.map(x => ({ id: x.id, ten: x.ten, ma: x.ma?.toLowerCase() || "#000" }));
            countMauSac = 0;
            $("#lstMauSac").empty();
            themBienTheMauSac();
        });
    });

     // --- Tạo mới Kích cỡ ---
     function taoMoiKichCo() {
        const ten = prompt("Nhập kích cỡ mới:");
        if (!ten || !ten.trim()) {
            alert("Tên kích cỡ không được để trống!");
            return;
        }

        $.post("/Admin/TaoKichCoMoiTuSanPham", { ten: ten.trim() }, function(res) {
            if (res.success && res.data) {
                alert("Thêm kích cỡ thành công!");
                // gọi lại API GetAllKichCo và render
                $.get("/Admin/GetAllKichCo", function(list) {
                    lstKichCo = list.map(x => ({ id: x.id, ten: x.ten }));
                    $("#lstKichCo").empty();
                    countKichCo = 0;
                    themBienTheKichCo();
                });
            } else {
                alert(res.message || "Thêm thất bại!");
            }
        }).fail(function(xhr) {
            alert("Lỗi kết nối: " + (xhr.responseText || xhr.statusText));
        });
    }

    // --- Tạo mới Màu sắc ---
    function taoMoiMauSac() {
        const ten = prompt("Tên màu:");
        const ma = prompt("Mã hex màu (#xxxxxx):");
        if (!ten || !ma) return;

        $.ajax({
            url: "/Admin/TaoMauMoiTuSanPham",
            type: "POST",
            data: { ten: ten, ma: ma, trangthai: 1 }, // ví dụ trạng thái mặc định là 1 (đang dùng)
            success: function (res) {
                alert("Thêm thành công!");
                $.get("/Admin/GetAllMauSac", function (data) {
                    lstMauSac = data.map(x => ({ id: x.id, ten: x.ten, ma: x.ma.toLowerCase() }));
                    $("#lstMauSac").empty();
                    countMauSac = 0;
                    themBienTheMauSac();
                });
            },
            error: function () {
                alert("Thêm thất bại!");
            }
        });
    }

    function themBienTheKichCo() {
        const id = countKichCo;
        const html = `
            <div class="d-flex align-items-center gap-2" id="kichco${id}">
                <select name="IDKichCos[${id}]" class="form-select" style="width: 250px;">
                    ${lstKichCo.map(x => `<option value="${x.id}">${x.ten}</option>`).join("")}
                </select>
                <button type="button" class="btn btn-danger btn-sm" onclick="xoaKichCo(${id})">-</button>
            </div>`;
        $("#lstKichCo").append(html);
        countKichCo++;
    }

    function xoaKichCo(id) {
        $(`#kichco${id}`).remove();
    }

    function themBienTheMauSac() {
        const id = countMauSac;

        const html = `
            <div class="d-flex align-items-center gap-2" id="mau${id}">
                <select id="selectMau${id}" name="IDMauSacs[${id}]" class="form-select" style="width: 250px;" onchange="changeMauSac(${id})">
                    ${lstMauSac.map(x => `<option value="${x.id}">${x.ten}</option>`).join('')}
                </select>
                <input name="MauSacs[${id}].Ma" type="color" class="form-control" style="width: 60px;" id="maMau${id}" value="${lstMauSac[0]?.ma || '#000'}" />
                <button type="button" class="btn btn-danger btn-sm" onclick="xoaMau(${id})">-</button>
            </div>`;

        $("#lstMauSac").append(html);
        countMauSac++;
    }

    function changeMauSac(id) {
        const selectedID = document.getElementById(`selectMau${id}`).value;
        const mau = lstMauSac.find(x => x.id == selectedID);
        if (mau) {
            document.getElementById(`maMau${id}`).value = mau.ma;
        }
    }

    function xoaMau(id) {
        $(`#mau${id}`).remove();
    }
</script>

<style>
    .form-group {
        margin-bottom: 16px;
    }

    .form-control, .form-select {
        height: 42px;
    }

    .btn-secondary {
        background: #6c757d !important;
        color: #fff !important;
        border: none;
    }

        .btn-secondary:hover {
            background: #5a6268 !important;
        }

    .gap-2 {
        gap: 8px;
    }

    #lstMauSac > div, #lstKichCo > div {
        width: 48%;
        padding: 6px;
        border: 1px solid #ddd;
        border-radius: 6px;
        background: #fff;
    }



    .btn-outline-orange {
        background-color: #fff;
        color: #000 !important;
        border: 1px solid #ff6600;
        transition: 0.3s;
    }

        .btn-outline-orange:hover {
            background-color: #ff6600;
            color: #fff !important;
        }
</style>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
