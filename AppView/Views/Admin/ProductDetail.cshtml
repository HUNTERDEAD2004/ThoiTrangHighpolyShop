@{
    ViewData["Title"] = "ProductDetail";
    string idSanPham = TempData["IDSanPham"] as string;
}

<h1>Chi tiết sản phẩm</h1>

<div class="row mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label mb-0">Sắp xếp:</label>
    </div>
    <div class="col-auto">
        <select class="form-select" id="sort" onchange="ReloadPagination()">
            <option selected value="1">Theo mã</option>
            <option value="2">Giá tăng dần</option>
            <option value="3">Giá giảm dần</option>
            <option value="4">SL tăng dần</option>
            <option value="5">SL giảm dần</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target=".filter">
            <i class="bx bx-filter-alt"></i>
        </button>
    </div>
</div>

<div class="row filter collapse mb-3">
    <div class="col-md-3">
        <label class="form-label">Mã sản phẩm</label>
        <input type="text" class="form-control" placeholder="Tìm theo mã" id="searchName">
    </div>
    <div class="col-md-2">
        <label class="form-label">Giá bán Min</label>
        <input type="number" class="form-control" id="priceMin">
    </div>
    <div class="col-md-2">
        <label class="form-label">Giá bán Max</label>
        <input type="number" class="form-control" id="priceMax">
    </div>
    <div class="col-md-2">
        <label class="form-label">SL Min</label>
        <input type="number" class="form-control" id="quantityMin">
    </div>
    <div class="col-md-2">
        <label class="form-label">SL Max</label>
        <input type="number" class="form-control" id="quantityMax">
    </div>
    <div class="col-md-1 d-flex align-items-end">
        <button class="btn btn-primary w-100" type="button" onclick="ReloadPagination()">Lọc</button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover">
        <thead class="table-light text-center">
            <tr>
                <th>STT</th> <!-- thêm dòng này -->
                <th>Mã</th>
                <th>Tên màu</th>
                <th>Mã màu</th>
                <th>Size</th>
                <th>SL</th>
                <th>Giá gốc</th>
                <th>Giá bán</th>
                <th>Mặc định</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody id="list_productdetails"></tbody>
    </table>
</div>

<div class="d-flex justify-content-end mb-3">
    <a asp-action="QuanLyAnhChiTiet" asp-route-idSanPham="@idSanPham" class="btn btn-outline-success me-2">Quản lý ảnh</a>
    <a asp-action="AddChiTietSanPham" asp-route-idSanPham="@idSanPham" class="btn btn-primary">Thêm chi tiết</a>
</div>

<div class="row">
    <div class="col-lg-12 d-flex justify-content-center">
        <ul id="pagination-demo" class="pagination"></ul>
    </div>
</div>

<!-- Modal Sửa Giá & SL -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">Cập nhật giá & số lượng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Giá gốc mới</label>
                        <input type="number" id="editGiaGoc" class="form-control" min="0">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số lượng mới</label>
                        <input type="number" id="editSoLuong" class="form-control" min="0">
                    </div>
                </div>

                <table class="table table-bordered table-hover">
                    <thead>
                        <tr>
                            <th style="width:40px;"><input type="checkbox" id="checkAll"></th>
                            <th>Mã</th>
                            <th>Tên màu</th>
                            <th>Size</th>
                            <th>SL hiện tại</th>
                            <th>Giá gốc hiện tại</th>
                        </tr>
                    </thead>
                    <tbody id="modalProductList"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <!-- ✅ sửa tên hàm cho đúng -->
                <button type="button" class="btn btn-primary" onclick="updateMultipleProductDetails()">Cập nhật</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/jquery-3.3.1.min.js"></script>
<script>
    var pageIndex = 1;
    var pageSize = 10;
    var idSanPham = '@idSanPham';

    $(document).ready(function () {
        loadProductDetails(true);
    });

    function loadProductDetails(resetPagination = false) {
        showLoading(true);

        var request = {
            page: pageIndex,
            pageSize: pageSize,
            id: idSanPham,
            ma: $("#searchName").val(),
            minPrice: $("#priceMin").val(),
            maxPrice: $("#priceMax").val(),
            minQuantity: $("#quantityMin").val(),
            maxQuantity: $("#quantityMax").val(),
            sort: $("#sort").val()
        };

        $.ajax({
            url: "/Admin/ShowProductDetail",
            type: "GET",
            data: request,
            success: function (response) {
                $("#list_productdetails").empty();
                $.each(response.data, function (i, item) {
                    let stt = (pageIndex - 1) * pageSize + i + 1;
                    let radioBtn = item.trangThai == 1
                        ? `<input type="radio" name="macDinh" ${item.macDinh ? "checked" : ""} onclick="capNhatMacDinh('${item.id}')" />`
                        : `<input type="radio" name="macDinh" ${item.macDinh ? "checked" : ""} disabled />`;

                    let hoatDongText = item.trangThai == 1
                        ? `<span style="color:green">Hoạt động</span>`
                        : `<span style="color:red">Không hoạt động</span>`;

                    let actionButtons = "";

                    // chức năng tạo mã qr sẽ nâng cấp sau không được xóa
                    // let actionButtons = `<a href="/Admin/GenerateQRCode?id=${item.id}&ma=${item.ma}" class="btn btn-secondary">Tạo mã QR</a>`;

                    if (item.trangThai == 0) {
                            const canUndo = item.giaGoc > 0 && item.soLuong > 0;
                            const titleUndo = !canUndo
                                ? `title="Không thể hoàn tác: ${(item.giaGoc <= 0 ? 'Giá bán không hợp lệ. ' : '')}${(item.soLuong <= 0 ? 'Số lượng không hợp lệ.' : '')}"`
                                : '';
                            actionButtons += `<button type="button" class="btn btn-success" ${canUndo ? `onclick="undo('${item.id}')"` : "disabled"} ${titleUndo}>Hoàn tác</button>`;
                    }
                    else {
                        actionButtons += `<button type="button" class="btn btn-danger" onclick="xoa('${item.id}')">Xóa</button>`;
                    }

                    // luôn hiển thị nút sửa
                    actionButtons += `<button type="button" class="btn btn-warning" onclick="openEditModal()">Sửa</button>`;

                    $("#list_productdetails").append(`
                        <tr>
                            <td>${stt}</td>
                            <td>${item.ma}</td>
                            <td>${item.tenMauSac}</td>
                            <td><input type="color" value="${item.maMauSac}" style="border:none;width:27px;height:25px" disabled></td>
                            <td>${item.tenKichCo}</td>
                            <td style="width:100px">
                                <input type="number" value="${item.soLuong}" id="soLuong_${item.id}" onchange="changeSoLuong('${item.id}')" min="0" class="form-control form-control-sm">
                            </td>
                            <td style="width:100px">
                                <input type="number" value="${item.giaGoc}" id="giaGoc_${item.id}" onchange="changeGiaBan('${item.id}')" min="0" class="form-control form-control-sm">
                            </td>
                            <td id="giaBan_${item.id}">${item.giaBan}</td>
                            <td>${radioBtn}</td>
                            <td id="hoatDong_${item.id}">${hoatDongText}</td>
                            <td id="xoa_${item.id}">${actionButtons}</td>
                        </tr>
                    `);
                });

                if (resetPagination) {
                    setupPagination(response.total);
                }

                showLoading(false);
            },
            error: function (err) {
                alert("Lỗi khi tải chi tiết sản phẩm.");
                console.log(err);
                showLoading(false);
            }
        });
    }

    function setupPagination(totalRows) {
        $("#pagination-demo").twbsPagination('destroy');
        $("#pagination-demo").twbsPagination({
            totalPages: Math.ceil(totalRows / pageSize),
            visiblePages: 7,
            onPageClick: function (event, page) {
                pageIndex = page;
                loadProductDetails(false);
            }
        });
    }

    function ReloadPagination() {
        pageIndex = 1;
        loadProductDetails(true);
    }

    function changeSoLuong(idSP) {
        let ip = document.getElementById("soLuong_" + idSP);
        let value = parseInt(ip.value);
        if (value < 0) {
            alert("Số lượng không được âm");
            ip.value = 0;
            return;
        }
        $.post('/Admin/UpdateSoluongChiTietSanPham', { id: idSP, soLuong: value }, function (res) {
        if (!res.success) {
            alert("Cập nhật số lượng thất bại.");
        }
        }).fail(function () {
            alert("Có lỗi xảy ra khi cập nhật số lượng.");
        });
    }

    function changeGiaBan(idSP) {
        let ip = document.getElementById("giaGoc_" + idSP);
        let value = parseInt(ip.value);
        if (value < 0) {
            alert("Giá không được âm");
            ip.value = 0;
            return;
        }
        $.post('/Admin/UpdateGiaGocChiTietSanPham', { id: idSP, giaGoc: value }, function (res) {
        if (res.success) {
            // Cập nhật lại giá bán hiển thị
            $("#giaBan_" + idSP).text(res.giaBan);
        } else {
            alert("Cập nhật giá thất bại.");
        }
    });

    }

    function changeTrangThai(idSP, trangThai) {
        $.post('/Admin/UpdateTrangThaiChiTietSanPham', { id: idSP, trangThai: trangThai }, function (response) {
            if (response) {
                alert("Cập nhật thành công.");
                ReloadPagination();
            } else {
                alert("Không thể cập nhật trạng thái. Kiểm tra điều kiện sản phẩm cha, số lượng, giá bán hoặc mặc định.");
            }
        }).fail(function () {
            alert("Có lỗi xảy ra khi cập nhật trạng thái.");
        });
    }

    function xoa(idSP) {
        $("#xoa_" + idSP).html("Đang xử lý...");

        $.ajax({
            url: '/Admin/DeleteProductDetail?id=' + idSP,
            type: 'DELETE',
            success: function (res) {
                if (res.trangThai) {
                    ReloadPagination();
                } else {
                    alert(res.loi);
                }
            },
            error: function () {
                alert("Lỗi khi gửi yêu cầu xoá.");
            }
        });
    }

    function undo(idSP) {
        $.get('/Admin/UndoProductDetail', { id: idSP }, function (res) {
            if (res.trangThai) {
                ReloadPagination();
            } else {
                alert(res.loi || "Không thể hoàn tác.");
            }
        }).fail(function () {
            alert("Có lỗi xảy ra khi gọi API hoàn tác.");
        });
    }

    function capNhatMacDinh(idChiTiet) {
        $.post('/Admin/UpdateMacDinhChiTietSanPham', { id: idChiTiet }, function (res) {
            if (res.trangThai === true) {
                alert("Đã cập nhật mặc định thành công.");
                ReloadPagination();
            } else {
                alert("Cập nhật mặc định thất bại.\n" + (res.message || ""));
            }
        }).fail(function () {
            alert("Có lỗi xảy ra khi gọi API.");
        });
    }

    function showLoading(show) {
        if (show) {
            $("#list_productdetails").html(`<tr><td colspan="11" class="text-center">Đang tải...</td></tr>`);
        }
    }

    function openEditModal() {
        $("#editGiaGoc").val("");
        $("#editSoLuong").val("");
        $("#modalProductList").html(`<tr><td colspan="6" class="text-center">Đang tải...</td></tr>`);

        // Lấy danh sách chi tiết sản phẩm (không phân trang, để chọn nhiều)
        $.get('/Admin/ShowProductDetail', { page: 1, pageSize: 999, id: idSanPham }, function (res) {
            if (res.data && res.data.length > 0) {
                $("#modalProductList").empty();
                $.each(res.data, function (i, item) {
                    $("#modalProductList").append(`
                        <tr>
                            <td><input type="checkbox" class="chkProduct" value="${item.id}"></td>
                            <td>${item.ma}</td>
                            <td>${item.tenMauSac}</td>
                            <td>${item.tenKichCo}</td>
                            <td>${item.soLuong}</td>
                            <td>${item.giaGoc}</td>
                        </tr>
                    `);
                });
            } else {
                $("#modalProductList").html(`<tr><td colspan="6" class="text-center">Không có dữ liệu</td></tr>`);
            }
        });

        $("#editModal").modal('show');
    }

    // Chọn tất cả checkbox
    $(document).on("change", "#checkAll", function () {
        $(".chkProduct").prop('checked', $(this).prop('checked'));
    });

    function updateMultipleProductDetails() {
        let ids = $(".chkProduct:checked").map(function () {
            return $(this).val();
        }).get();

        let giaGoc = $("#editGiaGoc").val();
        let soLuong = $("#editSoLuong").val();

        if (ids.length === 0) {
            alert("Vui lòng chọn ít nhất 1 sản phẩm.");
            return;
        }

        $.ajax({
            url: '/Admin/UpdateMultipleProductDetails',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                Ids: ids,          // ✅ đổi đúng PascalCase
                GiaGoc: giaGoc || null,
                SoLuong: soLuong || null
            }),
            success: function (res) {
                if (res.trangThai) {
                    alert("Cập nhật thành công.");
                    $("#editModal").modal('hide');
                    ReloadPagination();
                } else {
                    alert("Cập nhật thất bại.");
                }
            },
            error: function () {
                alert("Có lỗi xảy ra khi cập nhật.");
            }
        });
    }

</script>



