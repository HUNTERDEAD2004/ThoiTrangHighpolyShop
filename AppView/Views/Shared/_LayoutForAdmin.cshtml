@using Newtonsoft.Json;
@using AppData.ViewModels;
@{
    AppData.Models.AssignmentDBContext context = new AppData.Models.AssignmentDBContext();
    var loginInfor = new LoginViewModel();
    string? session = Context.Session.GetString("LoginInfor");
    if (session != null)
    {
        loginInfor = JsonConvert.DeserializeObject<LoginViewModel>(session);
    }

    var nhanvien = context.NhanViens.FirstOrDefault(x => x.ID == loginInfor.Id);
    var phanquyen = nhanvien != null ? context.VaiTros.FirstOrDefault(x => x.ID == nhanvien.IDVaiTro) : null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop Admin</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="~/Admin/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Admin/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/Admin/vendor/boxicons/css/boxicons.min.css" rel="stylesheet" />
    <link href="~/Admin/vendor/quill/quill.snow.css" rel="stylesheet" />
    <link href="~/Admin/vendor/remixicon/remixicon.css" rel="stylesheet" />
    <link href="~/Admin/vendor/simple-datatables/style.css" rel="stylesheet" />
    <link href="~/Admin/css/style.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.2/css/toastr.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #ffffff;
            color: #111111;
        }

        .header, .sidebar {
            background-color: #ffffff !important;
        }

            .sidebar .nav-link, .dropdown-menu {
                background-color: #ffffff;
                color: #000000;
            }

                .sidebar .nav-link:hover {
                    background-color: #f2f2f2;
                }

                .sidebar .nav-link.active {
                    background-color: #e0e0e0;
                    font-weight: bold;
                }
    </style>
</head>

<body>
    <!-- ======= Header ======= -->
    <header id="header" class="header fixed-top d-flex align-items-center">
        <div class="d-flex align-items-center justify-content-between">
            <a href="/" class="logo d-flex align-items-center">
                <img src="~/img/highpoly_logo.png" alt="Logo" style="height: 100px;" />
            </a>
            <i class="bi bi-list toggle-sidebar-btn"></i>
        </div>

        <nav class="header-nav ms-auto">
            <ul class="d-flex align-items-center">
                <li class="nav-item dropdown pe-3">
                    <a class="nav-link nav-profile d-flex align-items-center pe-0" href="#" data-bs-toggle="dropdown">
                        <img src="~/img/profile-imgg.jpg" alt="Profile" class="rounded-circle">
                        <span class="d-none d-md-block dropdown-toggle ps-2">@loginInfor.Ten</span>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-arrow profile">
                        <li class="dropdown-header">
                            <h6>@loginInfor.Ten</h6>
                            <span>@(phanquyen?.Ten ?? "Không xác định")</span>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center" asp-controller="NhanVien" asp-action="ProfileNhanVien_Admin">
                                <i class="bi bi-person"></i>
                                <span>Thông tin cá nhân</span>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center" asp-controller="Home" asp-action="LogOut">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Đăng xuất</span>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
        </nav>
    </header>

    <!-- ======= Sidebar ======= -->
    <aside id="sidebar" class="sidebar">
        <ul class="sidebar-nav" id="sidebar-nav">
            @if (phanquyen?.Ten == "Admin")
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="ThongKe" asp-action="ThongKeAdmin">
                        <i class="bi bi-bar-chart-line"></i><span>Thống kê</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="BanHangTaiQuay" asp-action="BanHang">
                        <i class="bi bi-shop-window"></i><span>Bán hàng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="QuanLyHoaDon" asp-action="_QuanLyHoaDon">
                        <i class="bi bi-receipt"></i><span>Quản lý hóa đơn</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Admin" asp-action="ProductManager">
                        <i class="bi bi-box-seam"></i><span>Quản lý sản phẩm</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="NhanVien" asp-action="Show">
                        <i class="bi bi-people"></i><span>Quản lý nhân viên</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="KhachHang" asp-action="GetAllKhachHang">
                        <i class="bi bi-person-lines-fill"></i><span>Quản lý khách hàng</span>
                    </a>
                </li>
            }
            else if (phanquyen?.Ten == "Nhân viên")
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="BanHangTaiQuay" asp-action="BanHang">
                        <i class="bi bi-shop"></i><span>Bán hàng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="QuanLyHoaDon" asp-action="_QuanLyHoaDon">
                        <i class="bi bi-receipt"></i><span>Hóa đơn</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="KhachHang" asp-action="GetAllKhachHang">
                        <i class="bi bi-person-lines-fill"></i><span>Khách hàng</span>
                    </a>
                </li>
            }
        </ul>
    </aside>

    <!-- ======= Main Content ======= -->
    <main id="main" class="main">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- ======= Scripts ======= -->
    <script src="~/Admin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Admin/vendor/chart.js/chart.umd.js"></script>
    <script src="~/Admin/vendor/echarts/echarts.min.js"></script>
    <script src="~/Admin/vendor/quill/quill.min.js"></script>
    <script src="~/Admin/vendor/simple-datatables/simple-datatables.js"></script>
    <script src="~/Admin/js/main.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.2/js/toastr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
