@model AppData.ViewModels.KhuyenMaiView

@{
    ViewData["Title"] = "Sửa khuyến mãi";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Sửa Khuyến Mãi</h2>

    <form asp-action="Update">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- Hidden fields -->
        <input asp-for="ID" type="hidden" />
        <input asp-for="Ten" type="hidden" />
        <input asp-for="GiaTri" type="hidden" />

        <div class="row g-3">
            <!-- Ngày áp dụng -->
            <div class="col-md-6">
                <label class="form-label fw-bold">Ngày áp dụng</label>
                <input asp-for="NgayApDung" type="datetime-local" class="form-control" />
                <span class="text-danger">@ViewData["NgayApDung"]</span>
            </div>

            <!-- Ngày kết thúc -->
            <div class="col-md-6">
                <label class="form-label fw-bold">Ngày kết thúc</label>
                <input asp-for="NgayKetThuc" type="datetime-local" class="form-control" />
                <span class="text-danger">@ViewData["NgayKetThuc"]</span>
                <span class="text-danger">@ViewData["Ngay"]</span>
            </div>

            <!-- Mô tả -->
            <div class="col-md-12">
                <label class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="MoTa" class="form-control" rows="3" style="resize: vertical;" placeholder="Nhập mô tả khuyến mãi..."></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>
        </div>

        <!-- Buttons -->
        <div class="mt-4 d-flex gap-3">
            <button type="submit" class="btn btn-success px-4">Sửa khuyến mãi</button>
            <a asp-action="GetAllKM" class="btn btn-secondary px-4">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
