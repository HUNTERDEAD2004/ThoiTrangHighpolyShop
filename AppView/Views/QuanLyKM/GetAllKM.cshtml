@using AppData.ViewModels
@model AppView.PhanTrang.PhanTrangKhuyenMai

@{
    ViewData["Title"] = "Danh sách Khuyến Mãi";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
    int stt = 1;
}

<h2 class="text-center fw-bold mt-4 mb-4">Danh sách Khuyến Mãi</h2>



<div class="row mb-3">
    <!-- Cột trái: Nút tạo khuyến mãi -->
    <div class="col-md-6 col-12">
        <a asp-action="Create" class="btn btn-dark">
            <i class="fa fa-plus"></i> Tạo khuyến mãi
        </a>
    </div>

    <!-- Cột phải: Form tìm kiếm -->
    <div class="col-md-6 col-12 mt-2 mt-md-0">
        <form asp-action="TimKiemTenKM" asp-controller="QuanLyKM" method="get">
            <div class="input-group">
                <input type="text" name="TenKM" class="form-control" placeholder="Tìm theo tên">
                <button class="btn btn-secondary" type="submit">
                    <i class="fa fa-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>


<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark text-center">
        <tr>
            <th>STT</th>
            <th>Ma</th>
      
            <th>TÊN</th>
            <th>GIÁ TRỊ</th>
            <th>NGÀY BẮT ĐẦU</th>
            <th>NGÀY KẾT THÚC</th>
            <th>TÌNH TRẠNG</th>
            <th>TRẠNG THÁI</th>
            <th>THAO TÁC</th>
        </tr>
    </thead>
    <tbody class="text-center">
        @foreach (var item in Model.listkms)
        {
            <tr>
                <td>@(stt++)</td>
                <td><strong>@item.MaKhuyenMai</strong></td>
                <td>@item.Ten</td>
                <td>
                    @if (item.TrangThai == 0 || item.TrangThai == 2)
                    {
                        <span>@item.GiaTri.ToString("n0") VND</span>
                    }
                    else
                    {
                        <span>@item.GiaTri %</span>
                    }
                </td>
                <td>@item.NgayApDung.ToString("dd-MM-yyyy HH:mm")</td>
                <td>@item.NgayKetThuc.ToString("dd-MM-yyyy HH:mm")</td>
                <td>
                    @if (item.NgayKetThuc < DateTime.Now)
                    {
                        <span class="badge bg-primary">Đã kết thúc</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">Đang diễn ra</span>
                    }
                </td>
                <td>
                    @if (item.TrangThai == 0 || item.TrangThai == 1)
                    {
                        <span class="badge bg-primary">Hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">Đã huỷ</span>
                    }
                </td>
                <td>
                    <div class="d-flex justify-content-center gap-1">
                        <a asp-action="Update" asp-route-id="@item.ID" class="btn btn-warning btn-sm" title="Sửa">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <a asp-action="GetSPByIdKM" asp-route-id="@item.ID" class="btn btn-dark btn-sm" title="Xem chi tiết">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-danger btn-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa?');">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="col-12">
    <nav>
        @if (TempData["AlertMessage"] != null)
        {
            <div class="alert alert-@TempData["AlertType"]">
                @TempData["AlertMessage"]
            </div>

            <script>
                setTimeout(() => {
                    document.querySelector('.alert').style.display = 'none';
                }, 4000); // Ẩn sau 4 giây
            </script>
        }
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.PagingInfo.TotalPages; i++)
            {
                <li class="page-item">
                    <a class="page-link text-dark" href="/QuanLyKM/GetAllKM?ProductPage=@i">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>
