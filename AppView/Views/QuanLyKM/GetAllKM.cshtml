@using AppData.ViewModels
@model AppView.PhanTrang.PhanTrangKhuyenMai

@{
    ViewData["Title"] = "Quản lý khuyến mãi";
    Layout = "~/Views/Shared/_LayoutForAdmin.cshtml";
    int stt = 1;
}

<div class="container py-4">
    <h2 class="text-center fw-bold mb-4">Quản lý khuyến mãi</h2>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-primary" asp-action="Create">Thêm mới</a>

        <form asp-action="TimKiemTenKM" asp-controller="QuanLyKM" method="get" class="d-flex" style="width: 400px;">
            <input type="text" name="TenKM" class="form-control" placeholder="Tìm theo mã khuyến mãi" />
            <button type="submit" class="btn btn-outline-secondary ms-2">
                <i class="fa fa-search"></i>
            </button>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>STT</th>
                    <th>Mã</th>
                    <th>Giá trị</th>
                    <th>Ngày áp dụng</th>
                    <th>Ngày kết thúc</th>
                    <th>Mô tả</th>
                    <th>Tình trạng</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.listkms)
                {
                    <tr>
                        <td><strong>@stt</strong></td>
                        <td>@item.Ten</td>
                        <td class="@((item.TrangThai == 0 || item.TrangThai == 2) ? "text-danger" : "text-success")">
                            @if (item.TrangThai == 0 || item.TrangThai == 2)
                            {
                                @($"{item.GiaTri:n0} VND")
                            }
                            else
                            {
                                @($"{item.GiaTri} %")
                            }
                        </td>
                        <td class="text-success">@item.NgayApDung.ToString("dd/MM/yyyy hh:mm tt")</td>
                        <td class="@(item.NgayKetThuc >= DateTime.Now ? "text-success" : "text-danger")">
                            @item.NgayKetThuc.ToString("dd/MM/yyyy hh:mm tt")
                        </td>
                        <td>@item.MoTa</td>
                        <td class="fw-bold @(item.NgayKetThuc >= DateTime.Now ? "text-success" : "text-danger")">
                            @(item.NgayKetThuc >= DateTime.Now ? "Còn khuyến mãi" : "Hết khuyến mãi")
                        </td>
                        <td class="fw-bold @(item.TrangThai == 0 || item.TrangThai == 1 ? "text-success" : "text-danger")">
                            @(item.TrangThai == 0 || item.TrangThai == 1 ? "Sử dụng" : "Không sử dụng")
                        </td>
                        <td class="d-flex gap-2 justify-content-center">
                            <a class="btn btn-success btn-sm" asp-action="Update" asp-route-id="@item.ID">Sửa</a>

                            @if (item.TrangThai == 0 || item.TrangThai == 1)
                            {
                                <a class="btn btn-primary btn-sm" asp-action="GetSPByIdKM" asp-route-id="@item.ID">Chi tiết</a>
                                <a class="btn btn-danger btn-sm" asp-action="KoSuDung" asp-route-id="@item.ID">Không sử dụng</a>
                            }
                            else
                            {
                                <a class="btn btn-warning btn-sm" asp-action="SuDung" asp-route-id="@item.ID">Sử dụng</a>
                            }
                        </td>
                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>

    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.PagingInfo.TotalPages; i++)
            {
                <li class="page-item @(Model.PagingInfo.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="/QuanLyKM/GetAllKM?ProductPage=@i">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>
